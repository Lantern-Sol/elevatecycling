{%- doc -%}
  Elevate Cycling — B2B Problem section.
  Heading + 3 tiles explaining why excess inventory is a problem for brands.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-b2b-problem"
  data-scroll-reveal="children"
  style="
    background: #FDFCFC;
    --b2b-problem-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --b2b-problem-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
    {%- if section.settings.mobile_padding_custom -%}
      --b2b-problem-pad-top-m: {{ section.settings.padding_top_mobile | divided_by: 16.0 }}rem;
      --b2b-problem-pad-bottom-m: {{ section.settings.padding_bottom_mobile | divided_by: 16.0 }}rem;
    {%- endif -%}
  "
>
  <div class="elevate-b2b-problem__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="elevate-b2b-problem__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="elevate-b2b-problem__tiles">
        {%- for block in section.blocks -%}
          <div class="elevate-b2b-problem__tile" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <p class="elevate-b2b-problem__tile-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="elevate-b2b-problem__tile-body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .elevate-b2b-problem__inner {
    padding-block: var(--b2b-problem-pad-top-m, var(--b2b-problem-pad-top)) var(--b2b-problem-pad-bottom-m, var(--b2b-problem-pad-bottom));
    padding-inline: 0.5rem;
  }

  .elevate-b2b-problem__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #36393F;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }

  .elevate-b2b-problem__tiles {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-b2b-problem__tile {
    background: rgba(226, 227, 229, 0.4);
    border-radius: 1.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .elevate-b2b-problem__tile-title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-problem__tile-body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #36393F;
    margin: 0;
  }

  @media (min-width: 61.9375rem) {
    .elevate-b2b-problem__inner {
      padding-block: var(--b2b-problem-pad-top) var(--b2b-problem-pad-bottom);
      padding-inline: 4.375rem;
    }

    .elevate-b2b-problem__heading {
      font-size: 3.5625rem;
      margin-bottom: 2rem;
    }

    .elevate-b2b-problem__tiles {
      flex-direction: row;
      gap: 2rem;
    }

    .elevate-b2b-problem__tile {
      flex: 1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "B2B Problem",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXCESS INVENTORY IS A CASH & CHANNEL PROBLEM."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "mobile_padding_custom",
      "label": "Custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Tile title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Tile body text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Problem",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "title": "CAPITAL IS STUCK",
            "body": "Last-season frames, demo fleet, and B-stock sit on pallets for quarters while working capital stays frozen."
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "LIQUIDATORS KILL PRICE FLOORS",
            "body": "Once it hits the gray market, MAP integrity is gone — and your dealers notice. The damage outlasts the inventory."
          }
        },
        {
          "type": "tile",
          "settings": {
            "title": "NO ONE WANTS THE HEADACHE",
            "body": "Listing, photographing, shipping, returns — internal teams aren't staffed for secondary-market ops."
          }
        }
      ]
    }
  ]
}
{% endschema %}
