{%- doc -%}
  Elevate Cycling — Press hero section.
  Full-bleed background with solid dark overlay,
  center-aligned content: badge pill, heading with accent-color word,
  subtitle, and a Media Kit download card.
{%- enddoc -%}

{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign heading_html = section.settings.heading
  if section.settings.heading_accent != blank
    assign accent_open = '<span class="elevate-press-hero__accent">'
    assign accent_close = '</span>'
    assign accent_wrap = accent_open | append: section.settings.heading_accent | append: accent_close
    assign heading_html = heading_html | replace: section.settings.heading_accent, accent_wrap
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-press-hero"
  style="
    background: #0a0a0a;
    --elevate-press-hero-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-press-hero-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
    --elevate-press-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- comment -%} ── Background media ── {%- endcomment -%}
  <div class="elevate-press-hero__media">
    {%- if has_image -%}
      {%- assign img = section.settings.image -%}
      {{
        img
        | image_url: width: 3840
        | image_tag:
          widths: '375, 750, 1080, 1440, 1920, 2560, 3840',
          sizes: '100vw',
          fetchpriority: 'high',
          loading: 'eager',
          class: 'elevate-press-hero__image',
          alt: ''
      }}
    {%- else -%}
      <div class="elevate-press-hero__placeholder"></div>
    {%- endif -%}

    <div class="elevate-press-hero__overlay"></div>
  </div>

  <div class="elevate-press-hero__inner">
    {%- if section.settings.badge_text != blank -%}
      <span class="elevate-press-hero__badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="elevate-press-hero__heading">{{ heading_html }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="elevate-press-hero__subtitle">
        {{ section.settings.subtitle | newline_to_br }}
      </p>
    {%- endif -%}

    {%- if section.settings.media_kit_show -%}
      <div class="elevate-press-hero__media-kit">
        <p class="elevate-press-hero__media-kit-title">
          {{ section.settings.media_kit_heading }}
        </p>
        <p class="elevate-press-hero__media-kit-desc">
          {{ section.settings.media_kit_description }}
        </p>
        {%- assign kit_url = section.settings.media_kit_url -%}
        <a {% if kit_url != blank %}href="{{ kit_url }}" download{% endif %}
           class="elevate-press-hero__media-kit-btn"
           {% if kit_url == blank %}aria-disabled="true"{% endif %}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3V15M12 15L7.5 10.5M12 15L16.5 10.5" stroke="#FDFCFC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M4 17V19C4 19.5304 4.21071 20.0391 4.58579 20.4142C4.96086 20.7893 5.46957 21 6 21H18C18.5304 21 19.0391 20.7893 19.4142 20.4142C19.7893 20.0391 20 19.5304 20 19V17" stroke="#FDFCFC" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{ section.settings.media_kit_button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ─── Press Hero ─── */
  .elevate-press-hero {
    position: relative;
    overflow: hidden;
    padding-block-start: var(--elevate-press-hero-pt);
    padding-block-end: var(--elevate-press-hero-pb);
  }

  .elevate-press-hero__inner {
    grid-column: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 16rem;
    padding-inline: 0.5rem;
    gap: 1rem;
  }

  /* ── Media layer ── */
  .elevate-press-hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest);
    grid-column: 1 / -1;
  }

  .elevate-press-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .elevate-press-hero__placeholder {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
  }

  .elevate-press-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--elevate-press-hero-overlay-opacity, 0.95));
    pointer-events: none;
  }

  /* ── Badge ── */
  .elevate-press-hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3125rem 0.75rem;
    background: #E31E24;
    border-radius: 62.4375rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
    text-transform: uppercase;
  }

  /* ── Heading ── */
  .elevate-press-hero__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3.5625rem;
    line-height: 1;
    color: #FDFCFC;
    text-align: center;
    margin: 0;
  }

  .elevate-press-hero__accent {
    color: #E31E24;
  }

  /* ── Subtitle ── */
  .elevate-press-hero__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #E2E3E5;
    margin: 0;
  }

  /* ── Media Kit card ── */
  .elevate-press-hero__media-kit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 24rem;
    padding: 1rem;
    background: rgba(226, 227, 229, 0.4);
    border-radius: 1.5rem;
  }

  .elevate-press-hero__media-kit-title {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.5;
    color: #FDFCFC;
    text-transform: uppercase;
    text-align: center;
    margin: 0;
  }

  .elevate-press-hero__media-kit-desc {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    color: #FDFCFC;
    text-align: center;
    margin: 0;
  }

  .elevate-press-hero__media-kit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1.5rem;
    background: #E31E24;
    border: none;
    border-radius: 0.75rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.03em;
    color: #FDFCFC;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .elevate-press-hero__media-kit-btn:hover {
    background: #c9191f;
  }

  .elevate-press-hero__media-kit-btn:focus-visible {
    outline: 2px solid #FDFCFC;
    outline-offset: 2px;
  }

  .elevate-press-hero__media-kit-btn svg {
    flex-shrink: 0;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-press-hero__inner {
      min-height: 20rem;
      padding-inline: 4.375rem;
    }

    .elevate-press-hero__heading {
      font-size: 4rem;
    }

    .elevate-press-hero__subtitle {
      max-width: 35.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Press Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 95
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "BLOG"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Cycling Garage"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent text",
      "info": "Word(s) within the heading to highlight in red.",
      "default": "Garage"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Buying guides, gear reviews, and CPO advice\nfrom the Elevate mechanics team."
    },
    {
      "type": "header",
      "content": "Media Kit"
    },
    {
      "type": "checkbox",
      "id": "media_kit_show",
      "label": "Show Media Kit card",
      "default": true
    },
    {
      "type": "text",
      "id": "media_kit_heading",
      "label": "Media Kit heading",
      "default": "MEDIA KIT"
    },
    {
      "type": "text",
      "id": "media_kit_description",
      "label": "Media Kit description",
      "default": "Logos, brand guidelines, and press assets."
    },
    {
      "type": "text",
      "id": "media_kit_button_text",
      "label": "Media Kit button text",
      "default": "Download Media Kit"
    },
    {
      "type": "url",
      "id": "media_kit_url",
      "label": "Media Kit download link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Press Hero"
    }
  ]
}
{% endschema %}
