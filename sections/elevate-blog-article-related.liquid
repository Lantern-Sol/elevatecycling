{%- doc -%}
  Elevate Cycling — Related Articles section for article pages.
  Shows a gradient card container with articles from the same blog,
  excluding the current article. Horizontal swipe slider on mobile,
  3-column grid on desktop.
{%- enddoc -%}

{%- liquid
  assign heading      = section.settings.heading
  assign count        = section.settings.articles_count
  assign cta_text     = section.settings.cta_text
  assign cta_url      = section.settings.cta_url | default: blog.url
  assign pt           = section.settings.padding_top | times: 0.0625
  assign pb           = section.settings.padding_bottom | times: 0.0625
  assign sid          = section.id
-%}

{%- if blog.articles_count > 1 -%}
<div
  class="section section--page-width page-width-normal elevate-blog-related"
  data-scroll-reveal
  style="
    background: linear-gradient(180deg, #F1DBDC 0%, #FDFCFC 100%);
    padding-block-start: {{ pt }}rem;
    padding-block-end: {{ pb }}rem;
    border-radius: 2rem;
    overflow: hidden;
  "
>
  <div class="elevate-blog-related__inner">
    {%- if heading != blank -%}
      <h2 class="elevate-blog-related__heading">{{ heading }}</h2>
    {%- endif -%}

    {%- comment -%} ── Slider track (mobile) / Grid (desktop) ── {%- endcomment -%}
    <div class="elevate-blog-related__slider" id="related-slider-{{ sid }}">
      {%- assign shown = 0 -%}
      {%- for related_article in blog.articles -%}
        {%- if related_article.id == article.id -%}
          {%- continue -%}
        {%- endif -%}
        {%- if shown >= count -%}
          {%- break -%}
        {%- endif -%}
        {%- assign shown = shown | plus: 1 -%}

        {%- liquid
          assign badge_text = related_article.metafields.custom.article_badge.value
          assign word_count = related_article.content | strip_html | split: ' ' | size
          assign read_time  = word_count | divided_by: 200
          if read_time < 1
            assign read_time = 1
          endif
        -%}

        <a href="{{ related_article.url }}" class="elevate-blog-related__card">
          {%- comment -%} ── Image with tag badge ── {%- endcomment -%}
          <div class="elevate-blog-related__image-wrap">
            {%- if related_article.image -%}
              {{
                related_article.image
                | image_url: width: 800
                | image_tag:
                  widths: '300, 400, 600, 800',
                  sizes: '(min-width: 990px) 33vw, 100vw',
                  loading: 'lazy',
                  class: 'elevate-blog-related__image',
                  alt: related_article.title
              }}
            {%- else -%}
              <div class="elevate-blog-related__image-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect width="24" height="24" rx="4" fill="#E5E7EB"/>
                  <path d="M4 16l4-4 4 4 4-6 4 6" stroke="#9CA3AF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="15" cy="9" r="2" fill="#9CA3AF"/>
                </svg>
              </div>
            {%- endif -%}

            {%- if badge_text != blank -%}
              <span class="elevate-blog-related__tag">{{ badge_text }}</span>
            {%- endif -%}
          </div>

          {%- comment -%} ── Content ── {%- endcomment -%}
          <div class="elevate-blog-related__content">
            <h3 class="elevate-blog-related__title">{{ related_article.title }}</h3>

            {%- if related_article.excerpt_or_content != blank -%}
              <p class="elevate-blog-related__excerpt">
                {{ related_article.excerpt_or_content | strip_html | truncate: 120 }}
              </p>
            {%- endif -%}

            <hr class="elevate-blog-related__divider">

            <div class="elevate-blog-related__meta">
              <div class="elevate-blog-related__meta-left">
                {%- if related_article.metafields.custom.author_avatar.value != blank -%}
                  <img
                    class="elevate-blog-related__avatar-img"
                    src="{{ related_article.metafields.custom.author_avatar.value | image_url: width: 48 }}"
                    alt="{{ related_article.author }}"
                    width="24"
                    height="24"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="elevate-blog-related__avatar">
                    {{ related_article.author | slice: 0 | upcase }}
                  </div>
                {%- endif -%}
                <div class="elevate-blog-related__meta-text">
                  <span class="elevate-blog-related__author">{{ related_article.author }}</span>
                  <span class="elevate-blog-related__date">
                    {{ related_article.published_at | date: '%b %d, %Y' }}
                  </span>
                </div>
              </div>
              <span class="elevate-blog-related__read-time">{{ read_time }} min read</span>
            </div>

            <span class="elevate-blog-related__cta">
              Read Article &rarr;
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- comment -%} ── Stepper dots (mobile only) ── {%- endcomment -%}
    {%- if shown > 1 -%}
      <div class="elevate-blog-related__dots" id="related-dots-{{ sid }}" aria-hidden="true">
        {%- for i in (1..shown) -%}
          <button
            class="elevate-blog-related__dot{% if i == 1 %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            type="button"
            aria-label="Go to article {{ i }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="elevate-blog-related__btn-wrap">
      <a href="{{ cta_url }}" class="elevate-blog-related__btn">
        {{ cta_text }}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 4.5l7.5 7.5-7.5 7.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</div>
{%- endif -%}

<script>
  (function () {
    var slider = document.getElementById('related-slider-{{ sid }}');
    var dotsWrap = document.getElementById('related-dots-{{ sid }}');
    if (!slider || !dotsWrap) return;

    var dots = dotsWrap.querySelectorAll('.elevate-blog-related__dot');
    var cards = slider.querySelectorAll('.elevate-blog-related__card');
    if (!cards.length) return;

    function getActive() {
      var sl = slider.scrollLeft;
      var best = 0;
      var bestDist = Infinity;
      cards.forEach(function (c, i) {
        var d = Math.abs(c.offsetLeft - sl - slider.offsetLeft);
        if (d < bestDist) { bestDist = d; best = i; }
      });
      return best;
    }

    function setActive(idx) {
      dots.forEach(function (d, i) {
        d.classList.toggle('is-active', i === idx);
      });
    }

    var ticking = false;
    slider.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          setActive(getActive());
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var idx = parseInt(this.dataset.index, 10);
        if (cards[idx]) {
          slider.scrollTo({ left: cards[idx].offsetLeft - slider.offsetLeft, behavior: 'smooth' });
        }
      });
    });
  })();
</script>

{% stylesheet %}
  /* ─── Related Articles ─── */
  .elevate-blog-related__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  .elevate-blog-related__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.25rem;
    line-height: 1.2;
    color: #36393F;
    text-transform: uppercase;
    text-align: left;
    align-self: flex-start;
    margin: 0;
  }

  /* ── Slider (mobile) / Grid (desktop) ── */
  .elevate-blog-related__slider {
    display: flex;
    gap: 0.5rem;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .elevate-blog-related__slider::-webkit-scrollbar {
    display: none;
  }

  /* ── Card ── */
  .elevate-blog-related__card {
    display: flex;
    flex-direction: column;
    flex: 0 0 calc(100% - 2rem);
    min-width: 0;
    background: #FDFCFC;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0.25rem 0.375rem -0.0625rem rgba(0, 0, 0, 0.1),
      0 0.125rem 0.25rem -0.125rem rgba(0, 0, 0, 0.1);
    text-decoration: none;
    color: inherit;
    scroll-snap-align: start;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .elevate-blog-related__card:hover {
    box-shadow:
      0 0.25rem 0.5rem rgba(0, 0, 0, 0.1),
      0 0.75rem 1.5rem rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  /* ── Image ── */
  .elevate-blog-related__image-wrap {
    position: relative;
    width: 100%;
    height: 14.25rem;
    overflow: hidden;
  }

  .elevate-blog-related__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .elevate-blog-related__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F3F4F6;
    border-radius: 0.5rem;
  }

  .elevate-blog-related__tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    background: #E31E24;
    border-radius: 0.125rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #FDFCFC;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* ── Content ── */
  .elevate-blog-related__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
  }

  .elevate-blog-related__title {
    font-family: 'Inter', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: -0.0125rem;
    color: #141517;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .elevate-blog-related__excerpt {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #36393F;
    margin: 0;
    letter-spacing: -0.0075rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .elevate-blog-related__divider {
    border: none;
    border-top: 0.5px solid #AEB2B8;
    margin: 0;
    opacity: 0.4;
  }

  /* ── Meta row ── */
  .elevate-blog-related__meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.5rem;
  }

  .elevate-blog-related__meta-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .elevate-blog-related__avatar-img {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .elevate-blog-related__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: #AEB2B8;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.625rem;
    color: #141517;
    flex-shrink: 0;
  }

  .elevate-blog-related__meta-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .elevate-blog-related__author {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.625rem;
    line-height: 1.5;
    color: #AEB2B8;
    letter-spacing: -0.00625rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .elevate-blog-related__date {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.625rem;
    line-height: 1.5;
    color: #AEB2B8;
    letter-spacing: -0.00625rem;
  }

  .elevate-blog-related__read-time {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #AEB2B8;
    white-space: nowrap;
    text-align: right;
  }

  /* ── Card CTA ── */
  .elevate-blog-related__cta {
    display: inline-flex;
    align-self: flex-end;
    padding-inline: 0.5rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    color: #E31E24;
    letter-spacing: 0.03rem;
    text-decoration: none;
    border-bottom: 0.5px solid #E31E24;
    padding-block: 0.5rem;
    transition: border-bottom-width 0.2s ease;
  }

  .elevate-blog-related__card:hover .elevate-blog-related__cta {
    border-bottom-width: 1.5px;
  }

  /* ── Stepper dots ── */
  .elevate-blog-related__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
  }

  .elevate-blog-related__dot {
    width: 0.75rem;
    height: 0.25rem;
    border-radius: 62.4375rem;
    background: #6B7280;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .elevate-blog-related__dot.is-active {
    background: #E31E24;
  }

  /* ── Button ── */
  .elevate-blog-related__btn-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .elevate-blog-related__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    height: 3rem;
    padding: 0.5rem 1.5rem;
    background: #E31E24;
    color: #FDFCFC;
    border: none;
    border-radius: 0.75rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .elevate-blog-related__btn:hover {
    background: #c9191e;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-blog-related__inner {
      padding-inline: 4.375rem;
    }

    .elevate-blog-related__heading {
      font-size: 3.5625rem;
      text-align: center;
      align-self: center;
    }

    .elevate-blog-related__slider {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      overflow: visible;
      scroll-snap-type: none;
    }

    .elevate-blog-related__card {
      flex: unset;
    }

    .elevate-blog-related__dots {
      display: none;
    }

    .elevate-blog-related__btn {
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Related Articles",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RELATED ARTICLES"
    },
    {
      "type": "range",
      "id": "articles_count",
      "label": "Articles to show",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Read All Articles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "templates": ["article"]
}
{% endschema %}
