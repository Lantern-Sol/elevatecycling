{%- comment -%}
  Elevate 404 — Custom "Wrong Turn" error page.
  Matches Figma node 4598:9323.
{%- endcomment -%}

<div class="elevate-404" style="--elevate-404-pt: {{ section.settings.padding_top }}px; --elevate-404-pb: {{ section.settings.padding_bottom }}px;">
  <div class="elevate-404__inner" data-scroll-reveal="children">
    {%- comment -%} Error code ── "404" {%- endcomment -%}
    {%- if section.settings.error_code != blank -%}
      <p class="elevate-404__code">
        {{ section.settings.error_code }}
      </p>
    {%- endif -%}

    {%- comment -%} Ghost / watermark heading ── "WRONG TURN" {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="elevate-404__heading">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- comment -%} Subtitle lines {%- endcomment -%}
    {%- if section.settings.subtitle_line_1 != blank or section.settings.subtitle_line_2 != blank -%}
      <div class="elevate-404__subtitle">
        {%- if section.settings.subtitle_line_1 != blank -%}
          <p>{{ section.settings.subtitle_line_1 }}</p>
        {%- endif -%}
        {%- if section.settings.subtitle_line_2 != blank -%}
          <p>{{ section.settings.subtitle_line_2 }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} CTA buttons {%- endcomment -%}
    <div class="elevate-404__buttons">
      {%- if section.settings.secondary_url != blank and section.settings.secondary_text != blank -%}
        <a href="{{ section.settings.secondary_url }}" class="elevate-404__btn elevate-404__btn--outline">
          {{ section.settings.secondary_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.primary_url != blank and section.settings.primary_text != blank -%}
        <a href="{{ section.settings.primary_url }}" class="elevate-404__btn elevate-404__btn--primary">
          {{ section.settings.primary_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
            <path d="M11.0391 0L9.96094 1.07812L15.0469 6.16406H0V7.66406H15.0469L9.96094 12.75L11.0391 13.8281L17.4141 7.45312L17.9297 6.91406L17.4141 6.375L11.0391 0Z" fill="#FDFCFC"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ================================================================
     elevate-404 — Custom 404 page
     ================================================================ */

  .elevate-404 {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--elevate-404-pt) var(--elevate-404-pb);
    background: radial-gradient(
      ellipse at bottom left,
      #6D1316 0%,
      #490E10 50%,
      #250A0A 100%
    );
  }

  /* Extra bottom padding only when followed by arrivals section */
  .elevate-404-section:has(+ .elevate-arrivals-section) .elevate-404 {
    padding-bottom: calc(var(--elevate-404-pb) + 2.5rem);
  }

  /* ── Pull new arrivals up so dark gradient shows behind border-radius ── */
  .elevate-404-section + .elevate-arrivals-section {
    margin-top: -2.5rem;
    position: relative;
    z-index: 1;
  }

  .elevate-404__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 40rem;
    padding-inline: 1.5rem;
    width: 100%;
  }

  /* ── Error code ("404") ── */
  .elevate-404__code {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
    color: #E31E24;
    margin: 0 0 0.5rem;
  }

  /* ── Ghost heading ("WRONG TURN") ── */
  .elevate-404__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-size: 4rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    color: var(--Text-on-dark, var(--Neutrals-Light-50, #FDFCFC));
    margin: 0 0 1rem;
  }

  /* ── Subtitle ── */
  .elevate-404__subtitle {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-404__subtitle p {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--Text-subtle-mixed, var(--Neutrals-Dark-200, #AEB2B8));
    margin: 0;
  }

  /* ── Buttons row ── */
  .elevate-404__buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2.5rem;
    width: 100%;
  }

  .elevate-404__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color 0.2s ease-in-out,
      border-color 0.2s ease-in-out,
      opacity 0.2s ease-in-out;
  }

  .elevate-404__btn:focus-visible {
    outline: 0.125rem solid #fff;
    outline-offset: 0.125rem;
  }

  /* Outlined button — "Back to Home" */
  .elevate-404__btn--outline {
    background: transparent;
    color: var(--Text-on-dark, var(--Neutrals-Light-50, #FDFCFC));
    border: 0.0625rem solid var(--Neutrals-Light-50, #FDFCFC);
  }

  .elevate-404__btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Filled button — "Explore Collections" */
  .elevate-404__btn--primary {
    background: #E31E24;
    color: #fff;
    border: 0.0625rem solid #E31E24;
    gap: 0.5rem;
  }

  .elevate-404__btn--primary:hover {
    opacity: 0.9;
  }

  .elevate-404__btn--primary svg {
    width: 1.25rem;
    height: auto;
    flex-shrink: 0;
  }

  /* ── Desktop ── */
  @media (min-width: 48rem) {
    .elevate-404__heading {
      font-size: 6.25rem;
    }

    .elevate-404__subtitle p {
      font-size: 1rem;
    }

    .elevate-404__buttons {
      flex-direction: row;
      justify-content: center;
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Elevate 404",
  "class": "elevate-404-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "error_code",
      "label": "Error code",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WRONG TURN"
    },
    {
      "type": "textarea",
      "id": "subtitle_line_1",
      "label": "Subtitle — line 1",
      "default": "Looks like this bike took a different route."
    },
    {
      "type": "textarea",
      "id": "subtitle_line_2",
      "label": "Subtitle — line 2",
      "default": "The page you're looking for may have been sold, moved, is out of stock, or simply no longer exists."
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button text",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link",
      "default": "/"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "Back to Home"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "default": 72,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Elevate 404"
    }
  ]
}
{% endschema %}
