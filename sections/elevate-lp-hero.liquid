{%- doc -%}
  Elevate Cycling — LP Hero (product-driven).
  Two-column layout: copy left (eyebrow, title, subtitle, price row, CTAs)
  and media right (trust pills, product image, trust icons).
  All dynamic data pulled from a product picker + custom.msrp metafield.
{%- enddoc -%}

{%- liquid
  assign product = all_products[section.settings.product]

  assign has_product = false
  if product != blank and product != empty
    assign has_product = true
  endif

  assign current_variant = product.selected_or_first_available_variant

  comment
    Title: use override if provided, else product title
  endcomment
  assign hero_title = section.settings.title_override
  if hero_title == blank and has_product
    assign hero_title = product.title
  endif

  comment
    MSRP savings calculation — same logic as PDP sidecar
  endcomment
  assign has_msrp = false
  assign savings_pct = 0
  if has_product
    assign msrp_raw = product.metafields.custom.msrp.value
    if msrp_raw != blank
      assign msrp_cents = msrp_raw | times: 100 | round
      assign price_cents = current_variant.price
      if msrp_cents > price_cents
        assign has_msrp = true
        assign diff = msrp_cents | minus: price_cents
        assign savings_pct = diff | times: 100 | divided_by: msrp_cents
      endif
    endif
  endif

  assign primary_url = section.settings.primary_link
  if primary_url == blank and has_product
    assign primary_url = product.url
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-lp-hero"
  style="
    background: #250A0A;
    --lp-hero-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --lp-hero-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
  "
>
  <div class="elevate-lp-hero__inner">
    {%- comment -%} ── Left column: copy ── {%- endcomment -%}
    <div class="elevate-lp-hero__copy">

      <div class="elevate-lp-hero__text-group">
        {%- if section.settings.eyebrow != blank -%}
          <p class="elevate-lp-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if hero_title != blank -%}
          <h1 class="elevate-lp-hero__title">{{ hero_title }}</h1>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="elevate-lp-hero__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if has_product -%}
        <div class="elevate-lp-hero__price-row">
          <span class="elevate-lp-hero__price">
            {{ current_variant.price | money_without_trailing_zeros }}
          </span>

          {%- if has_msrp -%}
            <div class="elevate-lp-hero__msrp-col">
              <span class="elevate-lp-hero__retail">
                Retail Price: ~{{ msrp_cents | money_without_trailing_zeros }}
              </span>
              <span class="elevate-lp-hero__savings-badge">
                Save ~{{ savings_pct }}% off retail
              </span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.primary_label != blank or section.settings.secondary_label != blank -%}
        <div class="elevate-lp-hero__buttons">
          {%- if section.settings.primary_label != blank -%}
            <a href="{{ primary_url }}" class="elevate-lp-hero__btn elevate-lp-hero__btn--primary">
              <span>{{ section.settings.primary_label }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'arrow-right-solid' -%}
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_label != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="elevate-lp-hero__btn elevate-lp-hero__btn--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Right column: media ── {%- endcomment -%}
    <div class="elevate-lp-hero__media">

      {%- comment -%} Trust pills ── {%- endcomment -%}
      <div class="elevate-lp-hero__pills">
        {%- if section.settings.pill_1 != blank -%}
          <span class="elevate-lp-hero__pill">{{ section.settings.pill_1 }}</span>
        {%- endif -%}
        {%- if section.settings.pill_2 != blank -%}
          <span class="elevate-lp-hero__pill elevate-lp-hero__pill--rating">
            <span class="elevate-lp-hero__stars" aria-hidden="true">★★★★★</span>
            {{ section.settings.pill_2 }}
          </span>
        {%- endif -%}
      </div>

      {%- comment -%} Product image ── {%- endcomment -%}
      <div class="elevate-lp-hero__image-wrap">
        {%- if has_product and product.featured_image != blank -%}
          {%- assign img = product.featured_image -%}
          {{
            img
            | image_url: width: 1260
            | image_tag:
              widths: '375, 630, 750, 1260',
              sizes: '(min-width: 61.9375rem) 630px, 100vw',
              fetchpriority: 'high',
              loading: 'eager',
              class: 'elevate-lp-hero__image',
              alt: product.title
          }}
        {%- else -%}
          <div class="elevate-lp-hero__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>

      {%- comment -%} Trust icons row ── {%- endcomment -%}
      <div class="elevate-lp-hero__trust-row">
        <div class="elevate-lp-hero__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
