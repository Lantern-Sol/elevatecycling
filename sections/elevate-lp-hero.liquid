          </svg>
          <span>{{ section.settings.trust_4 }}</span>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── LP Hero ─── */
  .elevate-lp-hero {
    grid-column: 1 / -1;
    padding-block: var(--lp-hero-pt) var(--lp-hero-pb);
    overflow: hidden;
  }

  .elevate-lp-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 80rem;
    margin-inline: auto;
  }

  /* ── Mobile: flatten containers for reordering ── */
  .elevate-lp-hero__copy {
    display: contents;
  }

  .elevate-lp-hero__media {
    display: contents;
  }

  .elevate-lp-hero__text-group { order: 1; }
  .elevate-lp-hero__pills { order: 2; }
  .elevate-lp-hero__image-wrap { order: 3; }
  .elevate-lp-hero__price-row { order: 4; }
  .elevate-lp-hero__buttons { order: 5; }
  .elevate-lp-hero__trust-row { order: 6; }

  .elevate-lp-hero__text-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-lp-hero__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-lp-hero__title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.25rem;
    line-height: 1.2;
    color: #FDFCFC;
    margin: 0;
  }

  .elevate-lp-hero__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #AEB2B8;
    margin: 0;
    max-width: 36rem;
  }

  /* ── Price row ── */
  .elevate-lp-hero__price-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .elevate-lp-hero__price {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 400;
    font-size: 2.25rem;
    line-height: 1.2;
    color: #FDFCFC;
  }

  .elevate-lp-hero__msrp-col {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-lp-hero__retail {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #AEB2B8;
  }

  .elevate-lp-hero__savings-badge {
    display: inline-block;
    background: #EDFCF2;
    color: #359E5B;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    padding-inline: 0.5rem;
    border-radius: 0.25rem;
    white-space: nowrap;
    width: fit-content;
  }

  /* ── Buttons ── */
  .elevate-lp-hero__buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    margin-block-start: 0.5rem;
  }

  .elevate-lp-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color 0.2s ease-in-out,
      border-color 0.2s ease-in-out,
      opacity 0.2s ease-in-out;
  }

  .elevate-lp-hero__btn:focus-visible {
    outline: 0.125rem solid #fff;
    outline-offset: 0.125rem;
  }

  .elevate-lp-hero__btn--primary {
    background: #E31E24;
    color: #FDFCFC;
    border: none;
    gap: 0.5rem;
  }

  .elevate-lp-hero__btn--primary svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .elevate-lp-hero__btn--primary:hover {
    background: #c8191e;
  }

  .elevate-lp-hero__btn--secondary {
    background: transparent;
    color: #FDFCFC;
    border: 0.03125rem solid rgba(255, 255, 255, 0.5);
  }

  .elevate-lp-hero__btn--secondary:hover {
    border-color: #fff;
  }

  /* ── Trust pills ── */
  .elevate-lp-hero__pills {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .elevate-lp-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 3rem;
    background: rgba(226, 227, 229, 0.4);
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
    white-space: nowrap;
  }

  .elevate-lp-hero__stars {
    color: #FBC70F;
    font-family: 'Gibson', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: normal;
  }

  /* ── Product image ── */
  .elevate-lp-hero__image-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    border-radius: 1rem;
    overflow: hidden;
  }

  .elevate-lp-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .elevate-lp-hero__placeholder {
    width: 100%;
    height: 100%;
    background: #1a1a1a;
    border-radius: 1rem;
  }

  /* ── Trust icons row ── */
  .elevate-lp-hero__trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding-inline: 0.5rem;
  }

  .elevate-lp-hero__trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    flex: 1 1 0%;
    min-width: 0;
    color: #FDFCFC;
  }

  .elevate-lp-hero__trust-item svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: #E31E24;
  }

  .elevate-lp-hero__trust-item span {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #FDFCFC;
    white-space: normal;
    text-align: center;
  }

  /* ── Entrance animation ── */
  @keyframes lp-hero-fadeUp {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .elevate-lp-hero__copy > * {
    animation: lp-hero-fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .elevate-lp-hero__copy > *:nth-child(1) { animation-delay: 0.15s; }
  .elevate-lp-hero__copy > *:nth-child(2) { animation-delay: 0.3s; }
  .elevate-lp-hero__copy > *:nth-child(3) { animation-delay: 0.45s; }
  .elevate-lp-hero__copy > *:nth-child(4) { animation-delay: 0.6s; }
  .elevate-lp-hero__copy > *:nth-child(5) { animation-delay: 0.75s; }

  .elevate-lp-hero__pills,
  .elevate-lp-hero__image-wrap,
  .elevate-lp-hero__trust-row {
    animation: lp-hero-fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .elevate-lp-hero__copy > *,
    .elevate-lp-hero__media {
      animation: none;
    }
  }

  /* ── Desktop (990px+) ── */
  @media (min-width: 61.9375rem) {
    .elevate-lp-hero__inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }

    .elevate-lp-hero__copy {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      flex: 1 1 0%;
      min-width: 0;
      gap: 1rem;
    }

    .elevate-lp-hero__media {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
      flex: 0 0 39.375rem;
      width: 39.375rem;
    }

    .elevate-lp-hero__title {
      font-size: 3.4375rem;
    }

    .elevate-lp-hero__subtitle {
      font-size: 1rem;
    }

    .elevate-lp-hero__price {
      font-size: 3rem;
    }

    .elevate-lp-hero__buttons {
      flex-direction: row;
      width: auto;
      max-width: 33rem;
    }

    .elevate-lp-hero__btn {
      flex: 1 1 0%;
      min-width: 0;
    }

    .elevate-lp-hero__image-wrap {
      border-radius: 1.5rem;
    }

    .elevate-lp-hero__trust-row {
      padding-inline: 0;
    }

    .elevate-lp-hero__trust-item {
      flex-direction: row;
      gap: 0.25rem;
    }
  }

{% endstylesheet %}

