          </svg>
          <span>{{ section.settings.trust_1 }}</span>
        </div>

        <div class="elevate-lp-hero__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="19" height="17" viewBox="0 0 19 17" fill="none" aria-hidden="true" focusable="false">
            <path d="M6.51562 0L0.515625 6L0 6.53906L0.515625 7.07812L6.51562 13.0781L7.59375 12L2.88281 7.28906H13.0547C15.1348 7.28906 16.8047 8.95898 16.8047 11.0391C16.8047 13.1191 15.1348 14.7891 13.0547 14.7891V16.2891C15.9463 16.2891 18.3047 13.9307 18.3047 11.0391C18.3047 8.14746 15.9463 5.78906 13.0547 5.78906H2.88281L7.59375 1.07812L6.51562 0Z" fill="currentColor"/>
          </svg>
          <span>{{ section.settings.trust_2 }}</span>
        </div>

        <div class="elevate-lp-hero__trust-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="19" height="20" viewBox="0 0 19 20" fill="none" aria-hidden="true" focusable="false">
