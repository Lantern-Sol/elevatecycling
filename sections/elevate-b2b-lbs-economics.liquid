{%- doc -%}
  Elevate Cycling — B2B LBS Economics section.
  Pricing table + stat callouts + tagline.
{%- enddoc -%}

{%- liquid
  assign table_rows = section.blocks | where: 'type', 'table_row'
  assign stats = section.blocks | where: 'type', 'stat'
-%}

<div
  class="section section--page-width page-width-normal elevate-b2b-lbs-economics"
  data-scroll-reveal="children"
  style="
    background: #FDFCFC;
    --lbs-econ-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --lbs-econ-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
    {%- if section.settings.mobile_padding_custom -%}
      --lbs-econ-pad-top-m: {{ section.settings.padding_top_mobile | divided_by: 16.0 }}rem;
      --lbs-econ-pad-bottom-m: {{ section.settings.padding_bottom_mobile | divided_by: 16.0 }}rem;
    {%- endif -%}
  "
>
  <div class="elevate-b2b-lbs-economics__inner">
    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="elevate-b2b-lbs-economics__header">
      <div class="elevate-b2b-lbs-economics__header-left">
        {%- if section.settings.eyebrow != blank -%}
          <p class="elevate-b2b-lbs-economics__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="elevate-b2b-lbs-economics__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.description != blank -%}
        <div class="elevate-b2b-lbs-economics__header-right">
          <p class="elevate-b2b-lbs-economics__description">{{ section.settings.description }}</p>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Pricing table ── {%- endcomment -%}
    {%- if table_rows.size > 0 -%}
      <div class="elevate-b2b-lbs-economics__table" role="table" aria-label="Trade-in pricing examples">
        <div class="elevate-b2b-lbs-economics__table-head" role="row">
          <span role="columnheader">Example Bike</span>
          <span role="columnheader">Elevate Offer</span>
          <span role="columnheader">Store Credit (1.25×)</span>
          <span role="columnheader">Your Margin</span>
        </div>
        {%- for block in table_rows -%}
          <div
            class="elevate-b2b-lbs-economics__table-row{% if forloop.index == 2 or forloop.index == 4 %} elevate-b2b-lbs-economics__table-row--alt{% endif %}"
            role="row"
            {{ block.shopify_attributes }}
          >
            <span class="elevate-b2b-lbs-economics__bike" role="cell">{{ block.settings.bike }}</span>
            <span role="cell" data-label="ELEVATE OFFER">{{ block.settings.offer }}</span>
            <span role="cell" data-label="STORE CREDIT (1.25×)">{{ block.settings.credit }}</span>
            <span class="elevate-b2b-lbs-economics__margin" role="cell" data-label="YOUR MARGIN">{{ block.settings.margin }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Stat callouts ── {%- endcomment -%}
    {%- if stats.size > 0 -%}
      <div class="elevate-b2b-lbs-economics__stats">
        {%- for block in stats -%}
          <div class="elevate-b2b-lbs-economics__stat-card" {{ block.shopify_attributes }}>
            {%- if block.settings.value != blank -%}
              <p class="elevate-b2b-lbs-economics__stat-value">{{ block.settings.value }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <p class="elevate-b2b-lbs-economics__stat-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="elevate-b2b-lbs-economics__stat-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Tagline ── {%- endcomment -%}
    {%- if section.settings.tagline != blank -%}
      <p class="elevate-b2b-lbs-economics__tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .elevate-b2b-lbs-economics__inner {
    padding-block: var(--lbs-econ-pad-top-m, var(--lbs-econ-pad-top)) var(--lbs-econ-pad-bottom-m, var(--lbs-econ-pad-bottom));
    padding-inline: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Header ── */
  .elevate-b2b-lbs-economics__header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-b2b-lbs-economics__header-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-b2b-lbs-economics__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-economics__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #141517;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-economics__description {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #36393F;
    margin: 0;
  }

  /* ── Pricing table ── */
  .elevate-b2b-lbs-economics__table {
    border-radius: 1.5rem;
    overflow: hidden;
  }

  .elevate-b2b-lbs-economics__table-head {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: #141517;
    padding: 1rem 2rem;
  }

  .elevate-b2b-lbs-economics__table-head span {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    color: #FDFCFC;
    text-transform: uppercase;
  }

  .elevate-b2b-lbs-economics__table-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 1.25rem 2rem;
    background: #FDFCFC;
  }

  .elevate-b2b-lbs-economics__table-row--alt {
    background: #E2E3E5;
  }

  .elevate-b2b-lbs-economics__table-row span {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #141517;
  }

  .elevate-b2b-lbs-economics__margin {
    color: #E31E24;
    font-weight: 700;
  }

  /* ── Stat callouts ── */
  .elevate-b2b-lbs-economics__stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .elevate-b2b-lbs-economics__stat-card {
    background: #141517;
    border-radius: 1.5rem;
    padding: 1.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-b2b-lbs-economics__stat-value {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1.2;
    color: #E31E24;
    margin: 0;
  }

  .elevate-b2b-lbs-economics__stat-title {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: -0.0125rem;
    color: #FDFCFC;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-economics__stat-desc {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #AEB2B8;
    margin: 0;
  }

  /* ── Tagline ── */
  .elevate-b2b-lbs-economics__tagline {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #E31E24;
    margin: 0;
  }

  /* ── Mobile card layout ── */
  @media (max-width: 61.875rem) {
    .elevate-b2b-lbs-economics__table {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      border-radius: 0;
      overflow: visible;
    }

    .elevate-b2b-lbs-economics__table-head {
      display: none;
    }

    .elevate-b2b-lbs-economics__table-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      background: rgba(226, 227, 229, 0.4);
      border-radius: 1.5rem;
      padding: 0.75rem 1rem;
    }

    .elevate-b2b-lbs-economics__table-row--alt {
      background: rgba(226, 227, 229, 0.4);
    }

    .elevate-b2b-lbs-economics__bike {
      grid-column: 1 / -1;
      font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      line-height: 1.2;
      color: #36393F;
    }

    .elevate-b2b-lbs-economics__table-row span[data-label] {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.875rem;
    }

    .elevate-b2b-lbs-economics__table-row span[data-label]::before {
      content: attr(data-label);
      font-family: 'Inter', var(--font-body--family), sans-serif;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: -0.0075rem;
      color: #36393F;
    }

    .elevate-b2b-lbs-economics__margin {
      text-align: right;
    }

    .elevate-b2b-lbs-economics__margin::before {
      text-align: right;
    }

    .elevate-b2b-lbs-economics__table-row span[data-label]:nth-child(3) {
      text-align: center;
    }

    .elevate-b2b-lbs-economics__table-row span[data-label]:nth-child(3)::before {
      text-align: center;
    }

    .elevate-b2b-lbs-economics__stat-card {
      padding: 1.5rem 1rem;
      gap: 0.75rem;
    }

    .elevate-b2b-lbs-economics__stat-value {
      font-size: 3.5625rem;
    }

    .elevate-b2b-lbs-economics__stats {
      gap: 0.5rem;
    }

    .elevate-b2b-lbs-economics__tagline {
      font-size: 3rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 61.9375rem) {
    .elevate-b2b-lbs-economics__inner {
      padding-block: var(--lbs-econ-pad-top) var(--lbs-econ-pad-bottom);
      padding-inline: 4.375rem;
      gap: 2rem;
    }

    .elevate-b2b-lbs-economics__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .elevate-b2b-lbs-economics__header-left {
      max-width: 31rem;
    }

    .elevate-b2b-lbs-economics__header-right {
      max-width: 33rem;
      padding-block-start: 4.3125rem;
    }

    .elevate-b2b-lbs-economics__heading {
      font-size: 3.5625rem;
    }

    .elevate-b2b-lbs-economics__stats {
      flex-direction: row;
      gap: 2rem;
    }

    .elevate-b2b-lbs-economics__stat-card {
      flex: 1;
    }

    .elevate-b2b-lbs-economics__stat-value {
      font-size: 4.25rem;
    }

    .elevate-b2b-lbs-economics__tagline {
      font-size: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LBS Economics",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE ECONOMICS"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "YOU EARN ON THE CREDIT. AND ON THE UPSELL."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Cash buys a coffee. Credit buys their next bike — from you."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "mobile_padding_custom",
      "label": "Custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    }
  ],
  "blocks": [
    {
      "type": "table_row",
      "name": "Table row",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "bike",
          "label": "Bike name",
          "default": "2021 Trek Madone SL6"
        },
        {
          "type": "text",
          "id": "offer",
          "label": "Elevate offer",
          "default": "$2,400"
        },
        {
          "type": "text",
          "id": "credit",
          "label": "Store credit",
          "default": "$3,000"
        },
        {
          "type": "text",
          "id": "margin",
          "label": "Your margin",
          "default": "+$288"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat callout",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "82%"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "RETURN WITHIN 30 DAYS"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LBS Economics",
      "blocks": [
        {
          "type": "table_row",
          "settings": {
            "bike": "2021 Trek Madone SL6",
            "offer": "$2,400",
            "credit": "$3,000",
            "margin": "+$288"
          }
        },
        {
          "type": "table_row",
          "settings": {
            "bike": "2023 Cannondale Topstone",
            "offer": "$1,180",
            "credit": "$1,475",
            "margin": "+$142"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "82%",
            "title": "RETURN WITHIN 30 DAYS",
            "description": "Customers who accept store credit come back to your shop within a month."
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "1.4×",
            "title": "AVERAGE BASKET AT REDEMPTION",
            "description": "They spend 40% more than the credit value."
          }
        }
      ]
    }
  ]
}
{% endschema %}
