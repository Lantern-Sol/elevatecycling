{%- doc -%}
  Elevate Cycling — Contact cards section.
  "Reach us directly" heading with phone, email, and visit cards.
  Reusable on any page via template JSON.
{%- enddoc -%}

<div
  class="section elevate-contact-cards"
  style="
    --elevate-contact-cards-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-contact-cards-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
  "
>
  <div class="elevate-contact-cards__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="elevate-contact-cards__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="elevate-contact-cards__grid">
      {%- comment -%} Phone card {%- endcomment -%}
      {%- if section.settings.phone != blank -%}
        <a href="tel:{{ section.settings.phone | remove: '(' | remove: ')' | remove: ' ' | remove: '-' | remove: '.' }}" class="elevate-contact-cards__card">
          <span class="elevate-contact-cards__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'phone-solid' -%}
            </svg>
          </span>
          <span class="elevate-contact-cards__card-text">
            <span class="elevate-contact-cards__card-label">{{ section.settings.phone_label }}</span>
            <span class="elevate-contact-cards__card-value">{{ section.settings.phone }}</span>
            <span class="elevate-contact-cards__card-meta">{{ section.settings.phone_hours }}</span>
          </span>
          <span class="elevate-contact-cards__card-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </span>
        </a>
      {%- endif -%}

      {%- comment -%} Email card {%- endcomment -%}
      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="elevate-contact-cards__card">
          <span class="elevate-contact-cards__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'mail-solid' -%}
            </svg>
          </span>
          <span class="elevate-contact-cards__card-text">
            <span class="elevate-contact-cards__card-label">{{ section.settings.email_label }}</span>
            <span class="elevate-contact-cards__card-value">{{ section.settings.email }}</span>
            <span class="elevate-contact-cards__card-meta">{{ section.settings.email_meta }}</span>
          </span>
          <span class="elevate-contact-cards__card-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </span>
        </a>
      {%- endif -%}

      {%- comment -%} Visit card {%- endcomment -%}
      {%- if section.settings.visit_location != blank -%}
        <a href="https://www.google.com/maps/search/?api=1&query={{ section.settings.visit_location | url_encode }}" target="_blank" rel="noopener" class="elevate-contact-cards__card">
          <span class="elevate-contact-cards__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'map-pin-solid' -%}
            </svg>
          </span>
          <span class="elevate-contact-cards__card-text">
            <span class="elevate-contact-cards__card-label">{{ section.settings.visit_label }}</span>
            <span class="elevate-contact-cards__card-value">{{ section.settings.visit_location }}</span>
            <span class="elevate-contact-cards__card-meta">{{ section.settings.visit_meta }}</span>
          </span>
          <span class="elevate-contact-cards__card-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── Contact Cards Section ─── */
  .shopify-section .elevate-contact-cards.section {
    background: #FDFCFC;
    padding-block-start: var(--elevate-contact-cards-pt);
    padding-block-end: var(--elevate-contact-cards-pb);
  }

  .elevate-contact-cards__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-contact-cards__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #141517;
    margin: 0;
    text-align: center;
  }

  /* ── Cards grid ── */
  .elevate-contact-cards__grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-contact-cards__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    border: 0.03125rem solid #AEB2B8;
    border-radius: 1rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }

  a.elevate-contact-cards__card:hover {
    border-color: #36393F;
  }

  .elevate-contact-cards__card:focus-visible {
    outline: 0.125rem solid #141517;
    outline-offset: 0.125rem;
  }

  .elevate-contact-cards__card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.625rem;
    background: #F1DBDC;
    color: #E31E24;
  }

  .elevate-contact-cards__card-icon svg {
    display: block;
    width: 1.5rem;
    height: 1.5rem;
  }

  .elevate-contact-cards__card-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    line-height: 1.5;
  }

  .elevate-contact-cards__card-label {
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    color: #141517;
  }

  .elevate-contact-cards__card-value {
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    color: #D61D18;
  }

  .elevate-contact-cards__card-meta {
    font-size: 0.75rem;
    letter-spacing: -0.01em;
    color: #6B7280;
  }

  .elevate-contact-cards__card-arrow {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    color: #AEB2B8;
  }

  .elevate-contact-cards__card-arrow svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ─── Desktop (768px+) ─── */
  @media (min-width: 48rem) {
    .elevate-contact-cards__heading {
      font-size: 3rem;
    }

    .elevate-contact-cards__grid {
      flex-direction: row;
      gap: 1rem;
    }

    .elevate-contact-cards__card {
      flex: 1;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Cards",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reach us directly"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Call or text us"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "(714) 248-5066"
    },
    {
      "type": "text",
      "id": "phone_hours",
      "label": "Phone hours",
      "default": "Mon–Fri, 9AM–5PM PST"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email support"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "support@elevatecycling.com"
    },
    {
      "type": "text",
      "id": "email_meta",
      "label": "Email response time",
      "default": "Response within 24hrs"
    },
    {
      "type": "header",
      "content": "Visit"
    },
    {
      "type": "text",
      "id": "visit_label",
      "label": "Visit label",
      "default": "Visit us"
    },
    {
      "type": "text",
      "id": "visit_location",
      "label": "Location",
      "default": "Santa Ana, CA"
    },
    {
      "type": "text",
      "id": "visit_meta",
      "label": "Visit meta",
      "default": "Warehouse pickup available"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Contact Cards"
    }
  ]
}
{% endschema %}
