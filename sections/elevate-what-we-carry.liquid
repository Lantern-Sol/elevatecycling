          "default": "We source directly from brands — overstock, closeouts, and bulk deals — so you get current-model gear at prices you won't find at a standard retailer."
        },
        {
          "type": "text",
          "id": "feature_1",
          "label": "Feature 1",
          "default": "100% brand new, never ridden"
        },
        {
          "type": "text",
          "id": "feature_2",
          "label": "Feature 2",
          "default": "Direct from the brand, not gray market"
        },
        {
          "type": "text",
          "id": "feature_3",
          "label": "Feature 3",
          "default": "Full manufacturer's warranty applies"
        },
        {
          "type": "text",
          "id": "feature_4",
          "label": "Feature 4",
          "default": "Inspected and packaged before it ships"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "SHOP NEW STOCK"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What We Carry",
      "settings": {
        "eyebrow": "OUR INVENTORY",
        "heading": "WHAT WE CARRY",
        "subtitle": "Two types of inventory. One standard: every item inspected, spec'd, and priced right before it ships."
      },
      "blocks": [
        {
          "type": "inventory_card",
          "settings": {
