            { "value": "none", "label": "None" },
            { "value": "star", "label": "Star" },
            { "value": "certificate-solid", "label": "Certificate" },
            { "value": "certified", "label": "Certified checkmark" },
            { "value": "tags-solid", "label": "Tags" }
