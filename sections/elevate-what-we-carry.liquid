{%- doc -%}
  Elevate Cycling — What We Carry section.
  Two-card layout explaining inventory types: New Below Retail & Certified Pre-Owned.
  Each card has a badge, description, feature list, and CTA link.
{%- enddoc -%}

<div
  class="section-background"
  style="background-color: {{ section.settings.background_color }}66;"
></div>
<div
  class="section section--page-width elevate-carry"
  data-scroll-reveal
  style="
    --page-content-width: 75rem;
    --page-width: calc(75rem + var(--page-margin) * 2);
    padding-block-start: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    padding-block-end: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
  "
>
  {%- comment -%} ── Header ── {%- endcomment -%}
  <div class="elevate-carry__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="elevate-carry__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="elevate-carry__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="elevate-carry__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── Card grid ── {%- endcomment -%}
  <div class="elevate-carry__grid">
    {%- for block in section.blocks -%}
      <div class="elevate-carry__card" {{ block.shopify_attributes }}>
        {%- comment -%} Badge {%- endcomment -%}
        {%- if block.settings.badge_text != blank -%}
          <div class="elevate-carry__badge">
            {%- if block.settings.badge_icon != 'none' -%}
              <svg
                class="elevate-carry__badge-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                {%- render 'icon', icon: block.settings.badge_icon -%}
              </svg>
            {%- endif -%}
            <span class="elevate-carry__badge-text">{{ block.settings.badge_text }}</span>
          </div>
        {%- endif -%}

        {%- comment -%} Description {%- endcomment -%}
        {%- if block.settings.description != blank -%}
          <p class="elevate-carry__desc">{{ block.settings.description }}</p>
        {%- endif -%}

        {%- comment -%} Features list {%- endcomment -%}
        <ul class="elevate-carry__features" role="list">
          {%- if block.settings.feature_1 != blank -%}
            <li class="elevate-carry__feature">
              <span class="elevate-carry__dot" aria-hidden="true"></span>
              {{ block.settings.feature_1 }}
            </li>
          {%- endif -%}
          {%- if block.settings.feature_2 != blank -%}
            <li class="elevate-carry__feature">
              <span class="elevate-carry__dot" aria-hidden="true"></span>
              {{ block.settings.feature_2 }}
            </li>
          {%- endif -%}
          {%- if block.settings.feature_3 != blank -%}
            <li class="elevate-carry__feature">
              <span class="elevate-carry__dot" aria-hidden="true"></span>
              {{ block.settings.feature_3 }}
            </li>
          {%- endif -%}
          {%- if block.settings.feature_4 != blank -%}
            <li class="elevate-carry__feature">
              <span class="elevate-carry__dot" aria-hidden="true"></span>
              {{ block.settings.feature_4 }}
            </li>
          {%- endif -%}
        </ul>

        {%- comment -%} CTA link {%- endcomment -%}
        {%- if block.settings.cta_label != blank -%}
          <div class="elevate-carry__cta-wrap">
            <a
              class="elevate-carry__cta"
              {% if block.settings.cta_link != blank %}href="{{ block.settings.cta_link }}"{% endif %}
            >
              <span>{{ block.settings.cta_label }}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                {%- render 'icon', icon: 'arrow-right-solid' -%}
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  /* ─── What We Carry ─── */
  .elevate-carry {
    border-radius: 0 0 2rem 2rem;
    overflow: hidden;
  }

  /* ── Header ── */
  .elevate-carry__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .elevate-carry__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-carry__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3.5625rem;
    line-height: 1.2;
    color: #36393F;
    margin: 0;
    text-transform: uppercase;
  }

  .elevate-carry__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #36393F;
    margin: 0;
  }

  /* ── Card grid ── */
  .elevate-carry__grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Card ── */
  .elevate-carry__card {
    background-color: #141517;
    border-radius: 2rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Badge ── */
  .elevate-carry__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(226, 227, 229, 0.4);
    border-radius: 1rem;
    padding: 0.3125rem 0.625rem;
    align-self: flex-start;
  }

  .elevate-carry__badge-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: #FDFCFC;
  }

  .elevate-carry__badge-text {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
    white-space: nowrap;
  }

  /* ── Description ── */
  .elevate-carry__desc {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #FDFCFC;
    margin: 0;
  }

  /* ── Features list ── */
  .elevate-carry__features {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .elevate-carry__feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
  }

  .elevate-carry__dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background-color: #E31E24;
    flex-shrink: 0;
  }

  /* ── CTA link ── */
  .elevate-carry__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: auto;
  }

  .elevate-carry__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0;
    color: #FDFCFC;
    text-decoration: none;
    border-bottom: 0.03125rem solid #FDFCFC;
    transition: opacity 0.2s ease;
  }

  .elevate-carry__cta:hover {
    opacity: 0.8;
  }

  .elevate-carry__cta span {
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .elevate-carry__cta svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  /* ─── Desktop (48rem / 768px) ─── */
  @media (min-width: 48rem) {
    .elevate-carry__grid {
      flex-direction: row;
      gap: 2rem;
    }

    .elevate-carry__card {
      flex: 1;
      min-width: 0;
      padding: 1.5rem 2rem;
    }

    .elevate-carry__badge {
      border-radius: 0.5rem;
    }

    .elevate-carry__cta-wrap {
      justify-content: flex-end;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "What We Carry",
  "tag": "section",
  "class": "elevate-carry-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#E2E3E5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR INVENTORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT WE CARRY"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Two types of inventory. One standard: every item inspected, spec'd, and priced right before it ships."
    }
  ],
  "blocks": [
    {
      "type": "inventory_card",
      "name": "Inventory Card",
      "settings": [
        {
          "type": "select",
