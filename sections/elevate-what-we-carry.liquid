            "feature_1": "100% brand new, never ridden",
            "feature_2": "Direct from the brand, not gray market",
            "feature_3": "Full manufacturer's warranty applies",
            "feature_4": "Inspected and packaged before it ships",
            "cta_label": "SHOP NEW STOCK"
          }
        },
        {
          "type": "inventory_card",
          "settings": {
            "badge_icon": "certificate-solid",
            "badge_text": "CERTIFIED PRE-OWNED",
            "description": "Every used item goes through our in-house inspection process — cleaned, photographed, condition-graded, and fully spec'd — so there are no surprises when it arrives.",
            "feature_1": "Mechanic-inspected and condition-graded",
