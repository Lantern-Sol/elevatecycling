{%- doc -%}
  Elevate Cycling — B2B LBS Program section.
  "FOUR STEPS. NO INVENTORY. NO RISK." Dark section with sidebar + 2×2 step grid.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-b2b-lbs-program"
  data-scroll-reveal="children"
  style="
    background: #141517;
    border-radius: 2rem;
    --lbs-program-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --lbs-program-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
    {%- if section.settings.mobile_padding_custom -%}
      --lbs-program-pad-top-m: {{ section.settings.padding_top_mobile | divided_by: 16.0 }}rem;
      --lbs-program-pad-bottom-m: {{ section.settings.padding_bottom_mobile | divided_by: 16.0 }}rem;
    {%- endif -%}
  "
>
  <div class="elevate-b2b-lbs-program__inner">
    <div class="elevate-b2b-lbs-program__sidebar">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-b2b-lbs-program__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-b2b-lbs-program__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="elevate-b2b-lbs-program__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a
          class="elevate-b2b-lbs-program__cta"
          href="{{ section.settings.cta_link | default: '#' }}"
        >
          {{- section.settings.cta_text -}}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="elevate-b2b-lbs-program__grid">
        {%- for block in section.blocks -%}
          <div class="elevate-b2b-lbs-program__card" {{ block.shopify_attributes }}>
            {%- if block.settings.number != blank -%}
              <p class="elevate-b2b-lbs-program__card-number">{{ block.settings.number }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <p class="elevate-b2b-lbs-program__card-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="elevate-b2b-lbs-program__card-body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.tag != blank -%}
              <p class="elevate-b2b-lbs-program__card-tag">{{ block.settings.tag }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .elevate-b2b-lbs-program__inner {
    padding-block: var(--lbs-program-pad-top-m, var(--lbs-program-pad-top)) var(--lbs-program-pad-bottom-m, var(--lbs-program-pad-bottom));
    padding-inline: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Sidebar ── */
  .elevate-b2b-lbs-program__sidebar {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .elevate-b2b-lbs-program__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-program__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1.2;
    color: #FDFCFC;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-program__description {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #AEB2B8;
    margin: 0;
    max-width: 17rem;
  }

  .elevate-b2b-lbs-program__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: #E31E24;
    border-radius: 0.75rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    color: #FDFCFC;
    text-decoration: none;
    transition: background 0.2s ease;
    margin-block-start: 0.5rem;
  }

  .elevate-b2b-lbs-program__cta:hover {
    background: #c9191f;
  }

  /* ── Grid ── */
  .elevate-b2b-lbs-program__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  /* ── Card ── */
  .elevate-b2b-lbs-program__card {
    background: #FDFCFC;
    border-radius: 1.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-b2b-lbs-program__card-number {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: #E31E24;
    margin: 0;
  }

  .elevate-b2b-lbs-program__card-title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #141517;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-lbs-program__card-body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #36393F;
    margin: 0;
  }

  .elevate-b2b-lbs-program__card-tag {
    display: inline-block;
    align-self: flex-start;
    background: #F1DBDC;
    color: #E31E24;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.8125rem;
    line-height: 1;
    letter-spacing: -0.00813rem;
    text-transform: uppercase;
    padding: 0.25rem 1rem;
    border-radius: 6.25rem;
    margin: 0.25rem 0 0;
  }

  /* ── Desktop ── */
  @media (min-width: 61.9375rem) {
    .elevate-b2b-lbs-program__inner {
      padding-block: var(--lbs-program-pad-top) var(--lbs-program-pad-bottom);
      padding-inline: 4.375rem;
      flex-direction: row;
      align-items: flex-start;
      gap: 2rem;
    }

    .elevate-b2b-lbs-program__sidebar {
      flex-shrink: 0;
      width: 18.3125rem;
      position: sticky;
      top: 6rem;
      align-self: flex-start;
    }

    .elevate-b2b-lbs-program__heading {
      font-size: 3.5625rem;
    }

    .elevate-b2b-lbs-program__grid {
      flex: 1;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .elevate-b2b-lbs-program__card-title {
      font-size: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LBS Program Steps",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE PROGRAM"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "FOUR STEPS. NO INVENTORY. NO RISK."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Submit in 2 minutes. Offer in 24 hours. Credit, same day."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Start a 90-Day Pilot"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "mobile_padding_custom",
      "label": "Custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "QUOTE IN STORE"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LBS Program Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "QUOTE IN STORE",
            "body": "The customer brings their bike to your counter. You submit the make, model, and condition. Written offer within 24 hours.",
            "tag": "OFFER IN 24 HOURS"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "ISSUE STORE CREDIT",
            "body": "Customer accepts. You issue store credit at 1.25× our cash offer — applied immediately toward a new bike, parts, or service.",
            "tag": "1.25× CASH OFFER"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "YOU SHIP",
            "body": "We email a prepaid FedEx label the moment the customer accepts. Box the bike, hand it to FedEx. That's it.",
            "tag": "PREPAID LABEL SENT INSTANTLY"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "04",
            "title": "WE PAY, INSTANTLY",
            "body": "ACH hits your account the moment FedEx scans the label — not on delivery, not on inspection. Same-day direct deposit.",
            "tag": "PAID ON LABEL SCAN"
          }
        }
      ]
    }
  ]
}
{% endschema %}
