{%- doc -%}
  Elevate Cycling — Collection newsletter signup section.
  Two-column layout: text content (left), email form (right).
  Uses Shopify customer form for email capture.
{%- enddoc -%}

{%- liquid
  assign heading_html = section.settings.heading
  if section.settings.heading_accent != blank
    assign accent_open = '<span class="elevate-collection-newsletter__accent">'
    assign accent_close = '</span>'
    assign accent_wrap = accent_open | append: section.settings.heading_accent | append: accent_close
    assign heading_html = heading_html | replace: section.settings.heading_accent, accent_wrap
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-collection-newsletter"
  data-scroll-reveal
  style="
    background: #FDFCFC;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="elevate-collection-newsletter__inner">
    <div class="elevate-collection-newsletter__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-collection-newsletter__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-collection-newsletter__heading">{{ heading_html }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="elevate-collection-newsletter__body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="elevate-collection-newsletter__form-wrap" id="newsletter-form-{{ section.id }}">
      {%- form 'customer', id: 'CollectionNewsletter' -%}
        {%- if form.posted_successfully? -%}
          <p class="elevate-collection-newsletter__success" role="status" tabindex="-1">
            {{ section.settings.success_message }}
          </p>
        {%- else -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.errors -%}
            <p class="elevate-collection-newsletter__error" role="alert">
              {{ form.errors.translated_fields['email'] | capitalize }}
              {{ form.errors.messages['email'] }}
            </p>
          {%- endif -%}

          <div class="elevate-collection-newsletter__field">
            <label
              for="newsletter-email-{{ section.id }}"
              class="elevate-collection-newsletter__label"
            >
              {{ section.settings.email_label }}
            </label>
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email-{{ section.id }}"
              class="elevate-collection-newsletter__input"
              placeholder="{{ section.settings.email_placeholder }}"
              value="{{ form.email }}"
              required
              autocomplete="email"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>

          <button type="submit" class="elevate-collection-newsletter__btn">
            {{ section.settings.button_label }}
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── Collection Newsletter ─── */
  .elevate-collection-newsletter__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  /* ── Text content ── */
  .elevate-collection-newsletter__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .elevate-collection-newsletter__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    text-transform: uppercase;
    color: #E31E24;
    margin: 0;
  }

  .elevate-collection-newsletter__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #36393F;
    margin: 0;
  }

  .elevate-collection-newsletter__accent {
    color: #E31E24;
  }

  .elevate-collection-newsletter__body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #000;
    margin: 0;
  }

  /* ── Form ── */
  .elevate-collection-newsletter__form-wrap {
    width: 100%;
  }

  .elevate-collection-newsletter__form-wrap form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-collection-newsletter__field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-collection-newsletter__label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    color: #141517;
    padding-inline: 0.5rem;
  }

  .elevate-collection-newsletter__input {
    height: 2.875rem;
    border-radius: 0.5rem;
    border: 0.0625rem solid #AEB2B8;
    background: #FDFCFC;
    padding: 0 1rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    color: #36393F;
    outline: none;
    transition: border-color 0.2s ease-in-out;
  }

  .elevate-collection-newsletter__input::placeholder {
    color: #AEB2B8;
  }

  .elevate-collection-newsletter__input:focus-visible {
    border-color: #E31E24;
    outline: 0.125rem solid #E31E24;
    outline-offset: 0.0625rem;
  }

  .elevate-collection-newsletter__input[aria-invalid="true"] {
    border-color: #E31E24;
  }

  .elevate-collection-newsletter__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 2.875rem;
    border-radius: 0.75rem;
    background: #E31E24;
    color: #FDFCFC;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease-in-out;
  }

  .elevate-collection-newsletter__btn:hover {
    background: #c8191e;
  }

  .elevate-collection-newsletter__btn:focus-visible {
    outline: 0.125rem solid #36393F;
    outline-offset: 0.125rem;
  }

  /* ── Success / Error ── */
  .elevate-collection-newsletter__success {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    color: #1a7a3a;
    margin: 0;
    padding: 0.75rem 1rem;
    background: #e8f5e9;
    border-radius: 0.5rem;
  }

  .elevate-collection-newsletter__error {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #E31E24;
    margin: 0;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-collection-newsletter__inner {
      flex-direction: row;
      align-items: center;
      padding-inline: 4.375rem;
    }

    .elevate-collection-newsletter__content {
      flex: 1 1 0%;
      min-width: 0;
    }

    .elevate-collection-newsletter__heading {
      font-size: 3rem;
    }

    .elevate-collection-newsletter__form-wrap {
      flex: 0 0 23.375rem;
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Newsletter",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "SUBSCRIBE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Save your search, get $50 OFF"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent text (highlighted in red)",
      "default": "get $50 OFF"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "300–500 new listings each week — get notified when similar gear gets listed."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "johndoe@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe to Newsletter"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in! We'll notify you of new listings."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 32,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Collection Newsletter"
    }
  ]
}
{% endschema %}
