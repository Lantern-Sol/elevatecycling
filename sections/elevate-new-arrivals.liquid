    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #141517;
    margin: 0;
  }

  /* ── Carousel wrapper ── */
  .elevate-arrivals__carousel-wrap {
    position: relative;
    width: calc(100% + 1.5rem);
    margin-right: -1.5rem;
    align-self: stretch;
  }

  /* ── Track ── */
  .elevate-arrivals__track {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-left: 0;
    padding-right: 1.5rem;
    padding-block: 0.25rem;
