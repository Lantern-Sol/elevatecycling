{%- comment -%}
  Elevate Cycling — New Arrivals section.
  Horizontal product card carousel showcasing a featured collection.
  Cards display brand, condition badges, grade, pricing, and quick-action buttons.
{%- endcomment -%}

{{ 'elevate-product-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'elevate-product-card.js' | asset_url }}" defer></script>

{%- liquid
  assign collection = collections[section.settings.collection]
  assign max = section.settings.max_products | default: 6
  assign products = collection.products | default: empty
-%}

<div
  class="section section--full-width elevate-arrivals"
  data-scroll-reveal
  style="
    --arrivals-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --arrivals-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
  "
>
  <div class="elevate-arrivals__inner">
    {%- comment -%} ── Section header ── {%- endcomment -%}
    <div class="elevate-arrivals__header elevate-arrivals__header--{{ section.settings.header_alignment }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-arrivals__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-arrivals__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="elevate-arrivals__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Carousel ── {%- endcomment -%}
    {%- if collection != blank and products.size > 0 -%}
      <div class="elevate-arrivals__carousel-wrap">
        <div class="elevate-arrivals__track" data-arrivals-track>
          {%- for product in products limit: max -%}
            {% render 'elevate-product-card', product: product %}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} ── Carousel nav: arrows + dots ── {%- endcomment -%}
      <div class="elevate-arrivals__nav">
        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Previous products"
          data-arrivals-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-left-solid' -%}
          </svg>
        </button>

        <div class="elevate-arrivals__dots" aria-label="Carousel navigation" data-arrivals-dots></div>

        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Next products"
          data-arrivals-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-right-solid' -%}
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- comment -%} ── Footer: subtitle + CTA ── {%- endcomment -%}
    <div class="elevate-arrivals__footer">
      <div class="elevate-arrivals__divider"></div>
      {%- if section.settings.footer_text != blank -%}
        <p class="elevate-arrivals__footer-text">{{ section.settings.footer_text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a
          class="elevate-arrivals__cta"
          {% if section.settings.cta_link != blank %}href="{{ section.settings.cta_link }}"{% endif %}
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── New Arrivals — section-level styles (mobile-first) ─── */
  /* Card styles are in assets/elevate-product-card.css (loaded by the snippet) */

  .elevate-arrivals {
    padding-block-start: var(--arrivals-pad-top);
    padding-block-end: var(--arrivals-pad-bottom);
  }

  .elevate-arrivals__inner {
    background: linear-gradient(180deg, #f1dbdc 0%, #fdfcfc 100%);
    border-radius: 2rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    overflow: hidden;
  }

  /* ── Header ── */
  .elevate-arrivals__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    text-align: left;
    overflow: hidden;
  }

  .elevate-arrivals__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-arrivals__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #141517;
    margin: 0;
  }

  .elevate-arrivals__subheading {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #36393F;
    margin: 0;
    max-width: 36rem;
  }

  /* ── Header alignment modifiers ── */
  .elevate-arrivals__header--left {
    text-align: left;
    align-items: flex-start;
  }

  .elevate-arrivals__header--center {
    text-align: center;
    align-items: center;
  }

  .elevate-arrivals__header--right {
    text-align: right;
    align-items: flex-end;
  }

  /* ── Carousel wrapper ── */
  .elevate-arrivals__carousel-wrap {
    position: relative;
    width: calc(100% + 1.5rem);
    margin-right: -1.5rem;
    align-self: stretch;
  }

  /* ── Track ── */
  .elevate-arrivals__track {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-left: 0;
    padding-right: 1.5rem;
    padding-block: 0.25rem;
  }

  .elevate-arrivals__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Nav row (arrows + dots) ── */
  .elevate-arrivals__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    align-self: center;
  }

  /* ── Arrow buttons ── */
  .elevate-arrivals__arrow {
    display: none;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    border: 0.03125rem solid #141517;
    background-color: transparent;
    color: #141517;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__arrow:hover {
    background-color: rgba(20, 21, 23, 0.06);
  }

  .elevate-arrivals__arrow:focus-visible {
    outline: 0.125rem solid #141517;
    outline-offset: 0.125rem;
  }

  .elevate-arrivals__arrow svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* ── Dot indicators ── */
  .elevate-arrivals__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .elevate-arrivals__dot {
    width: 0.75rem;
    height: 0.25rem;
    border-radius: 999px;
    background-color: #6B7280;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__dot--active {
    background-color: #E31E24;
  }

  /* ── Footer divider ── */
  .elevate-arrivals__divider {
    display: none;
    width: 100%;
    max-width: 49.375rem;
    height: 0.0625rem;
    background-color: #E2E3E5;
  }

  /* ── Footer ── */
  .elevate-arrivals__footer {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    text-align: left;
    width: 100%;
  }

  .elevate-arrivals__footer-text {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #36393F;
    margin: 0;
  }

  .elevate-arrivals__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 2.875rem;
    padding-inline: 1.5rem;
    background-color: #E31E24;
    border-radius: 0.75rem;
    color: #FDFCFC;
    text-decoration: none;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    white-space: nowrap;
    transition: background-color 0.2s ease;
    width: 100%;
  }

  .elevate-arrivals__cta:hover {
    background-color: #c9191e;
  }

  /* ─── Desktop (48rem / 768px) ─── */
  @media (min-width: 48rem) {
    .elevate-arrivals__inner {
      border-radius: 2.5rem;
      padding: 4.5rem 7.5rem;
      gap: 1.5rem;
      align-items: center;
    }

    .elevate-arrivals__subheading {
      font-size: 0.875rem;
      letter-spacing: -0.00875rem;
    }

    .elevate-arrivals__heading {
      font-size: 3.5625rem;
    }

    .elevate-arrivals__carousel-wrap {
      width: calc(100% + 7.5rem);
      margin-right: -7.5rem;
    }

    .elevate-arrivals__track {
      gap: 2rem;
      padding-left: 0;
      padding-right: 7.5rem;
    }

    .elevate-arrivals__arrow {
      display: flex;
    }

    .elevate-arrivals__divider {
      display: block;
    }

    .elevate-arrivals__footer {
      align-items: center;
      text-align: center;
      gap: 1rem;
    }

    .elevate-arrivals__footer-text {
      font-size: 0.875rem;
      letter-spacing: -0.00875rem;
    }

    .elevate-arrivals__cta {
      width: 36.5rem;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  /* ─── New Arrivals — page-based carousel navigation ─── */
  (function () {
    document.querySelectorAll('.elevate-arrivals').forEach(function (section) {
      var track = section.querySelector('[data-arrivals-track]');
      var dotsWrap = section.querySelector('[data-arrivals-dots]');
      var prevBtn = section.querySelector('[data-arrivals-prev]');
      var nextBtn = section.querySelector('[data-arrivals-next]');
      var cards = section.querySelectorAll('[data-arrivals-card]');
      if (!track || cards.length < 2) return;

      var activePage = 0;
      var pageCount = 1;
      var dots = [];

      /* ── Helpers ── */
      function getCardStep() {
        if (!cards[0]) return 300;
        var gap = parseFloat(getComputedStyle(track).gap) || 32;
        return cards[0].offsetWidth + gap;
      }

      function getVisibleCount() {
        if (!cards[0]) return 1;
        return Math.max(1, Math.round(track.offsetWidth / getCardStep()));
      }

      function getPageCount() {
        var visible = getVisibleCount();
        return Math.max(1, cards.length - visible + 1);
      }

      function getPageFromScroll() {
        var step = getCardStep();
        if (step <= 0) return 0;
        return Math.round(track.scrollLeft / step);
      }

      /* ── Build dots dynamically ── */
      function buildDots() {
        var newCount = getPageCount();
        if (newCount === pageCount && dots.length === newCount) return;
        pageCount = newCount;
        dotsWrap.innerHTML = '';
        dots = [];
        for (var i = 0; i < pageCount; i++) {
          var btn = document.createElement('button');
          btn.className = 'elevate-arrivals__dot' + (i === activePage ? ' elevate-arrivals__dot--active' : '');
          btn.type = 'button';
          btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          btn.setAttribute('data-dot-index', i);
          btn.addEventListener('click', (function (idx) {
            return function () { scrollToPage(idx); };
          })(i));
          dotsWrap.appendChild(btn);
          dots.push(btn);
        }
      }

      function updateActiveDot(page) {
        activePage = Math.max(0, Math.min(page, pageCount - 1));
        dots.forEach(function (dot, i) {
          dot.classList.toggle('elevate-arrivals__dot--active', i === activePage);
        });
      }

      /* ── Scroll to page ── */
      function scrollToPage(page) {
        var target = Math.max(0, Math.min(page, pageCount - 1));
        var step = getCardStep();
        track.scrollTo({ left: target * step, behavior: 'smooth' });
      }

      /* ── Scroll listener → sync dots ── */
      var scrollTimer;
      track.addEventListener('scroll', function () {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(function () {
          updateActiveDot(getPageFromScroll());
        }, 60);
      }, { passive: true });

      /* ── Arrow clicks ── */
      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          var page = getPageFromScroll();
          scrollToPage(page <= 0 ? pageCount - 1 : page - 1);
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          var page = getPageFromScroll();
          scrollToPage(page >= pageCount - 1 ? 0 : page + 1);
        });
      }

      /* ── Rebuild dots on resize ── */
      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          buildDots();
          updateActiveDot(getPageFromScroll());
        }, 150);
      });

      /* ── Init ── */
      buildDots();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "New Arrivals",
  "tag": "section",
  "class": "elevate-arrivals-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check what Just Dropped!"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional paragraph below the heading"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text",
      "default": "Stock moves fast. New items drop every weekday."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "View All Arrivals"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals",
      "settings": {
        "eyebrow": "NEW ARRIVALS",
        "heading": "Check what Just Dropped!",
        "footer_text": "Stock moves fast. New items drop every weekday.",
        "cta_label": "View All Arrivals"
      }
    }
  ]
}
{% endschema %}
