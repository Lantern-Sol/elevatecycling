{%- comment -%}
  Elevate Cycling — New Arrivals section.
  Horizontal product card carousel showcasing a featured collection.
  Cards display brand, condition badges, grade, pricing, and quick-action buttons.
{%- endcomment -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign max = section.settings.max_products | default: 6
  assign products = collection.products | default: empty
-%}

<div
  class="section section--full-width elevate-arrivals"
  data-scroll-reveal
  style="
    --arrivals-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --arrivals-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
  "
>
  <div class="elevate-arrivals__inner">
    {%- comment -%} ── Section header ── {%- endcomment -%}
    <div class="elevate-arrivals__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-arrivals__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-arrivals__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} ── Carousel ── {%- endcomment -%}
    {%- if collection != blank and products.size > 0 -%}
      <div class="elevate-arrivals__carousel-wrap">
        <div class="elevate-arrivals__track" data-arrivals-track>
          {%- for product in products limit: max -%}
            {%- liquid
              assign has_new_tag = false
              assign has_new_arrival_tag = false
              assign has_preowned_tag = false
              assign grade_value = ''
              assign condition_label = 'CPO / Brand New'

              for tag in product.tags
                assign tag_lower = tag | downcase
                if tag_lower == 'new arrival'
                  assign has_new_arrival_tag = true
                elsif tag_lower == 'new'
                  assign has_new_tag = true
                elsif tag_lower == 'pre-owned'
                  assign has_preowned_tag = true
                endif

                if tag contains 'Grade:'
                  assign grade_value = tag | split: ':' | last
                endif
              endfor

              if has_preowned_tag
                assign condition_label = 'Certified Pre-Owned'
              elsif has_new_tag and has_new_arrival_tag
                assign condition_label = 'CPO / Brand New'
              elsif has_new_arrival_tag
                assign condition_label = 'New Arrival'
              elsif has_new_tag
                assign condition_label = 'Brand New'
              endif

              comment
                Stats panel — metafield reads
              endcomment
              assign cr = product.metafields.custom.condition_rating.value
              assign mi = product.metafields.custom.mechanical_integrity.value
              assign msrp_raw = product.metafields.custom.msrp.value
              assign sl = product.metafields.custom.spec_level.value

              comment
                Grade letter + label from condition_rating
              endcomment
              assign card_grade_letter = ''
              assign card_grade_label = ''
              if cr != blank
                assign cr_num = cr | times: 1.0
                if cr_num >= 9
                  assign card_grade_letter = 'A+'
                  assign card_grade_label = 'New'
                elsif cr_num >= 8
                  assign card_grade_letter = 'A'
                  assign card_grade_label = 'Like New'
                elsif cr_num >= 6
                  assign card_grade_letter = 'B'
                  assign card_grade_label = 'Wear use'
                else
                  assign card_grade_letter = 'C'
                  assign card_grade_label = 'Good'
                endif
              endif

              comment
                Savings % from MSRP
              endcomment
              assign card_savings_pct = 0
              assign card_has_msrp = false
              if msrp_raw != blank
                assign msrp_cents = msrp_raw | times: 100 | round
                assign price_cents = product.price
                if msrp_cents > price_cents
                  assign card_has_msrp = true
                  assign diff = msrp_cents | minus: price_cents
                  assign card_savings_pct = diff | times: 100 | divided_by: msrp_cents
                endif
              endif

              comment
                Spec level label
              endcomment
              assign card_spec_label = ''
              if sl != blank
                assign sl_lower = sl | downcase
                if sl_lower == 'entry'
                  assign card_spec_label = 'Entry'
                elsif sl_lower == 'medium'
                  assign card_spec_label = 'Medium'
                elsif sl_lower == 'pro'
                  assign card_spec_label = 'Pro'
                else
                  assign card_spec_label = sl
                endif
              endif

              comment
                Show stats button only if at least one stat exists
              endcomment
              assign has_any_card_stat = false
              if cr != blank or mi != blank or card_has_msrp or sl != blank
                assign has_any_card_stat = true
              endif
            -%}

            <div class="elevate-arrivals__card" data-arrivals-card>
              {%- comment -%} Image area {%- endcomment -%}
              <a href="{{ product.url }}" class="elevate-arrivals__img-wrap" tabindex="-1" aria-hidden="true">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 760
                    | image_tag:
                      class: 'elevate-arrivals__img',
                      loading: 'lazy',
                      widths: '380,500,760',
                      sizes: '(min-width: 48rem) 24rem, 80vw',
                      alt: product.title
                  }}
                {%- else -%}
                  <div class="elevate-arrivals__img-placeholder"></div>
                {%- endif -%}

                {%- comment -%} Overlay badges (bottom-left) {%- endcomment -%}
                <div class="elevate-arrivals__badges">
                  {%- if has_new_tag -%}
                    <span class="elevate-arrivals__badge elevate-arrivals__badge--new">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        {%- render 'icon', icon: 'star' -%}
                      </svg>
                      New
                    </span>
                  {%- endif -%}
                  {%- if has_new_arrival_tag -%}
                    <span class="elevate-arrivals__badge elevate-arrivals__badge--arrival">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        {%- render 'icon', icon: 'certified' -%}
                      </svg>
                      New Arrival
                    </span>
                  {%- endif -%}
                </div>

                {%- comment -%} Grade pill (bottom-right) — tag fallback to metafield {%- endcomment -%}
                {%- liquid
                  assign display_grade = grade_value
                  if display_grade == blank and card_grade_letter != blank
                    assign display_grade = card_grade_letter
                  endif
                -%}
                {%- if display_grade != blank -%}
                  <span class="elevate-arrivals__grade elevate-arrivals__grade--{{ display_grade | downcase | replace: '+', 'plus' }}">
                    {{ display_grade }}
                  </span>
                {%- endif -%}
              </a>

              {%- comment -%} Brand / Condition row {%- endcomment -%}
              <div class="elevate-arrivals__meta">
                <span class="elevate-arrivals__brand">{{ product.vendor | upcase }}</span>
                <span class="elevate-arrivals__condition">{{ condition_label }}</span>
              </div>

              {%- comment -%} Product title {%- endcomment -%}
              <div class="elevate-arrivals__name">
                <a href="{{ product.url }}" class="elevate-arrivals__title">{{ product.title }}</a>
              </div>

              {%- comment -%} Price + CTA buttons {%- endcomment -%}
              <div class="elevate-arrivals__footer-row">
                <div class="elevate-arrivals__pricing">
                  <span class="elevate-arrivals__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="elevate-arrivals__retail">Retail Price {{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <div class="elevate-arrivals__ctas">
                  {%- if has_any_card_stat -%}
                    <button type="button" class="elevate-arrivals__btn-stats" aria-label="Toggle stats for {{ product.title }}" data-arrivals-stats-toggle>
                      <svg class="elevate-arrivals__icon-chart" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M18.5916 10.6357C19.064 10.6357 19.4468 10.2529 19.4468 9.78054C19.4468 9.30823 19.064 8.92534 18.5916 8.92534H6.85524C6.38293 8.92534 6.00004 9.30823 6.00004 9.78054C6.00004 10.2529 6.38293 10.6357 6.85524 10.6357H18.5916ZM15.1942 15.0611C15.6627 15.0611 16.0426 14.6812 16.0426 14.2127C16.0426 13.7441 15.6627 13.3643 15.1942 13.3643H6.84845C6.37989 13.3643 6.00004 13.7441 6.00004 14.2127C6.00004 14.6812 6.37989 15.0611 6.84845 15.0611H15.1942ZM21.1516 19.5C21.6202 19.5 22 19.1202 22 18.6516C22 18.183 21.6202 17.8032 21.1516 17.8032H6.84845C6.37989 17.8032 6.00004 18.183 6.00004 18.6516C6.00004 19.1202 6.37989 19.5 6.84845 19.5H21.1516Z" fill="#141517"/>
                        <path d="M2.00004 21C2.00004 21.5523 2.44776 22 3.00004 22C3.55232 22 4.00004 21.5523 4.00004 21V2.99999C4.00004 2.44771 3.55232 2 3.00004 2C2.44776 2 2.00004 2.44771 2.00004 3L2.00002 15.3334L2.00004 21ZM11.7899 4.5C12.2585 4.5 12.6383 4.87985 12.6383 5.34842C12.6383 5.81698 12.2585 6.19683 11.7899 6.19683H6.84845C6.37989 6.19683 6.00004 5.81698 6.00004 5.34842C6.00004 4.87985 6.37989 4.5 6.84845 4.5H11.7899Z" fill="#141517"/>
                      </svg>
                      <svg class="elevate-arrivals__icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M18 6L6 18M6 6L18 18" stroke="#141517" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  {%- endif -%}
                  {%- if product.available -%}
                    <button
                      type="button"
                      class="elevate-arrivals__btn-atc"
                      aria-label="Add {{ product.title }} to cart"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      data-arrivals-atc
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
                        <path d="M7.5 0V7.5H0V9H7.5V16.5H9V9H16.5V7.5H9V0H7.5Z" fill="#FDFCFC"/>
                      </svg>
                    </button>
                  {%- else -%}
                    <button
                      type="button"
                      class="elevate-arrivals__btn-atc"
                      aria-label="{{ product.title }} is sold out"
                      disabled
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
                        <path d="M7.5 0V7.5H0V9H7.5V16.5H9V9H16.5V7.5H9V0H7.5Z" fill="#FDFCFC"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Stats panel (toggled via JS) — absolutely positioned overlay {%- endcomment -%}
              {%- if has_any_card_stat -%}
                {%- liquid
                  comment
                    Progress bar widths: condition & mechanical = value*10%, savings = capped at 100, spec = entry 33 / medium 66 / pro 100
                  endcomment
                  assign cr_bar = 0
                  if cr != blank
                    assign cr_bar = cr | times: 10
                  endif
                  assign mi_bar = 0
                  if mi != blank
                    assign mi_bar = mi | times: 10
                  endif
                  assign savings_bar = 0
                  if card_has_msrp
                    assign savings_bar = card_savings_pct | at_most: 100
                  endif
                  assign spec_bar = 0
                  if sl != blank
                    assign sl_lower2 = sl | downcase
                    if sl_lower2 == 'entry'
                      assign spec_bar = 33
                    elsif sl_lower2 == 'medium'
                      assign spec_bar = 66
                    elsif sl_lower2 == 'pro'
                      assign spec_bar = 100
                    endif
                  endif
                -%}
                <div class="elevate-arrivals__stats-panel" data-arrivals-stats-panel>
                  <div class="elevate-arrivals__stats-header">
                    <span class="elevate-arrivals__stats-title">General Stats</span>
                    {%- if card_grade_letter != blank -%}
                      <span class="elevate-arrivals__stats-grade elevate-arrivals__stats-grade--{{ card_grade_letter | downcase | replace: '+', 'plus' }}">
                        Grade {{ card_grade_letter }} — {{ card_grade_label }}
                        <span class="elevate-arrivals__stats-grade-letter elevate-arrivals__stats-grade-letter--{{ card_grade_letter | downcase | replace: '+', 'plus' }}">{{ card_grade_letter }}</span>
                      </span>
                    {%- endif -%}
                  </div>
                  <div class="elevate-arrivals__stats-list">
                    {%- if cr != blank -%}
                      <div class="elevate-arrivals__stats-row">
                        <div class="elevate-arrivals__stats-row-top">
                          <span class="elevate-arrivals__stats-label">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C6.875 2 6.11719 2.44336 5.4375 2.8125C4.75781 3.18164 4.14062 3.5 3 3.5H2.5V4C2.5 7.85938 3.80469 10.3711 5.125 11.8906C6.44531 13.4102 7.8125 13.9688 7.8125 13.9688L8 14.0312L8.1875 13.9688C8.1875 13.9688 9.55469 13.4219 10.875 11.9062C12.1953 10.3906 13.5 7.87305 13.5 4V3.5H13C11.8652 3.5 11.2422 3.18164 10.5625 2.8125C9.88281 2.44336 9.125 2 8 2ZM8 3C8.875 3 9.37695 3.30664 10.0781 3.6875C10.6699 4.00977 11.4551 4.31836 12.4688 4.42188C12.373 7.80469 11.2539 9.95508 10.125 11.25C9.10156 12.4238 8.24219 12.8145 8 12.9219C7.75586 12.8125 6.89844 12.4121 5.875 11.2344C4.74609 9.93555 3.62695 7.78906 3.53125 4.42188C4.54883 4.31836 5.33008 4.00977 5.92188 3.6875C6.62305 3.30664 7.125 3 8 3Z" fill="#141517"/></svg>
                            Condition
                          </span>
                          <span class="elevate-arrivals__stats-value elevate-arrivals__stats-value--green">{{ cr }}/10</span>
                        </div>
                        <div class="elevate-arrivals__stats-bar">
                          <div class="elevate-arrivals__stats-bar-fill" style="width: {{ cr_bar }}%"></div>
                        </div>
                      </div>
                    {%- endif -%}
                    {%- if mi != blank -%}
                      <div class="elevate-arrivals__stats-row">
                        <div class="elevate-arrivals__stats-row-top">
                          <span class="elevate-arrivals__stats-label">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.625 1.375L2.34375 1.64062L1.64062 2.34375L1.375 2.625L1.57812 2.95312L2.625 4.70312L2.76562 4.95312H4.23438L6.23438 6.9375C4.44727 8.73242 2.17383 11.0137 2.09375 11.0937C1.31055 11.877 1.30859 13.1602 2.10938 13.9062C2.89062 14.6777 4.16406 14.6973 4.90625 13.9062C4.91211 13.9004 4.91602 13.8965 4.92188 13.8906L8 10.7969L11.0938 13.9062L11.1406 13.9375C11.9258 14.6777 13.1738 14.6875 13.9062 13.9062V13.8906H13.9219C14.6875 13.1074 14.6953 11.834 13.9062 11.0937L13.8906 11.0781L11.2812 8.48437C13.0371 8.32031 14.4121 6.83789 14.4375 5.04687H14.4531C14.4551 5.03711 14.4531 5.02539 14.4531 5.01562C14.4531 5.00977 14.4531 5.00586 14.4531 5C14.502 4.42187 14.377 3.86914 14.0781 3.39062L13.7344 2.85937L11.4062 5.1875L10.7031 4.45312L13.0781 2.07812L12.3906 1.79687C11.9883 1.625 11.5234 1.5 11 1.5C9.07812 1.5 7.5 3.07812 7.5 5C7.5 5.20898 7.54492 5.39062 7.57812 5.57812C7.35938 5.79687 7.19531 5.97656 6.9375 6.23437L4.95312 4.25V2.76562L4.70312 2.625L2.95312 1.57812L2.625 1.375ZM11 2.5C11.0703 2.5 11.1191 2.54102 11.1875 2.54687L9.29688 4.4375L9.64062 4.79687L11.0469 6.25L11.3906 6.60937L13.375 4.625C13.3848 4.74023 13.4668 4.82422 13.4531 4.95312V5C13.4531 6.37695 12.3301 7.5 10.9531 7.5C10.7695 7.5 10.5469 7.45703 10.2969 7.40625L10.0312 7.35937L9.84375 7.54687L4.20312 13.2031H4.1875V13.2187C3.83203 13.6074 3.21094 13.6172 2.79688 13.2031V13.1875H2.78125C2.39258 12.832 2.38281 12.2109 2.79688 11.7969C2.98633 11.6074 6.65625 7.90625 8.45312 6.10937L8.65625 5.90625L8.57812 5.625C8.53711 5.46289 8.5 5.18359 8.5 5C8.5 3.62305 9.62305 2.5 11 2.5ZM2.78125 2.625L3.95312 3.34375V3.84375L3.84375 3.95312H3.34375L2.625 2.78125L2.78125 2.625ZM10.0938 8.70312L13.2031 11.7969V11.8125H13.2188C13.6074 12.168 13.6172 12.7891 13.2031 13.2031H13.1875V13.2187C12.832 13.6074 12.2109 13.6172 11.7969 13.2031L8.70312 10.0937L10.0938 8.70312Z" fill="#141517"/></svg>
                            Mechanical integrity
                          </span>
                          <span class="elevate-arrivals__stats-value elevate-arrivals__stats-value--green">{{ mi }}/10</span>
                        </div>
                        <div class="elevate-arrivals__stats-bar">
                          <div class="elevate-arrivals__stats-bar-fill" style="width: {{ mi_bar }}%"></div>
                        </div>
                      </div>
                    {%- endif -%}
                    {%- if card_has_msrp -%}
                      <div class="elevate-arrivals__stats-row">
                        <div class="elevate-arrivals__stats-row-top">
                          <span class="elevate-arrivals__stats-label">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5L7.84375 2.64062L2.14062 8.40625L1.79688 8.75L2.14062 9.10938L6.89062 13.8594L7.25 14.2031L7.59375 13.8594L13.3594 8.15625L13.5 8V2.5H8ZM8.42188 3.5H12.5V7.57812L7.25 12.7969L3.20312 8.75L8.42188 3.5ZM11 4.5C10.7246 4.5 10.5 4.72461 10.5 5C10.5 5.27539 10.7246 5.5 11 5.5C11.2754 5.5 11.5 5.27539 11.5 5C11.5 4.72461 11.2754 4.5 11 4.5Z" fill="#141517"/></svg>
                            Value vs. retail
                          </span>
                          <span class="elevate-arrivals__stats-value elevate-arrivals__stats-value--green">{{ card_savings_pct }}% below MSRP</span>
                        </div>
                        <div class="elevate-arrivals__stats-bar">
                          <div class="elevate-arrivals__stats-bar-fill" style="width: {{ savings_bar }}%"></div>
                        </div>
                      </div>
                    {%- endif -%}
                    {%- if sl != blank -%}
                      <div class="elevate-arrivals__stats-row">
                        <div class="elevate-arrivals__stats-row-top">
                          <span class="elevate-arrivals__stats-label">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3C4.69141 3 2 5.69141 2 9C2 10.4473 2.51758 11.7754 3.375 12.8125L3.51562 13H12.4844L12.625 12.8125C13.4824 11.7754 14 10.4473 14 9C14 5.69141 11.3086 3 8 3ZM8 4C10.7676 4 13 6.23242 13 9C13 10.1328 12.6035 11.1621 11.9688 12H4.03125C3.39648 11.1621 3 10.1328 3 9C3 6.23242 5.23242 4 8 4ZM8 4.5C7.72461 4.5 7.5 4.72461 7.5 5C7.5 5.27539 7.72461 5.5 8 5.5C8.27539 5.5 8.5 5.27539 8.5 5C8.5 4.72461 8.27539 4.5 8 4.5ZM6 5.03125C5.72461 5.03125 5.5 5.25586 5.5 5.53125C5.5 5.80664 5.72461 6.03125 6 6.03125C6.27539 6.03125 6.5 5.80664 6.5 5.53125C6.5 5.25586 6.27539 5.03125 6 5.03125ZM10 5.03125C9.72461 5.03125 9.5 5.25586 9.5 5.53125C9.5 5.80664 9.72461 6.03125 10 6.03125C10.2754 6.03125 10.5 5.80664 10.5 5.53125C10.5 5.25586 10.2754 5.03125 10 5.03125ZM4.53125 6.5C4.25586 6.5 4.03125 6.72461 4.03125 7C4.03125 7.27539 4.25586 7.5 4.53125 7.5C4.80664 7.5 5.03125 7.27539 5.03125 7C5.03125 6.72461 4.80664 6.5 4.53125 6.5ZM11.3281 6.51562L8.5 8.14062C8.35352 8.05469 8.18164 8 8 8C7.44727 8 7 8.44727 7 9C7 9.55273 7.44727 10 8 10C8.54688 10 8.99219 9.56055 9 9.01562C9 9.00977 9 9.00586 9 9L11.8281 7.39062L11.3281 6.51562ZM4 8.5C3.72461 8.5 3.5 8.72461 3.5 9C3.5 9.27539 3.72461 9.5 4 9.5C4.27539 9.5 4.5 9.27539 4.5 9C4.5 8.72461 4.27539 8.5 4 8.5ZM12 8.5C11.7246 8.5 11.5 8.72461 11.5 9C11.5 9.27539 11.7246 9.5 12 9.5C12.2754 9.5 12.5 9.27539 12.5 9C12.5 8.72461 12.2754 8.5 12 8.5ZM4.53125 10.5C4.25586 10.5 4.03125 10.7246 4.03125 11C4.03125 11.2754 4.25586 11.5 4.53125 11.5C4.80664 11.5 5.03125 11.2754 5.03125 11C5.03125 10.7246 4.80664 10.5 4.53125 10.5ZM11.4688 10.5C11.1934 10.5 10.9688 10.7246 10.9688 11C10.9688 11.2754 11.1934 11.5 11.4688 11.5C11.7441 11.5 11.9688 11.2754 11.9688 11C11.9688 10.7246 11.7441 10.5 11.4688 10.5Z" fill="#141517"/></svg>
                            Spec Level
                          </span>
                          <span class="elevate-arrivals__stats-value">{{ card_spec_label }}</span>
                        </div>
                        <div class="elevate-arrivals__stats-bar">
                          <div class="elevate-arrivals__stats-bar-fill" style="width: {{ spec_bar }}%"></div>
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} ── Carousel nav: arrows + dots ── {%- endcomment -%}
      <div class="elevate-arrivals__nav">
        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Previous products"
          data-arrivals-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-left-solid' -%}
          </svg>
        </button>

        <div class="elevate-arrivals__dots" aria-label="Carousel navigation" data-arrivals-dots>
          {%- assign dot_count = products.size | at_most: max -%}
          {%- for i in (1..dot_count) -%}
            <button
              class="elevate-arrivals__dot{% if forloop.first %} elevate-arrivals__dot--active{% endif %}"
              type="button"
              aria-label="Go to product {{ forloop.index }}"
              data-dot-index="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>

        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Next products"
          data-arrivals-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-right-solid' -%}
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- comment -%} ── Footer: subtitle + CTA ── {%- endcomment -%}
    <div class="elevate-arrivals__footer">
      <div class="elevate-arrivals__divider"></div>
      {%- if section.settings.footer_text != blank -%}
        <p class="elevate-arrivals__footer-text">{{ section.settings.footer_text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a
          class="elevate-arrivals__cta"
          {% if section.settings.cta_link != blank %}href="{{ section.settings.cta_link }}"{% endif %}
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── New Arrivals — base (mobile-first) ─── */
  .elevate-arrivals {
    padding-block-start: var(--arrivals-pad-top);
    padding-block-end: var(--arrivals-pad-bottom);
  }

  .elevate-arrivals__inner {
    background: linear-gradient(180deg, #f1dbdc 0%, #fdfcfc 100%);
    border-radius: 2rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    overflow: hidden;
  }

  /* ── Header ── */
  .elevate-arrivals__header {
