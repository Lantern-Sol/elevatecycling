{%- comment -%}
  Elevate Cycling — New Arrivals section.
  Horizontal product card carousel showcasing a featured collection.
  Cards display brand, condition badges, grade, pricing, and quick-action buttons.
{%- endcomment -%}

{%- liquid
  assign collection = collections[section.settings.collection]
  assign max = section.settings.max_products | default: 6
  assign products = collection.products | default: empty
-%}

<div
  class="section section--full-width elevate-arrivals"
  data-scroll-reveal
  style="
    --arrivals-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --arrivals-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
  "
>
  <div class="elevate-arrivals__inner">
    {%- comment -%} ── Section header ── {%- endcomment -%}
    <div class="elevate-arrivals__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-arrivals__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-arrivals__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} ── Carousel ── {%- endcomment -%}
    {%- if collection != blank and products.size > 0 -%}
      <div class="elevate-arrivals__carousel-wrap">
        <div class="elevate-arrivals__track" data-arrivals-track>
          {%- for product in products limit: max -%}
            {%- liquid
              assign has_new_tag = false
              assign has_new_arrival_tag = false
              assign has_preowned_tag = false
              assign grade_value = ''
              assign condition_label = 'CPO / Brand New'

              for tag in product.tags
                assign tag_lower = tag | downcase
                if tag_lower == 'new arrival'
                  assign has_new_arrival_tag = true
                elsif tag_lower == 'new'
                  assign has_new_tag = true
                elsif tag_lower == 'pre-owned'
                  assign has_preowned_tag = true
                endif

                if tag contains 'Grade:'
                  assign grade_value = tag | split: ':' | last
                endif
              endfor

              if has_preowned_tag
                assign condition_label = 'Certified Pre-Owned'
              elsif has_new_tag and has_new_arrival_tag
                assign condition_label = 'CPO / Brand New'
              elsif has_new_arrival_tag
                assign condition_label = 'New Arrival'
              elsif has_new_tag
                assign condition_label = 'Brand New'
              endif
            -%}

            <div class="elevate-arrivals__card" data-arrivals-card>
              {%- comment -%} Image area {%- endcomment -%}
              <a href="{{ product.url }}" class="elevate-arrivals__img-wrap" tabindex="-1" aria-hidden="true">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 760
                    | image_tag:
                      class: 'elevate-arrivals__img',
                      loading: 'lazy',
                      widths: '380,500,760',
                      sizes: '(min-width: 48rem) 24rem, 80vw',
                      alt: product.title
                  }}
                {%- else -%}
                  <div class="elevate-arrivals__img-placeholder"></div>
                {%- endif -%}

                {%- comment -%} Overlay badges (bottom-left) {%- endcomment -%}
                <div class="elevate-arrivals__badges">
                  {%- if has_new_tag -%}
                    <span class="elevate-arrivals__badge elevate-arrivals__badge--new">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        {%- render 'icon', icon: 'star' -%}
                      </svg>
                      New
                    </span>
                  {%- endif -%}
                  {%- if has_new_arrival_tag -%}
                    <span class="elevate-arrivals__badge elevate-arrivals__badge--arrival">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        {%- render 'icon', icon: 'certified' -%}
                      </svg>
                      New Arrival
                    </span>
                  {%- endif -%}
                </div>

                {%- comment -%} Grade pill (bottom-right) {%- endcomment -%}
                {%- if grade_value != blank -%}
                  <span class="elevate-arrivals__grade elevate-arrivals__grade--{{ grade_value | downcase | replace: '+', 'plus' }}">
                    {{ grade_value }}
                  </span>
                {%- endif -%}
              </a>

              {%- comment -%} Brand / Condition row {%- endcomment -%}
              <div class="elevate-arrivals__meta">
                <span class="elevate-arrivals__brand">{{ product.vendor | upcase }}</span>
                <span class="elevate-arrivals__condition">{{ condition_label }}</span>
              </div>

              {%- comment -%} Product title {%- endcomment -%}
              <div class="elevate-arrivals__name">
                <a href="{{ product.url }}" class="elevate-arrivals__title">{{ product.title }}</a>
              </div>

              {%- comment -%} Price + CTA buttons {%- endcomment -%}
              <div class="elevate-arrivals__footer-row">
                <div class="elevate-arrivals__pricing">
                  <span class="elevate-arrivals__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="elevate-arrivals__retail">Retail Price {{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <div class="elevate-arrivals__ctas">
                  <a href="{{ product.url }}" class="elevate-arrivals__btn-stats" aria-label="View stats for {{ product.title }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M18.5916 10.6357C19.064 10.6357 19.4468 10.2529 19.4468 9.78054C19.4468 9.30823 19.064 8.92534 18.5916 8.92534H6.85524C6.38293 8.92534 6.00004 9.30823 6.00004 9.78054C6.00004 10.2529 6.38293 10.6357 6.85524 10.6357H18.5916ZM15.1942 15.0611C15.6627 15.0611 16.0426 14.6812 16.0426 14.2127C16.0426 13.7441 15.6627 13.3643 15.1942 13.3643H6.84845C6.37989 13.3643 6.00004 13.7441 6.00004 14.2127C6.00004 14.6812 6.37989 15.0611 6.84845 15.0611H15.1942ZM21.1516 19.5C21.6202 19.5 22 19.1202 22 18.6516C22 18.183 21.6202 17.8032 21.1516 17.8032H6.84845C6.37989 17.8032 6.00004 18.183 6.00004 18.6516C6.00004 19.1202 6.37989 19.5 6.84845 19.5H21.1516Z" fill="#141517"/>
                      <path d="M2.00004 21C2.00004 21.5523 2.44776 22 3.00004 22C3.55232 22 4.00004 21.5523 4.00004 21V2.99999C4.00004 2.44771 3.55232 2 3.00004 2C2.44776 2 2.00004 2.44771 2.00004 3L2.00002 15.3334L2.00004 21ZM11.7899 4.5C12.2585 4.5 12.6383 4.87985 12.6383 5.34842C12.6383 5.81698 12.2585 6.19683 11.7899 6.19683H6.84845C6.37989 6.19683 6.00004 5.81698 6.00004 5.34842C6.00004 4.87985 6.37989 4.5 6.84845 4.5H11.7899Z" fill="#141517"/>
                    </svg>
                  </a>
                  <button type="button" class="elevate-arrivals__btn-atc" aria-label="Add {{ product.title }} to cart">
                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
                      <path d="M7.5 0V7.5H0V9H7.5V16.5H9V9H16.5V7.5H9V0H7.5Z" fill="#FDFCFC"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} ── Carousel nav: arrows + dots ── {%- endcomment -%}
      <div class="elevate-arrivals__nav">
        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Previous products"
          data-arrivals-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-left-solid' -%}
          </svg>
        </button>

        <div class="elevate-arrivals__dots" aria-label="Carousel navigation" data-arrivals-dots>
          {%- assign dot_count = products.size | at_most: max -%}
          {%- for i in (1..dot_count) -%}
            <button
              class="elevate-arrivals__dot{% if forloop.first %} elevate-arrivals__dot--active{% endif %}"
              type="button"
              aria-label="Go to product {{ forloop.index }}"
              data-dot-index="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>

        <button
          class="elevate-arrivals__arrow"
          type="button"
          aria-label="Next products"
          data-arrivals-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="24" height="24">
            {%- render 'icon', icon: 'arrow-right-solid' -%}
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- comment -%} ── Footer: subtitle + CTA ── {%- endcomment -%}
    <div class="elevate-arrivals__footer">
      <div class="elevate-arrivals__divider"></div>
      {%- if section.settings.footer_text != blank -%}
        <p class="elevate-arrivals__footer-text">{{ section.settings.footer_text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a
          class="elevate-arrivals__cta"
          {% if section.settings.cta_link != blank %}href="{{ section.settings.cta_link }}"{% endif %}
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── New Arrivals — base (mobile-first) ─── */
  .elevate-arrivals {
    padding-block-start: var(--arrivals-pad-top);
    padding-block-end: var(--arrivals-pad-bottom);
  }

  .elevate-arrivals__inner {
    background: linear-gradient(180deg, #f1dbdc 0%, #fdfcfc 100%);
    border-radius: 2rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    overflow: hidden;
  }

  /* ── Header ── */
  .elevate-arrivals__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    text-align: left;
    overflow: hidden;
  }

  .elevate-arrivals__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-arrivals__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #141517;
    margin: 0;
  }

  /* ── Carousel wrapper ── */
  .elevate-arrivals__carousel-wrap {
    position: relative;
    width: calc(100% + 1.5rem);
    margin-right: -1.5rem;
    align-self: stretch;
  }

  /* ── Track ── */
  .elevate-arrivals__track {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-left: 0;
    padding-right: 1.5rem;
    padding-block: 0.25rem;
  }

  .elevate-arrivals__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Card ── */
  .elevate-arrivals__card {
    flex: 0 0 21.375rem;
    min-width: 21.375rem;
    background-color: #FDFCFC;
    border-radius: 1.5rem;
    overflow: hidden;
    scroll-snap-align: start;
    box-shadow: 0 0.0625rem 0.1875rem rgba(0, 0, 0, 0.1), 0 0.0625rem 0.125rem -0.0625rem rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Image area ── */
  .elevate-arrivals__img-wrap {
    position: relative;
    display: block;
    aspect-ratio: 342 / 228;
    overflow: hidden;
    border-radius: 1rem;
    background-color: #f2f2f3;
    text-decoration: none;
  }

  .elevate-arrivals__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .elevate-arrivals__img-placeholder {
    width: 100%;
    height: 100%;
    background-color: #e2e3e5;
  }

  /* ── Badges (bottom-left of image) ── */
  .elevate-arrivals__badges {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .elevate-arrivals__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.5;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    color: #141517;
    letter-spacing: -0.0075rem;
    white-space: nowrap;
  }

  .elevate-arrivals__badge svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .elevate-arrivals__badge--new {
    background-color: #4ade80;
  }

  .elevate-arrivals__badge--arrival {
    background-color: #f9d44e;
  }

  /* ── Grade pill (bottom-right of image) ── */
  .elevate-arrivals__grade {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    height: 1.5rem;
    padding-inline: 0.75rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    border-radius: 999px;
    color: #FDFCFC;
    background-color: #6B7280;
  }

  .elevate-arrivals__grade--aplus,
  .elevate-arrivals__grade--a {
    background-color: #4ade80;
  }

  .elevate-arrivals__grade--b {
    background-color: #f9d44e;
  }

  .elevate-arrivals__grade--c {
    background-color: #f97316;
  }

  /* ── Brand / Condition row ── */
  .elevate-arrivals__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 0.75rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
  }

  .elevate-arrivals__brand {
    flex: 1;
    min-width: 0;
    color: #E31E24;
  }

  .elevate-arrivals__condition {
    flex: 1;
    min-width: 0;
    color: #AEB2B8;
    text-align: right;
  }

  /* ── Product title ── */
  .elevate-arrivals__name {
    padding-inline: 0.75rem;
  }

  .elevate-arrivals__title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.2;
    color: #141517;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .elevate-arrivals__title:hover {
    text-decoration: underline;
  }

  /* ── Price + CTA row ── */
  .elevate-arrivals__footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.25rem 0.5rem 0.5rem 0.75rem;
    margin-top: auto;
  }

  .elevate-arrivals__pricing {
    display: flex;
    flex-direction: column;
    gap: 0;
    white-space: nowrap;
  }

  .elevate-arrivals__price {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: -0.0125rem;
    color: #141517;
  }

  .elevate-arrivals__retail {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #AEB2B8;
  }

  /* ── Card CTA buttons ── */
  .elevate-arrivals__ctas {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .elevate-arrivals__btn-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.75rem;
    border: 0.03125rem solid #141517;
    background-color: transparent;
    color: #141517;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__btn-stats:hover {
    background-color: rgba(20, 21, 23, 0.06);
  }

  .elevate-arrivals__btn-stats svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .elevate-arrivals__btn-atc {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.75rem;
    border: none;
    background-color: #E31E24;
    color: #FDFCFC;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__btn-atc:hover {
    background-color: #c9191e;
  }

  .elevate-arrivals__btn-atc svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* ── Nav row (arrows + dots) ── */
  .elevate-arrivals__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    align-self: center;
  }

  /* ── Arrow buttons ── */
  .elevate-arrivals__arrow {
    display: none;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    border: 0.03125rem solid #141517;
    background-color: transparent;
    color: #141517;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__arrow:hover {
    background-color: rgba(20, 21, 23, 0.06);
  }

  .elevate-arrivals__arrow:focus-visible {
    outline: 0.125rem solid #141517;
    outline-offset: 0.125rem;
  }

  .elevate-arrivals__arrow svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  /* ── Dot indicators ── */
  .elevate-arrivals__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .elevate-arrivals__dot {
    width: 0.75rem;
    height: 0.25rem;
    border-radius: 999px;
    background-color: #6B7280;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .elevate-arrivals__dot--active {
    background-color: #E31E24;
  }

  /* ── Footer divider ── */
  .elevate-arrivals__divider {
    display: none;
    width: 100%;
    max-width: 49.375rem;
    height: 0.0625rem;
    background-color: #E2E3E5;
  }

  /* ── Footer ── */
  .elevate-arrivals__footer {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    text-align: left;
    width: 100%;
  }

  .elevate-arrivals__footer-text {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #36393F;
    margin: 0;
  }

  .elevate-arrivals__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 2.875rem;
    padding-inline: 1.5rem;
    background-color: #E31E24;
    border-radius: 0.75rem;
    color: #FDFCFC;
    text-decoration: none;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    white-space: nowrap;
    transition: background-color 0.2s ease;
    width: 100%;
  }

  .elevate-arrivals__cta:hover {
    background-color: #c9191e;
  }

  /* ─── Desktop (48rem / 768px) ─── */
  @media (min-width: 48rem) {
    .elevate-arrivals__inner {
      border-radius: 2.5rem;
      padding: 4.5rem 7.5rem;
      gap: 1.5rem;
      align-items: center;
    }

    .elevate-arrivals__header {
      text-align: center;
    }

    .elevate-arrivals__heading {
      font-size: 3.5625rem;
    }

    .elevate-arrivals__carousel-wrap {
      width: calc(100% + 7.5rem);
      margin-right: -7.5rem;
    }

    .elevate-arrivals__track {
      gap: 2rem;
      padding-left: 0;
      padding-right: 7.5rem;
    }

    .elevate-arrivals__card {
      flex: 0 0 23.625rem;
      min-width: 23.625rem;
    }

    .elevate-arrivals__title {
      font-size: 1.25rem;
    }

    .elevate-arrivals__price {
      font-size: 1.5rem;
      letter-spacing: -0.015rem;
    }

    .elevate-arrivals__arrow {
      display: flex;
    }

    .elevate-arrivals__divider {
      display: block;
    }

    .elevate-arrivals__footer {
      align-items: center;
      text-align: center;
      gap: 1rem;
    }

    .elevate-arrivals__footer-text {
      font-size: 0.875rem;
      letter-spacing: -0.00875rem;
    }

    .elevate-arrivals__cta {
      width: 36.5rem;
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  /* ─── New Arrivals — carousel navigation ─── */
  (function () {
    document.querySelectorAll('.elevate-arrivals').forEach(function (section) {
      var track = section.querySelector('[data-arrivals-track]');
      var dots = section.querySelectorAll('.elevate-arrivals__dot');
      var prevBtn = section.querySelector('[data-arrivals-prev]');
      var nextBtn = section.querySelector('[data-arrivals-next]');
      var cards = section.querySelectorAll('[data-arrivals-card]');
      if (!track || cards.length < 2) return;

      /* Scroll → update active dot via IntersectionObserver */
      var activeDot = 0;
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var index = Array.prototype.indexOf.call(cards, entry.target);
            if (index >= 0) {
              activeDot = index;
              dots.forEach(function (dot, i) {
                dot.classList.toggle('elevate-arrivals__dot--active', i === index);
              });
            }
          }
        });
      }, {
        root: track,
        threshold: 0.6
      });

      cards.forEach(function (card) {
        observer.observe(card);
      });

      /* Arrow click → scroll by card width + gap (with loop) */
      function getScrollAmount() {
        if (!cards[0]) return 300;
        var style = getComputedStyle(track);
        var gap = parseFloat(style.gap) || 32;
        return cards[0].offsetWidth + gap;
      }

      function isAtStart() {
        return track.scrollLeft <= 2;
      }

      function isAtEnd() {
        return track.scrollLeft + track.offsetWidth >= track.scrollWidth - 2;
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          if (isAtStart()) {
            cards[cards.length - 1].scrollIntoView({ behavior: 'smooth', inline: 'end', block: 'nearest' });
          } else {
            track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
          }
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          if (isAtEnd()) {
            cards[0].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          } else {
            track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
          }
        });
      }

      /* Dot click → scroll to card */
      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          var index = parseInt(dot.getAttribute('data-dot-index'), 10);
          if (cards[index]) {
            cards[index].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          }
        });
      });
    });
  })();
{% endjavascript %}

