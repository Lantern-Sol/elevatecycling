{%- doc -%}
  Elevate Cycling — Blog newsletter signup section.
  Two-column layout: text content (left), email form (right).
{%- enddoc -%}

{%- liquid
  assign pt = section.settings.padding_top | times: 0.0625
  assign pb = section.settings.padding_bottom | times: 0.0625
-%}

<div
  class="section section--page-width page-width-normal elevate-blog-newsletter"
  data-scroll-reveal
  style="
    background: linear-gradient(180deg, transparent 0%, #E9E9E9 16%);
    padding-block-start: {{ pt }}rem;
    padding-block-end: {{ pb }}rem;
  "
>
  <div class="elevate-blog-newsletter__inner">
    <div class="elevate-blog-newsletter__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-blog-newsletter__heading">{{ section.settings.heading | newline_to_br }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="elevate-blog-newsletter__body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="elevate-blog-newsletter__form-wrap" id="blog-newsletter-{{ section.id }}">
      {%- form 'customer', id: 'BlogNewsletter' -%}
        {%- if form.posted_successfully? -%}
          <p class="elevate-blog-newsletter__success" role="status" tabindex="-1">
            {{ section.settings.success_message }}
          </p>
        {%- else -%}
          <input type="hidden" name="contact[tags]" value="newsletter, blog">

          {%- if form.errors -%}
            <p class="elevate-blog-newsletter__error" role="alert">
              {{ form.errors.translated_fields['email'] | capitalize }}
              {{ form.errors.messages['email'] }}
            </p>
          {%- endif -%}

          <div class="elevate-blog-newsletter__field">
            <label
              for="blog-newsletter-email-{{ section.id }}"
              class="elevate-blog-newsletter__label"
            >
              {{ section.settings.email_label }}
            </label>
            <input
              type="email"
              name="contact[email]"
              id="blog-newsletter-email-{{ section.id }}"
              class="elevate-blog-newsletter__input"
              placeholder="{{ section.settings.email_placeholder }}"
              value="{{ form.email }}"
              required
              autocomplete="email"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>

          <button type="submit" class="elevate-blog-newsletter__btn">
            {{ section.settings.button_label }}
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── Blog Newsletter ─── */
  .elevate-blog-newsletter__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  /* ── Text content ── */
  .elevate-blog-newsletter__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
    align-items: center;
  }

  .elevate-blog-newsletter__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #36393F;
    text-align: left;
    width: 100%;
    margin: 0;
  }

  .elevate-blog-newsletter__body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #000;
    text-align: left;
    margin: 0;
    width: 100%;
  }

  /* ── Form ── */
  .elevate-blog-newsletter__form-wrap {
    width: 100%;
  }

  .elevate-blog-newsletter__form-wrap form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-blog-newsletter__field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-blog-newsletter__label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    color: #141517;
    padding-inline: 0.5rem;
  }

  .elevate-blog-newsletter__input {
    height: 2.875rem;
    border-radius: 0.5rem;
    border: 0.0625rem solid #AEB2B8;
    background: #FDFCFC;
    padding: 0 1rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    color: #36393F;
    outline: none;
    transition: border-color 0.2s ease-in-out;
  }

  .elevate-blog-newsletter__input::placeholder {
    color: #AEB2B8;
  }

  .elevate-blog-newsletter__input:focus-visible {
    border-color: #E31E24;
    outline: 0.125rem solid #E31E24;
    outline-offset: 0.0625rem;
  }

  .elevate-blog-newsletter__input[aria-invalid="true"] {
    border-color: #E31E24;
  }

  .elevate-blog-newsletter__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 2.875rem;
    border-radius: 0.75rem;
    background: #E31E24;
    color: #FDFCFC;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease-in-out;
  }

  .elevate-blog-newsletter__btn:hover {
    background: #c8191e;
  }

  .elevate-blog-newsletter__btn:focus-visible {
    outline: 0.125rem solid #36393F;
    outline-offset: 0.125rem;
  }

  /* ── Success / Error ── */
  .elevate-blog-newsletter__success {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    color: #1a7a3a;
    margin: 0;
    padding: 0.75rem 1rem;
    background: #e8f5e9;
    border-radius: 0.5rem;
  }

  .elevate-blog-newsletter__error {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #E31E24;
    margin: 0;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-blog-newsletter__inner {
      flex-direction: row;
      align-items: center;
      padding-inline: 6.5rem;
    }

    .elevate-blog-newsletter__content {
      flex: 1 1 0%;
      min-width: 0;
    }

    .elevate-blog-newsletter__heading {
      font-size: 3rem;
    }

    .elevate-blog-newsletter__body {
      white-space: pre-line;
    }

    .elevate-blog-newsletter__form-wrap {
      flex: 0 0 30rem;
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog Newsletter",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New gear drops daily.\nDon't miss the good stuff."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Subscribe and we'll keep you posted — new listings, buying\nguides, and CPO tips straight to your inbox."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "johndoe@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe to Newsletter"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in! New articles will land in your inbox."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Blog Newsletter"
    }
  ]
}
{% endschema %}
