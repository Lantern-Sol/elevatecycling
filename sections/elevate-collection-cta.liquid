{%- doc -%}
  Elevate Cycling — Collection CTA banner.
  Horizontal bar promoting the trade-in / sell program.
  Dark red radial gradient, gold eyebrow, white heading, red button.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-collection-cta"
  data-scroll-reveal
  style="
    background: radial-gradient(circle at top left, rgba(109,19,22,1) 0%, rgba(73,14,16,1) 50%, rgba(37,10,10,1) 100%);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="elevate-collection-cta__inner">
    <div class="elevate-collection-cta__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-collection-cta__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-collection-cta__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link != blank %}href="{{ section.settings.button_link }}"{% endif %}
        class="elevate-collection-cta__btn"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ─── Collection CTA ─── */
  .elevate-collection-cta__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-inline: 0.5rem;
  }

  .elevate-collection-cta__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-collection-cta__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    text-transform: uppercase;
    color: #F9D44E;
    margin: 0;
  }

  .elevate-collection-cta__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #FDFCFC;
    margin: 0;
  }

  /* ── Button ── */
  .elevate-collection-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    background: #E31E24;
    color: #FDFCFC;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease-in-out;
  }

  .elevate-collection-cta__btn:hover {
    background: #c8191e;
  }

  .elevate-collection-cta__btn:focus-visible {
    outline: 0.125rem solid #fff;
    outline-offset: 0.125rem;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-collection-cta__inner {
      padding-inline: 4.375rem;
    }

    .elevate-collection-cta__heading {
      font-size: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection CTA",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "PAY WITH YOUR OLD GEAR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sell or trade in"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get a Quote"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 32,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Collection CTA"
    }
  ]
}
{% endschema %}
