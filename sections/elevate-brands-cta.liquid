{%- comment -%}
  Elevate Cycling — Brands CTA section.
  Dark gradient banner encouraging users to sell or trade brands
  not listed. Placed below the brands grid.
{%- endcomment -%}

<div
  class="section section--page-width page-width-normal elevate-brands-cta"
  data-scroll-reveal
  style="
    background: linear-gradient(to bottom, {{ section.settings.gradient_from }}, {{ section.settings.gradient_to }});
    --elevate-brands-cta-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-brands-cta-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
  "
>
  <div class="elevate-brands-cta__inner">
    {%- if section.settings.caption != blank -%}
      <p class="elevate-brands-cta__caption">{{ section.settings.caption }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="elevate-brands-cta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="elevate-brands-cta__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a {% if section.settings.button_url != blank %}href="{{ section.settings.button_url }}"{% endif %} class="elevate-brands-cta__btn">
        {{ section.settings.button_text }}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ─── Brands CTA ─── */
  .elevate-brands-cta {
    border-radius: 2rem 2rem 0 0;
    overflow: hidden;
    text-align: center;
  }

  .elevate-brands-cta__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-inline: 0;
    padding-block-start: var(--elevate-brands-cta-pt);
    padding-block-end: var(--elevate-brands-cta-pb);
  }

  /* ── Caption ── */
  .elevate-brands-cta__caption {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: 0.05em;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Heading ── */
  .elevate-brands-cta__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #FDFCFC;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Body ── */
  .elevate-brands-cta__body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #FDFCFC;
    margin: 0;
    max-width: none;
  }

  /* ── Button ── */
  .elevate-brands-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #E31E24;
    color: #FDFCFC;
    border-radius: 0.75rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.5;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .elevate-brands-cta__btn:hover {
    opacity: 0.85;
  }

  .elevate-brands-cta__btn svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-brands-cta__inner {
      padding-inline: 4.375rem;
    }

    .elevate-brands-cta__heading {
      font-size: 3rem;
    }

    .elevate-brands-cta__body {
      max-width: 24.125rem;
    }

    .elevate-brands-cta__btn {
      width: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brands CTA",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "SELL OR TRADE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DON'T SEE YOUR BRAND?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "We buy most performance road, gravel, and triathlon brands. Get a free offer within 24 hours."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get your offer"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "gradient_from",
      "label": "Gradient top",
      "default": "#250a0a"
    },
    {
      "type": "color",
      "id": "gradient_to",
      "label": "Gradient bottom",
      "default": "#6d1316"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Brands CTA"
    }
  ]
}
{% endschema %}
