    {
      "name": "FAQ",
      "settings": {
        "heading_line_1": "Questions?",
        "heading_line_2": "we got the answers",
        "help_eyebrow": "NEED MORE HELP?",
        "help_text": "Our mechanics answer the phone, reply to emails, and actually know what a BB386 is.",
