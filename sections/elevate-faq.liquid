{%- doc -%}
  Elevate Cycling — FAQ section.
  Desktop: two-column layout — sticky left sidebar (heading, contacts, CTA)
  + right accordion. Mobile: heading → accordion → divider → contacts → CTA.
{%- enddoc -%}

<div
  class="section section--page-width elevate-faq"
  data-scroll-reveal
  style="
    --page-content-width: 75rem;
    --page-width: calc(75rem + var(--page-margin) * 2);
    padding-block-end: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
  "
>
  {%- comment -%} ── Top divider ── {%- endcomment -%}
  {%- if section.settings.show_divider -%}
    <div class="elevate-faq__divider"></div>
  {%- endif -%}

  {%- comment -%} ── Two-column layout ── {%- endcomment -%}
  <div class="elevate-faq__layout">

    {%- comment -%} ── Heading — always first ── {%- endcomment -%}
    {%- if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank -%}
      <h2 class="elevate-faq__heading">
        {%- if section.settings.heading_line_1 != blank -%}
          <span class="elevate-faq__heading-line1">{{ section.settings.heading_line_1 }}</span>
        {%- endif -%}
        {%- if section.settings.heading_line_2 != blank -%}
          <span class="elevate-faq__heading-line2">{{ section.settings.heading_line_2 }}</span>
        {%- endif -%}
      </h2>
    {%- endif -%}

    {%- comment -%} ── FAQ accordion ── {%- endcomment -%}
    <div class="elevate-faq__accordion">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <details class="elevate-faq__item" {{ block.shopify_attributes }}>
            <summary class="elevate-faq__question">
              <span class="elevate-faq__question-text">{{ block.settings.question }}</span>
              <svg class="elevate-faq__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'angle-down-solid' -%}
              </svg>
            </summary>
            <div class="elevate-faq__answer">
              <p>{{ block.settings.answer }}</p>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── Bottom section: divider (mobile), contacts, help ── {%- endcomment -%}
    <div class="elevate-faq__bottom">
      <div class="elevate-faq__divider elevate-faq__divider--bottom"></div>

      {%- comment -%} Contact cards {%- endcomment -%}
      <div class="elevate-faq__contacts">
        {%- if section.settings.phone != blank -%}
          <a class="elevate-faq__contact" {% if section.settings.phone_link != blank %}href="{{ section.settings.phone_link }}"{% endif %}>
            <div class="elevate-faq__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'phone-solid' -%}
              </svg>
            </div>
            <div class="elevate-faq__contact-text">
              <span class="elevate-faq__contact-label">{{ section.settings.phone_label }}</span>
              <span class="elevate-faq__contact-value">{{ section.settings.phone }}</span>
              <span class="elevate-faq__contact-note">{{ section.settings.phone_note }}</span>
            </div>
            <svg class="elevate-faq__contact-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
          <a class="elevate-faq__contact" {% if section.settings.email_link != blank %}href="{{ section.settings.email_link }}"{% endif %}>
            <div class="elevate-faq__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'mail-solid' -%}
              </svg>
            </div>
            <div class="elevate-faq__contact-text">
              <span class="elevate-faq__contact-label">{{ section.settings.email_label }}</span>
              <span class="elevate-faq__contact-value">{{ section.settings.email }}</span>
              <span class="elevate-faq__contact-note">{{ section.settings.email_note }}</span>
            </div>
            <svg class="elevate-faq__contact-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.location != blank -%}
          <a class="elevate-faq__contact" {% if section.settings.location_link != blank %}href="{{ section.settings.location_link }}"{% endif %}>
            <div class="elevate-faq__contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'map-pin-solid' -%}
              </svg>
            </div>
            <div class="elevate-faq__contact-text">
              <span class="elevate-faq__contact-label">{{ section.settings.location_label }}</span>
              <span class="elevate-faq__contact-value">{{ section.settings.location }}</span>
              <span class="elevate-faq__contact-note">{{ section.settings.location_note }}</span>
            </div>
            <svg class="elevate-faq__contact-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              {%- render 'icon', icon: 'arrow-right-solid' -%}
            </svg>
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} Need more help {%- endcomment -%}
      <div class="elevate-faq__help">
        {%- if section.settings.help_eyebrow != blank -%}
          <p class="elevate-faq__help-eyebrow">{{ section.settings.help_eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.help_text != blank -%}
          <p class="elevate-faq__help-text">{{ section.settings.help_text }}</p>
        {%- endif -%}
        <div class="elevate-faq__help-buttons">
          {%- if section.settings.primary_label != blank -%}
            <a
              class="elevate-faq__btn elevate-faq__btn--primary"
              {% if section.settings.primary_link != blank %}href="{{ section.settings.primary_link }}"{% endif %}
            >
              {{ section.settings.primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_label != blank -%}
            <a
              class="elevate-faq__btn elevate-faq__btn--secondary"
              {% if section.settings.secondary_link != blank %}href="{{ section.settings.secondary_link }}"{% endif %}
            >
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .elevate-faq {
    padding-block-start: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
  }

  @media (max-width: 47.9375rem) {
    #shopify-section-{{ section.id }} .elevate-faq {
      padding-block-start: 0;
    }
  }
{%- endstyle -%}

{% stylesheet %}
  /* ─── FAQ Section ─── */

  /* ── Divider ── */
  .elevate-faq__divider {
    width: 100%;
    height: 1px;
    background-color: #E2E3E5;
    margin-bottom: 2rem;
  }

  /* ── Layout — mobile: stacked column ── */
  .elevate-faq__layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Heading ── */
  .elevate-faq__heading {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .elevate-faq__heading-line1 {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #E31E24;
  }

  .elevate-faq__heading-line2 {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #E31E24;
  }

  /* ── Accordion ── */
  .elevate-faq__accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-faq__item {
    background-color: rgba(226, 227, 229, 0.4);
    border-radius: 1rem;
    overflow: hidden;
  }

  .elevate-faq__question {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 1rem;
    cursor: pointer;
    list-style: none;
  }

  .elevate-faq__question::-webkit-details-marker {
    display: none;
  }

  .elevate-faq__question-text {
    flex: 1;
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.2;
    color: #1C2D38;
  }

  .elevate-faq__chevron {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: #36393F;
    transition: transform 0.3s ease;
  }

  .elevate-faq__item[open] .elevate-faq__chevron {
    transform: rotate(180deg);
  }

  .elevate-faq__answer {
    padding: 0 1rem 1rem 1.5rem;
  }

  .elevate-faq__answer p {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #36393F;
    margin: 0;
  }

  /* ── Bottom section (contacts + help) ── */
  .elevate-faq__bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-faq__divider--bottom {
    margin-bottom: 1rem;
  }

  /* ── Contact cards ── */
  .elevate-faq__contacts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-faq__contact {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    border: 0.03125rem solid #AEB2B8;
    border-radius: 1rem;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .elevate-faq__contact:hover {
    background-color: rgba(226, 227, 229, 0.3);
  }

  .elevate-faq__contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background-color: #F1DBDC;
    border-radius: 0.625rem;
    flex-shrink: 0;
  }

  .elevate-faq__contact-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: #E31E24;
  }

  .elevate-faq__contact-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .elevate-faq__contact-label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #141517;
  }

  .elevate-faq__contact-value {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #D61D18;
  }

  .elevate-faq__contact-note {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #6B7280;
  }

  .elevate-faq__contact-arrow {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: #AEB2B8;
  }

  /* ── Need more help ── */
  .elevate-faq__help {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-faq__help-eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-faq__help-text {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #6B7280;
    margin: 0;
  }

  .elevate-faq__help-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-faq__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 2.875rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .elevate-faq__btn:hover {
    opacity: 0.9;
  }

  .elevate-faq__btn--primary {
    background-color: #E31E24;
    color: #FDFCFC;
    border: none;
  }

  .elevate-faq__btn--secondary {
    background-color: transparent;
    color: #141517;
    border: 0.03125rem solid #141517;
  }

  /* ─── Desktop (48rem / 768px) ─── */
  @media (min-width: 48rem) {
    .elevate-faq__divider {
      width: 49.375rem;
      margin-inline: auto;
    }

    .elevate-faq__layout {
      display: grid;
      grid-template-columns: 24rem 1fr;
      grid-template-rows: auto 1fr;
      gap: 1.5rem 2rem;
      align-items: start;
    }

    /* Heading top-left */
    .elevate-faq__heading {
      grid-column: 1;
      grid-row: 1;
    }

    /* Accordion spans entire right column */
    .elevate-faq__accordion {
      grid-column: 2;
      grid-row: 1 / -1;
    }

    /* Bottom section (contacts + help) under heading */
    .elevate-faq__bottom {
      grid-column: 1;
      grid-row: 2;
      position: sticky;
      top: 6rem;
    }

    /* Hide mobile-only bottom divider on desktop */
    .elevate-faq__divider--bottom {
      display: none;
    }

    .elevate-faq__heading-line1 {
      font-size: 3.5625rem;
    }

    .elevate-faq__heading-line2 {
      font-size: 3rem;
    }

    .elevate-faq__question-text {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "elevate-faq-section",
  "settings": [
    {
      "type": "header",
