{%- doc -%}
  Elevate Cycling — LP How It Works (Buy) Section.
  Dark card with rounded bottom corners. Eyebrow + title header,
  then a 3-column numbered step grid showing the purchase process.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-lp-how-it-works"
  data-scroll-reveal
  style="
    background: #141517;
    border-radius: 0 0 2rem 2rem;
    --hiw-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --hiw-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
  "
>
  <div class="elevate-lp-how-it-works__inner">
    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="elevate-lp-how-it-works__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-lp-how-it-works__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="elevate-lp-how-it-works__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} ── Steps grid ── {%- endcomment -%}
    <div class="elevate-lp-how-it-works__steps">
      {%- for i in (1..3) -%}
        {%- liquid
          assign num_key   = 'step_' | append: i | append: '_number'
          assign title_key = 'step_' | append: i | append: '_title'
          assign desc_key  = 'step_' | append: i | append: '_description'
        -%}
        <div class="elevate-lp-how-it-works__step">
          <p class="elevate-lp-how-it-works__number">{{ section.settings[num_key] }}</p>
          <p class="elevate-lp-how-it-works__step-title">{{ section.settings[title_key] }}</p>
          <p class="elevate-lp-how-it-works__step-desc">{{ section.settings[desc_key] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── LP How It Works ─── */
  .elevate-lp-how-it-works {
    grid-column: 1 / -1;
    padding-block: var(--hiw-pt) var(--hiw-pb);
  }

  .elevate-lp-how-it-works__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 0.5rem;
  }

  /* ── Header ── */
  .elevate-lp-how-it-works__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-lp-how-it-works__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0.045rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-lp-how-it-works__title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #FDFCFC;
    margin: 0;
  }

  /* ── Steps grid ── */
  .elevate-lp-how-it-works__steps {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-lp-how-it-works__step {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-lp-how-it-works__number {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    color: #E31E24;
    margin: 0;
  }

  .elevate-lp-how-it-works__step-title {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.0125rem;
    color: #FDFCFC;
    margin: 0;
  }

  .elevate-lp-how-it-works__step-desc {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: rgba(253, 252, 252, 0.7);
    margin: 0;
  }

  /* ── Desktop (990px+) ── */
  @media (min-width: 61.9375rem) {
    .elevate-lp-how-it-works__inner {
      padding-inline: 2.375rem;
    }

    .elevate-lp-how-it-works__title {
      font-size: 3.5625rem;
    }

    .elevate-lp-how-it-works__steps {
      flex-direction: row;
      gap: 2rem;
    }

    .elevate-lp-how-it-works__step {
      flex: 1 1 0%;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
