    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PURCHASE PROCESS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How it works"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "step_1_number",
      "label": "Number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Title",
      "default": "Browse Verified Stock"
    },
    {
      "type": "textarea",
      "id": "step_1_description",
      "label": "Description",
      "default": "Filtered by frame size, groupset, and condition grade — no guesswork."
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "step_2_number",
      "label": "Number",
      "default": "02"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Title",
      "default": "Read the Full Report"
    },
    {
      "type": "textarea",
      "id": "step_2_description",
      "label": "Description",
      "default": "Every listing includes a detailed spec sheet and honest condition notes."
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "text",
      "id": "step_3_number",
