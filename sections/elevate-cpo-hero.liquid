{%- doc -%}
  Elevate Cycling — CPO (Certified Pre-Owned) hero section.
  Full-bleed background with left-to-right gradient overlay,
  left-aligned content: breadcrumb, badge pill, heading with accent word,
  subtitle, two CTA buttons, and a configurable stats row.
{%- enddoc -%}

{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign heading_html = section.settings.heading
  if section.settings.heading_accent != blank
    assign accent_open = '<span class="elevate-cpo-hero__accent">'
    assign accent_close = '</span>'
    assign accent_wrap = accent_open | append: section.settings.heading_accent | append: accent_close
    assign heading_html = heading_html | replace: section.settings.heading_accent, accent_wrap
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-cpo-hero"
  style="
    --elevate-cpo-hero-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-cpo-hero-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
    --elevate-cpo-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- comment -%} ── Background media ── {%- endcomment -%}
  <div class="elevate-cpo-hero__media">
    {%- if has_image -%}
      {%- assign img = section.settings.image -%}
      {{
        img
        | image_url: width: 3840
        | image_tag:
          widths: '375, 750, 1080, 1440, 1920, 2560, 3840',
          sizes: '100vw',
          fetchpriority: 'high',
          loading: 'eager',
          class: 'elevate-cpo-hero__image',
          alt: ''
      }}
    {%- else -%}
      <div class="elevate-cpo-hero__placeholder"></div>
    {%- endif -%}

    <div class="elevate-cpo-hero__overlay"></div>
  </div>

  <div class="elevate-cpo-hero__inner">
    {%- comment -%} ── Breadcrumb (outside content group — 40px gap to content) ── {%- endcomment -%}
    {%- if section.settings.breadcrumb_1_label != blank -%}
      <nav class="elevate-cpo-hero__breadcrumb" aria-label="Breadcrumb">
        <ol class="elevate-cpo-hero__breadcrumb-list">
          <li class="elevate-cpo-hero__breadcrumb-item">
            {%- if section.settings.breadcrumb_1_link != blank -%}
              <a href="{{ section.settings.breadcrumb_1_link }}">{{ section.settings.breadcrumb_1_label }}</a>
            {%- else -%}
              <span>{{ section.settings.breadcrumb_1_label }}</span>
            {%- endif -%}
          </li>
          {%- if section.settings.breadcrumb_2_label != blank -%}
            <li class="elevate-cpo-hero__breadcrumb-item">
              <span class="elevate-cpo-hero__breadcrumb-sep" aria-hidden="true">/</span>
              {%- if section.settings.breadcrumb_2_link != blank -%}
                <a href="{{ section.settings.breadcrumb_2_link }}">{{ section.settings.breadcrumb_2_label }}</a>
              {%- else -%}
                <span>{{ section.settings.breadcrumb_2_label }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
        </ol>
      </nav>
    {%- endif -%}

    <div class="elevate-cpo-hero__content">
      {%- if section.settings.badge_text != blank -%}
        <span class="elevate-cpo-hero__badge">{{ section.settings.badge_text }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="elevate-cpo-hero__heading">{{ heading_html }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="elevate-cpo-hero__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- comment -%} ── Stats row ── {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="elevate-cpo-hero__stats">
          {%- for block in section.blocks -%}
            <div class="elevate-cpo-hero__stat" {{ block.shopify_attributes }}>
              <p class="elevate-cpo-hero__stat-value">{{ block.settings.value }}</p>
              <p class="elevate-cpo-hero__stat-label">{{ block.settings.label }}</p>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} ── CTA buttons (secondary first, primary second per Figma) ── {%- endcomment -%}
      {%- if section.settings.primary_label != blank or section.settings.secondary_label != blank -%}
        <div class="elevate-cpo-hero__buttons">
          {%- if section.settings.secondary_label != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="elevate-cpo-hero__btn elevate-cpo-hero__btn--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}

          {%- if section.settings.primary_label != blank -%}
            <a href="{{ section.settings.primary_link }}" class="elevate-cpo-hero__btn elevate-cpo-hero__btn--primary">
              <span>{{ section.settings.primary_label }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {%- render 'icon', icon: 'arrow-right-solid' -%}
              </svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ─── CPO Hero ─── */
  .elevate-cpo-hero {
    position: relative;
    overflow: hidden;
    padding-block: 2rem;
  }

  .elevate-cpo-hero__inner {
    grid-column: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 2.5rem;
    min-height: 33.5rem;
    padding-inline: 1.25rem;
  }

  /* ── Media layer ── */
  .elevate-cpo-hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest);
    grid-column: 1 / -1;
  }

  .elevate-cpo-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .elevate-cpo-hero__placeholder {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
  }

  .elevate-cpo-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      203.6deg,
      rgba(7, 7, 7, 0) 26%,
      rgb(7, 7, 7) 60.265%
    );
    pointer-events: none;
  }

  /* ── Breadcrumb ── */
  .elevate-cpo-hero__breadcrumb {
    position: relative;
    z-index: var(--layer-flat);
  }

  .elevate-cpo-hero__breadcrumb-list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .elevate-cpo-hero__breadcrumb-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.5;
    color: #FDFCFC;
  }

  .elevate-cpo-hero__breadcrumb-item a {
    color: #FDFCFC;
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  .elevate-cpo-hero__breadcrumb-item a:hover {
    text-decoration: underline;
  }

  .elevate-cpo-hero__breadcrumb-sep {
    color: #FDFCFC;
  }

  /* ── Content group ── */
  .elevate-cpo-hero__content {
    position: relative;
    z-index: var(--layer-flat);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    gap: 0.75rem;
    flex: 1;
  }

  /* ── Badge ── */
  .elevate-cpo-hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3125rem 0.75rem;
    background: #E31E24;
    border-radius: 62.4375rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
    text-transform: uppercase;
  }

  /* ── Heading ── */
  .elevate-cpo-hero__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1.2;
    color: #FDFCFC;
    margin: 0;
  }

  .elevate-cpo-hero__accent {
    color: #E31E24;
  }

  /* ── Subtitle ── */
  .elevate-cpo-hero__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #E2E3E5;
    margin: 0;
    max-width: 35.75rem;
  }

  /* ── Stats row ── */
  .elevate-cpo-hero__stats {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0;
    padding-block-start: 1rem;
  }

  .elevate-cpo-hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
    flex: 1;
    padding-inline: 0.75rem;
  }

  .elevate-cpo-hero__stat:first-child {
    padding-inline-start: 0;
  }

  .elevate-cpo-hero__stat + .elevate-cpo-hero__stat {
    border-inline-start: 0.0625rem solid #6B7280;
  }

  .elevate-cpo-hero__stat-value {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #AEB2B8;
    margin: 0;
  }

  .elevate-cpo-hero__stat-label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #6B7280;
    margin: 0;
  }

  @media (min-width: 20.0625rem) {
    .elevate-cpo-hero__stat-label {
      white-space: nowrap;
    }
  }

  /* ── Buttons ── */
  .elevate-cpo-hero__buttons {
    display: flex;
    flex-direction: column-reverse;
    gap: 0.5rem;
    width: 100%;
  }

  .elevate-cpo-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 0 1.5rem;
    border-radius: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color 0.2s ease-in-out,
      border-color 0.2s ease-in-out,
      opacity 0.2s ease-in-out;
  }

  .elevate-cpo-hero__btn:focus-visible {
    outline: 0.125rem solid #fff;
    outline-offset: 0.125rem;
  }

  .elevate-cpo-hero__btn--primary {
    background: #E31E24;
    color: #FDFCFC;
    border: none;
    gap: 0.5rem;
  }

  .elevate-cpo-hero__btn--primary svg {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .elevate-cpo-hero__btn--primary:hover {
    background: #c8191e;
  }

  .elevate-cpo-hero__btn--secondary {
    background: transparent;
    color: #FDFCFC;
    border: 0.03125rem solid #FDFCFC;
  }

  .elevate-cpo-hero__btn--secondary:hover {
    border-color: #fff;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-cpo-hero {
      padding-block-start: var(--elevate-cpo-hero-pt);
      padding-block-end: var(--elevate-cpo-hero-pb);
    }

    .elevate-cpo-hero__overlay {
      background: linear-gradient(
        to right,
        rgba(0, 0, 0, var(--elevate-cpo-hero-overlay-opacity, 0.8)) 0%,
        rgba(0, 0, 0, var(--elevate-cpo-hero-overlay-opacity, 0.8)) 43.27%,
        rgba(0, 0, 0, 0) 75%
      );
    }

    .elevate-cpo-hero__inner {
      min-height: 28rem;
      padding-inline: 4.375rem;
    }

    .elevate-cpo-hero__content {
      justify-content: center;
      gap: 1.5rem;
    }

    .elevate-cpo-hero__heading {
      font-size: 4rem;
      line-height: 1.1;
      max-width: 37.5rem;
    }

    .elevate-cpo-hero__buttons {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      width: auto;
      max-width: 31.625rem;
    }

    .elevate-cpo-hero__btn {
      flex: 1 1 0%;
      min-width: 0;
    }

    .elevate-cpo-hero__stat {
      width: 10.5rem;
      flex: none;
    }

    .elevate-cpo-hero__stat-value {
      font-size: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CPO Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Gradient opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "text",
      "id": "breadcrumb_1_label",
      "label": "Breadcrumb 1 label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "breadcrumb_1_link",
      "label": "Breadcrumb 1 link"
    },
    {
      "type": "text",
      "id": "breadcrumb_2_label",
      "label": "Breadcrumb 2 label",
      "default": "Complete Bikes"
    },
    {
      "type": "url",
      "id": "breadcrumb_2_link",
      "label": "Breadcrumb 2 link"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "CERTIFIED PRE-OWNED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Serious cyclists don't buy new. They buy certified."
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent text",
      "info": "Word(s) within the heading to highlight in red.",
      "default": "They buy certified."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Each bike is inspected, tuned, and backed by a 30-day warranty — so you ride with total confidence."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Certified Bikes"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Sell or trade your bike"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "100+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "stat label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CPO Hero",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "3,500+",
            "label": "bikes certified"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "99.8%",
            "label": "eBay feedback"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "$5.4M",
            "label": "paid to sellers"
          }
        }
      ]
    }
  ]
}
{% endschema %}
