{%- doc -%}
  Elevate Cycling — B2B Mid-page conviction CTA.
  Dark banner: heading + description left, contact info + CTA button right.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-b2b-conviction"
  data-scroll-reveal
  style="
    background: {{ section.settings.background_color }};
    --b2b-conviction-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --b2b-conviction-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
    {%- if section.settings.mobile_padding_custom -%}
      --b2b-conviction-pad-top-m: {{ section.settings.padding_top_mobile | divided_by: 16.0 }}rem;
      --b2b-conviction-pad-bottom-m: {{ section.settings.padding_bottom_mobile | divided_by: 16.0 }}rem;
    {%- endif -%}
  "
>
  <div class="elevate-b2b-conviction__inner">
    {%- comment -%} Left column: heading + description {%- endcomment -%}
    <div class="elevate-b2b-conviction__left">
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-b2b-conviction__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="elevate-b2b-conviction__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Right column: contact block + CTA {%- endcomment -%}
    <div class="elevate-b2b-conviction__right">
      <div class="elevate-b2b-conviction__contacts">
        {%- if section.settings.contact_1_label != blank -%}
          <div class="elevate-b2b-conviction__contact">
            <p class="elevate-b2b-conviction__contact-label">{{ section.settings.contact_1_label }}</p>
            <p class="elevate-b2b-conviction__contact-value">{{ section.settings.contact_1_value }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.contact_2_label != blank -%}
          <span class="elevate-b2b-conviction__divider" aria-hidden="true"></span>
          <div class="elevate-b2b-conviction__contact">
            <p class="elevate-b2b-conviction__contact-label">{{ section.settings.contact_2_label }}</p>
            {%- if section.settings.contact_2_url != blank -%}
              <a class="elevate-b2b-conviction__contact-value elevate-b2b-conviction__contact-value--link" href="{{ section.settings.contact_2_url }}">{{ section.settings.contact_2_value }}</a>
            {%- else -%}
              <p class="elevate-b2b-conviction__contact-value">{{ section.settings.contact_2_value }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.contact_3_label != blank -%}
          <span class="elevate-b2b-conviction__divider" aria-hidden="true"></span>
          <div class="elevate-b2b-conviction__contact">
            <p class="elevate-b2b-conviction__contact-label">{{ section.settings.contact_3_label }}</p>
            {%- if section.settings.contact_3_url != blank -%}
              <a class="elevate-b2b-conviction__contact-value elevate-b2b-conviction__contact-value--link" href="{{ section.settings.contact_3_url }}">{{ section.settings.contact_3_value }}</a>
            {%- else -%}
              <p class="elevate-b2b-conviction__contact-value">{{ section.settings.contact_3_value }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <a
        class="elevate-b2b-conviction__cta"
        href="#elevate-b2b-cta"
        onclick="event.preventDefault();document.querySelector('.elevate-b2b-cta__inner').scrollIntoView({behavior:'smooth',block:'start'})"
      >
        {{- section.settings.cta_text -}}
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .elevate-b2b-conviction__inner {
    padding-block: var(--b2b-conviction-pad-top-m, var(--b2b-conviction-pad-top)) var(--b2b-conviction-pad-bottom-m, var(--b2b-conviction-pad-bottom));
    padding-inline: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    border-radius: 1.5rem 1.5rem 0 0;
    overflow: clip;
  }

  /* ---- Left column ---- */
  .elevate-b2b-conviction__left {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .elevate-b2b-conviction__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #FDFCFC;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-conviction__description {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #AEB2B8;
    margin: 0;
  }

  /* ---- Right column: contacts ---- */
  .elevate-b2b-conviction__right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-b2b-conviction__contacts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .elevate-b2b-conviction__contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-b2b-conviction__contact-label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #AEB2B8;
    text-transform: uppercase;
    margin: 0;
    white-space: nowrap;
  }

  .elevate-b2b-conviction__contact-value {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #FDFCFC;
    margin: 0;
    white-space: nowrap;
  }

  .elevate-b2b-conviction__contact-value--link {
    text-decoration: none;
  }
  .elevate-b2b-conviction__contact-value--link:hover {
    text-decoration: underline;
  }

  .elevate-b2b-conviction__divider {
    display: none;
  }

  /* ---- CTA button ---- */
  .elevate-b2b-conviction__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: #E31E24;
    color: #FDFCFC;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    text-decoration: none;
    text-transform: none;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    width: 100%;
  }
  .elevate-b2b-conviction__cta:hover {
    opacity: 0.9;
  }

  /* ---- Desktop ---- */
  @media (min-width: 61.9375rem) {
    .elevate-b2b-conviction__inner {
      padding-block: var(--b2b-conviction-pad-top) var(--b2b-conviction-pad-bottom);
      flex-direction: row;
      align-items: center;
      gap: 5rem;
      padding-inline: 4.375rem;
    }

    .elevate-b2b-conviction__left {
      flex: 1;
      min-width: 0;
    }

    .elevate-b2b-conviction__heading {
      font-size: 3rem;
    }

    .elevate-b2b-conviction__right {
      flex-shrink: 0;
    }

    .elevate-b2b-conviction__contacts {
      gap: 1.5rem;
      flex-wrap: nowrap;
    }

    .elevate-b2b-conviction__divider {
      display: block;
      width: 0.0625rem;
      align-self: stretch;
      background: #6B7280;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "B2B Conviction CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WRITTEN OFFER IN 48 HOURS."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Send us your SKUs, quantities, condition, and target floor. We come back with a written offer on the whole lot — and a draft resale agreement built around your channel rules."
    },
    {
      "type": "text",
      "id": "contact_1_label",
      "label": "Contact 1 label",
      "default": "PARTNERSHIPS LEAD"
    },
    {
      "type": "text",
      "id": "contact_1_value",
      "label": "Contact 1 value",
      "default": "Kevin Qian · COO"
    },
    {
      "type": "text",
      "id": "contact_2_label",
      "label": "Contact 2 label",
      "default": "EMAIL"
    },
    {
      "type": "text",
      "id": "contact_2_value",
      "label": "Contact 2 value",
      "default": "partners@elevatecycling.com"
    },
    {
      "type": "text",
      "id": "contact_2_url",
      "label": "Contact 2 link",
      "default": "mailto:partners@elevatecycling.com"
    },
    {
      "type": "text",
      "id": "contact_3_label",
      "label": "Contact 3 label",
      "default": "DIRECT"
    },
    {
      "type": "text",
      "id": "contact_3_value",
      "label": "Contact 3 value",
      "default": "(714) 248-5066"
    },
    {
      "type": "text",
      "id": "contact_3_url",
      "label": "Contact 3 link",
      "default": "tel:+17142485066"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Send Your Inventory List"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#250A0A"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "mobile_padding_custom",
      "label": "Custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    }
  ]
}
{% endschema %}
