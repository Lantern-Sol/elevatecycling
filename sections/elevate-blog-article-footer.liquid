<div
  class="section section--page-width page-width-normal elevate-blog-article-footer"
  data-scroll-reveal
  style="background: #FDFCFC; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">

  <div class="elevate-blog-article-footer__inner">
    {%- if section.blocks.size > 0 -%}
      <div class="elevate-blog-article-footer__takeaways">
        <span class="elevate-blog-article-footer__eyebrow">KEY TAKEAWAYS</span>
        <div class="elevate-blog-article-footer__takeaways-list">
          {%- for block in section.blocks -%}
            <div class="elevate-blog-article-footer__takeaway-item" {{ block.shopify_attributes }}>
              <span class="elevate-blog-article-footer__takeaway-num">{{ forloop.index }}</span>
              <p class="elevate-blog-article-footer__takeaway-text">{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="elevate-blog-article-footer__tags-card">
      {%- if article.tags.size > 0 -%}
        <span class="elevate-blog-article-footer__eyebrow">TAGS</span>
        <div class="elevate-blog-article-footer__tags-list">
          {%- for tag in article.tags -%}
            <span class="elevate-blog-article-footer__tag-pill">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="elevate-blog-article-footer__share-row">
        <span class="elevate-blog-article-footer__share-label">Share this article</span>
        <button
          type="button"
          class="elevate-blog-article-footer__copy-link"
          data-copy-url="{{ article.url | prepend: request.origin }}"
          aria-label="{{ section.settings.share_button_label }}">
          <span data-copy-label>{{ section.settings.share_button_label }}</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.querySelector('.elevate-blog-article-footer');
    if (!section) return;

    var btn = section.querySelector('.elevate-blog-article-footer__copy-link');
    if (!btn) return;

    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-copy-url') || window.location.href;
      var label = btn.querySelector('[data-copy-label]');
      var original = label.textContent;

      navigator.clipboard.writeText(url).then(function() {
        label.textContent = 'Copied!';
        btn.classList.add('is-copied');
        setTimeout(function() {
          label.textContent = original;
          btn.classList.remove('is-copied');
        }, 2000);
      });
    });
  })();
</script>

{% stylesheet %}
  .elevate-blog-article-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  /* — Key Takeaways Card — */
  .elevate-blog-article-footer__takeaways {
    background: rgba(226, 227, 229, 0.4);
    border-radius: 2rem;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-blog-article-footer__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #E31E24;
  }

  .elevate-blog-article-footer__takeaways-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-blog-article-footer__takeaway-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .elevate-blog-article-footer__takeaway-num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background: #E31E24;
    border-radius: 0.25rem;
    color: #FDFCFC;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1;
  }

  .elevate-blog-article-footer__takeaway-text {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #6B7280;
    margin: 0;
  }

  /* — Tags + Share Card — */
  .elevate-blog-article-footer__tags-card {
    background: linear-gradient(180deg, #250A0A 0%, #6D1316 100%);
    border-radius: 2rem;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-blog-article-footer__tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
  }

  .elevate-blog-article-footer__tag-pill {
    display: inline-block;
    border: 1px solid #FDFCFC;
    border-radius: 999px;
    padding: 0.25rem 0.625rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #FDFCFC;
    line-height: 1.4;
  }

  .elevate-blog-article-footer__share-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .elevate-blog-article-footer__share-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #AEB2B8;
  }

  .elevate-blog-article-footer__copy-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 0.5px solid #FDFCFC;
    border-radius: 0.75rem;
    padding: 0.5rem 1.5rem;
    background: transparent;
    color: #FDFCFC;
    font-family: 'Host Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .elevate-blog-article-footer__copy-link:hover,
  .elevate-blog-article-footer__copy-link:focus-visible {
    background: rgba(253, 252, 252, 0.15);
  }

  .elevate-blog-article-footer__copy-link:focus-visible {
    outline: 2px solid #FDFCFC;
    outline-offset: 2px;
  }

  .elevate-blog-article-footer__copy-link.is-copied {
    border-color: #4ADE80;
    color: #4ADE80;
  }

  .elevate-blog-article-footer__copy-link svg {
    flex-shrink: 0;
  }

  /* — Desktop — */
  @media (min-width: 61.9375rem) {
    .elevate-blog-article-footer__inner {
      flex-direction: row;
      align-items: flex-start;
      padding-inline: 10.375rem;
    }

    .elevate-blog-article-footer__takeaways {
      flex: 0 0 37rem;
    }

    .elevate-blog-article-footer__tags-card {
      flex: 1 1 0%;
      min-width: 0;
      max-width: 24.0625rem;
      align-self: center;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Article Footer",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "label": "Padding bottom"
    },
    {
      "type": "text",
      "id": "share_button_label",
      "default": "Copy Link",
      "label": "Share button label"
    }
  ],
  "blocks": [
    {
      "type": "takeaway",
      "name": "Takeaway",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Takeaway text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Article Footer"
    }
  ]
}
{% endschema %}
