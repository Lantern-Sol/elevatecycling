{%- comment -%}
  Elevate Cycling — PDP "Complete the Kit" bundle section.
  Shows current product + 2 complementary products from metafield (custom.bundle_products)
  with fallback to Shopify complementary recommendations API.
  Summary bar with bundle pricing + "Bike only" / "Add bundle to cart" CTAs.
{%- endcomment -%}

{%- if product != blank -%}
{%- liquid
  assign bundle_products = product.metafields.custom.bundle_products.value
  assign has_bundle = false
  if bundle_products != blank and bundle_products.size >= 2
    assign kit_1 = bundle_products[0]
    assign kit_2 = bundle_products[1]
    assign has_bundle = true
  else
    if section.settings.kit_product_1 != blank
      assign kit_1 = section.settings.kit_product_1
    endif
    if section.settings.kit_product_2 != blank
      assign kit_2 = section.settings.kit_product_2
    endif
    if kit_1 != blank or kit_2 != blank
      assign has_bundle = true
    endif
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign current_price = current_variant.price
  assign current_compare = current_variant.compare_at_price | default: current_price

  assign kit1_price = 0
  assign kit1_compare = 0
  assign kit2_price = 0
  assign kit2_compare = 0

  if kit_1 != blank
    assign kit1_variant = kit_1.selected_or_first_available_variant
    assign kit1_price = kit1_variant.price
    assign kit1_compare = kit1_variant.compare_at_price | default: kit1_price
  endif
  if kit_2 != blank
    assign kit2_variant = kit_2.selected_or_first_available_variant
    assign kit2_price = kit2_variant.price
    assign kit2_compare = kit2_variant.compare_at_price | default: kit2_price
  endif

  if has_bundle
    assign bundle_price = current_price | plus: kit1_price | plus: kit2_price
    assign bundle_compare = current_compare | plus: kit1_compare | plus: kit2_compare
    assign bundle_save = bundle_compare | minus: bundle_price
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-pdp-bundle"
  data-scroll-reveal
  data-product-id="{{ product.id }}"
  style="
    background: linear-gradient(180deg, #f1dbdc 0%, #FDFCFC 100%);
    border-radius: 2rem;
    --elevate-pdp-bundle-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-pdp-bundle-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
    {% unless has_bundle %}display: none;{% endunless %}
  "
>
  <div class="elevate-pdp-bundle__inner">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="elevate-pdp-bundle__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-pdp-bundle__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="elevate-pdp-bundle__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="elevate-pdp-bundle__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── Cards ── {%- endcomment -%}
    <div class="elevate-pdp-bundle__cards">

      {%- comment -%} Card 1 — Current product {%- endcomment -%}
      <div
        class="elevate-pdp-bundle__card is-current"
        data-bundle-card="current"
        data-variant-id="{{ current_variant.id }}"
      >
        <div class="elevate-pdp-bundle__card-img">
          {%- if product.featured_image != blank -%}
            {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 200px, 120px', widths: '120, 200, 400' }}
          {%- endif -%}
        </div>
        <div class="elevate-pdp-bundle__card-info">
          {%- assign current_category = product.type | default: product.collections.first.title -%}
          {%- if current_category != blank -%}
            <p class="elevate-pdp-bundle__card-category">{{ current_category }}</p>
          {%- endif -%}
          <p class="elevate-pdp-bundle__card-title">{{ product.title }}</p>
          {%- if product.description != blank -%}
            <p class="elevate-pdp-bundle__card-desc">{{ product.description | strip_html | truncatewords: 12 }}</p>
          {%- endif -%}
          <div class="elevate-pdp-bundle__card-price-row">
            <span class="elevate-pdp-bundle__card-price" data-current-price>{{ current_price | money }}</span>
            {%- if current_compare > current_price -%}
              <span class="elevate-pdp-bundle__card-compare">{{ current_compare | money }}</span>
              {%- assign card_save = current_compare | minus: current_price -%}
              <span class="elevate-pdp-bundle__save-badge">Save {{ card_save | money }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- if has_bundle -%}
        {%- if kit_1 != blank -%}
          {%- comment -%} Card 2 — Kit product 1 {%- endcomment -%}
          <div
            class="elevate-pdp-bundle__card"
            data-bundle-card="kit"
            data-variant-id="{{ kit1_variant.id }}"
            data-product-url="{{ kit_1.url }}"
            data-price="{{ kit1_price }}"
            data-compare="{{ kit1_compare }}"
          >
            <div class="elevate-pdp-bundle__card-img">
              {%- if kit_1.featured_image != blank -%}
                {{ kit_1.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 200px, 120px', widths: '120, 200, 400' }}
              {%- endif -%}
            </div>
            <div class="elevate-pdp-bundle__card-info">
              {%- assign kit1_category = kit_1.type | default: kit_1.collections.first.title -%}
              {%- if kit1_category != blank -%}
                <p class="elevate-pdp-bundle__card-category">{{ kit1_category }}</p>
              {%- endif -%}
              <p class="elevate-pdp-bundle__card-title">{{ kit_1.title }}</p>
              {%- if kit_1.description != blank -%}
                <p class="elevate-pdp-bundle__card-desc">{{ kit_1.description | strip_html | truncatewords: 12 }}</p>
              {%- endif -%}
              <div class="elevate-pdp-bundle__card-price-row">
                <span class="elevate-pdp-bundle__card-price">{{ kit1_price | money }}</span>
                {%- if kit1_compare > kit1_price -%}
                  <span class="elevate-pdp-bundle__card-compare">{{ kit1_compare | money }}</span>
                  {%- assign kit1_save = kit1_compare | minus: kit1_price -%}
                  <span class="elevate-pdp-bundle__save-badge">Save {{ kit1_save | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if kit_2 != blank -%}
          {%- comment -%} Card 3 — Kit product 2 {%- endcomment -%}
          <div
            class="elevate-pdp-bundle__card"
            data-bundle-card="kit"
            data-variant-id="{{ kit2_variant.id }}"
            data-product-url="{{ kit_2.url }}"
            data-price="{{ kit2_price }}"
            data-compare="{{ kit2_compare }}"
          >
            <div class="elevate-pdp-bundle__card-img">
              {%- if kit_2.featured_image != blank -%}
                {{ kit_2.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 200px, 120px', widths: '120, 200, 400' }}
              {%- endif -%}
            </div>
            <div class="elevate-pdp-bundle__card-info">
              {%- assign kit2_category = kit_2.type | default: kit_2.collections.first.title -%}
              {%- if kit2_category != blank -%}
                <p class="elevate-pdp-bundle__card-category">{{ kit2_category }}</p>
              {%- endif -%}
              <p class="elevate-pdp-bundle__card-title">{{ kit_2.title }}</p>
              {%- if kit_2.description != blank -%}
                <p class="elevate-pdp-bundle__card-desc">{{ kit_2.description | strip_html | truncatewords: 12 }}</p>
              {%- endif -%}
              <div class="elevate-pdp-bundle__card-price-row">
                <span class="elevate-pdp-bundle__card-price">{{ kit2_price | money }}</span>
                {%- if kit2_compare > kit2_price -%}
                  <span class="elevate-pdp-bundle__card-compare">{{ kit2_compare | money }}</span>
                  {%- assign kit2_save = kit2_compare | minus: kit2_price -%}
                  <span class="elevate-pdp-bundle__save-badge">Save {{ kit2_save | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

    </div>

    {%- comment -%} ── Summary bar ── {%- endcomment -%}
    <div class="elevate-pdp-bundle__summary" style="background: linear-gradient(180deg, #250a0a 0%, #6d1316 100%);">
      <div class="elevate-pdp-bundle__price-info">
        <p class="elevate-pdp-bundle__price-label">BUNDLE PRICE</p>
        <div class="elevate-pdp-bundle__price-values">
          <span class="elevate-pdp-bundle__bundle-price" data-bundle-price>
            {%- if has_bundle -%}{{ bundle_price | money }}{%- endif -%}
          </span>
          {%- if has_bundle and bundle_save > 0 -%}
            <span class="elevate-pdp-bundle__bundle-compare" data-bundle-compare>{{ bundle_compare | money }}</span>
            <span class="elevate-pdp-bundle__save-badge elevate-pdp-bundle__save-badge--summary" data-bundle-save>Save {{ bundle_save | money }}</span>
          {%- endif -%}
        </div>
        {%- if section.settings.shipping_note != blank -%}
          <p class="elevate-pdp-bundle__shipping-note">{{ section.settings.shipping_note }}</p>
        {%- endif -%}
      </div>
      <div class="elevate-pdp-bundle__ctas">
        <button
          type="button"
          class="elevate-pdp-bundle__btn elevate-pdp-bundle__btn--outline"
          data-bundle-bike-only
          data-variant-id="{{ current_variant.id }}"
        >
          {{ section.settings.bike_only_text }}
        </button>
        <button
          type="button"
          class="elevate-pdp-bundle__btn elevate-pdp-bundle__btn--primary"
          data-bundle-add-all
        >
          {{ section.settings.bundle_text }}
          <svg aria-hidden="true" focusable="false" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('.elevate-pdp-bundle[data-product-id="{{ product.id }}"]');
    if (!section) return;

    var hasBundleFromLiquid = {{ has_bundle }};
    var productId = {{ product.id }};
    var currentVariantId = {{ current_variant.id }};
    var currentVariantPrice = {{ current_price }};
    var currentVariantCompare = {{ current_compare }};

    /* ── Price formatter (matches build-a-box.js) ── */
    function formatMoney(cents) {
      var amount = (Number(cents) || 0) / 100;
      try {
        return new Intl.NumberFormat(document.documentElement.lang || 'en-US', {
          style: 'currency',
          currency: (window.Shopify && window.Shopify.currency && window.Shopify.currency.active) || 'USD'
        }).format(amount);
      } catch (_) {
        return '$' + amount.toFixed(2);
      }
    }

    /* ── Cart section IDs (for Section Rendering API) ── */
    function getCartSectionIds() {
      var ids = [];
      document.querySelectorAll('cart-items-component').forEach(function (el) {
        if (el.dataset && el.dataset.sectionId) ids.push(el.dataset.sectionId);
      });
      return ids;
    }

    /* ── Morph cart-items sections from add-to-cart response ── */
    function morphCartSections(sections) {
      if (!sections) return;
      Object.keys(sections).forEach(function (sectionId) {
        var html = sections[sectionId];
        var wrapper = document.getElementById('shopify-section-' + sectionId);
        if (wrapper && html) wrapper.innerHTML = html;
      });
    }

    /* ── Open the Horizon cart drawer ── */
    function openCartDrawer() {
      var drawer = document.querySelector('theme-drawer#cart-drawer');
      if (drawer && drawer.open) {
        drawer.open();
      }
    }

    /* ── Add a single item to cart ── */
    function postCartAdd(item, includeSections) {
      var payload = { id: item.id, quantity: item.quantity };
      if (includeSections) {
        var sectionIds = getCartSectionIds();
        if (sectionIds.length) payload.sections = sectionIds.join(',');
      }

      return fetch(Theme.routes.cart_add_url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.status && data.status !== 200) throw new Error(data.message || 'Add to cart failed');
          return data;
        });
    }

    /* ── Add one or more items to cart (atomic batch) then open drawer ── */
    function addToCart(items, btn) {
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');

      var payload = {
        items: items.map(function (item) { return { id: item.id, quantity: item.quantity }; })
      };
      var sectionIds = getCartSectionIds();
      if (sectionIds.length) payload.sections = sectionIds.join(',');

      fetch(Theme.routes.cart_add_url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (data.status && data.status !== 200) throw new Error(data.message || 'Add to cart failed');
          morphCartSections(data && data.sections);
          openCartDrawer();
        })
        .catch(function (err) {
          console.error('[elevate-pdp-bundle]', err);
        })
        .finally(function () {
          btn.disabled = false;
          btn.removeAttribute('aria-busy');
        });
    }

    /* ── "Bike only" button ── */
    var bikeOnlyBtn = section.querySelector('[data-bundle-bike-only]');
    if (bikeOnlyBtn) {
      bikeOnlyBtn.addEventListener('click', function () {
        var vId = Number(bikeOnlyBtn.getAttribute('data-variant-id'));
        addToCart([{ id: vId, quantity: 1 }], bikeOnlyBtn);
      });
    }

    /* ── "Add bundle to cart" button ── */
    var addAllBtn = section.querySelector('[data-bundle-add-all]');
    if (addAllBtn) {
      addAllBtn.addEventListener('click', function () {
        var cards = section.querySelectorAll('[data-bundle-card]');
        var items = [];
        cards.forEach(function (card) {
          var vId = Number(card.getAttribute('data-variant-id'));
          if (vId) items.push({ id: vId, quantity: 1 });
        });
        if (items.length) addToCart(items, addAllBtn);
      });
    }

    /* ── Variant change listener (Shopify Standard Events) ── */
    document.addEventListener('shopify:product:select', function (e) {
      if (!e.promise) return;
      e.promise.then(function (resolved) {
        var variant = resolved.detail && resolved.detail.resource;
        if (!variant || !variant.id) return;

        /* Update current card */
        var currentCard = section.querySelector('[data-bundle-card="current"]');
        if (currentCard) {
          currentCard.setAttribute('data-variant-id', variant.id);
          currentVariantId = variant.id;
          currentVariantPrice = variant.price;
          currentVariantCompare = variant.compare_at_price || variant.price;

          var priceEl = currentCard.querySelector('[data-current-price]');
          if (priceEl) priceEl.textContent = formatMoney(variant.price);
        }

        /* Update bike-only btn */
        if (bikeOnlyBtn) bikeOnlyBtn.setAttribute('data-variant-id', variant.id);

        /* Recalculate bundle total */
        recalcBundle();
      }).catch(function () { /* variant unavailable — ignore */ });
    });

    /* ── Recalculate bundle price ── */
    function recalcBundle() {
      var kitCards = section.querySelectorAll('[data-bundle-card="kit"]');
      if (kitCards.length === 0) return;

      var totalPrice = currentVariantPrice;
      var totalCompare = currentVariantCompare;

      kitCards.forEach(function (card) {
        totalPrice += Number(card.getAttribute('data-price')) || 0;
        totalCompare += Number(card.getAttribute('data-compare')) || 0;
      });

      var bundlePriceEl = section.querySelector('[data-bundle-price]');
      if (bundlePriceEl) bundlePriceEl.textContent = formatMoney(totalPrice);

      var bundleCompareEl = section.querySelector('[data-bundle-compare]');
      var bundleSaveEl = section.querySelector('[data-bundle-save]');
      var savings = totalCompare - totalPrice;

      if (savings > 0) {
        if (bundleCompareEl) {
          bundleCompareEl.textContent = formatMoney(totalCompare);
          bundleCompareEl.style.display = '';
        }
        if (bundleSaveEl) {
          bundleSaveEl.textContent = 'Save ' + formatMoney(savings);
          bundleSaveEl.style.display = '';
        }
      } else {
        if (bundleCompareEl) bundleCompareEl.style.display = 'none';
        if (bundleSaveEl) bundleSaveEl.style.display = 'none';
      }
    }

    /* ── Recommendations fallback (JSON API) ── */
    if (!hasBundleFromLiquid) {
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=2&intent=complementary')
        .then(function (res) { return res.json(); })
        .then(function (data) {
          var products = data && data.products;
          if (!products || products.length < 2) return;

          var cardsContainer = section.querySelector('.elevate-pdp-bundle__cards');

          products.slice(0, 2).forEach(function (p) {
            var variant = p.variants && p.variants[0];
            if (!variant) return;
            var price = variant.price ? Math.round(parseFloat(variant.price) * 100) : 0;
            var compare = variant.compare_at_price ? Math.round(parseFloat(variant.compare_at_price) * 100) : price;
            var imgSrc = p.featured_image ? p.featured_image.replace(/(\.\w+)$/, '_400x$1') : '';

            var card = document.createElement('div');
            card.className = 'elevate-pdp-bundle__card';
            card.setAttribute('data-bundle-card', 'kit');
            card.setAttribute('data-variant-id', variant.id);
            card.setAttribute('data-price', price);
            card.setAttribute('data-compare', compare);

            card.innerHTML =
              '<div class="elevate-pdp-bundle__card-img">' +
                (imgSrc ? '<img src="' + imgSrc + '" loading="lazy" alt="' + (p.title || '') + '">' : '') +
              '</div>' +
              '<div class="elevate-pdp-bundle__card-info">' +
                (p.product_type ? '<p class="elevate-pdp-bundle__card-category">' + p.product_type + '</p>' : '') +
                '<p class="elevate-pdp-bundle__card-title">' + (p.title || '') + '</p>' +
                '<div class="elevate-pdp-bundle__card-price-row">' +
                  '<span class="elevate-pdp-bundle__card-price">' + formatMoney(price) + '</span>' +
                  (compare > price ? '<span class="elevate-pdp-bundle__card-compare">' + formatMoney(compare) + '</span>' : '') +
                '</div>' +
              '</div>';

            cardsContainer.appendChild(card);
          });

          /* Calculate bundle price */
          var totalPrice = currentVariantPrice;
          var totalCompare = currentVariantCompare;
          section.querySelectorAll('[data-bundle-card="kit"]').forEach(function (c) {
            totalPrice += Number(c.getAttribute('data-price')) || 0;
            totalCompare += Number(c.getAttribute('data-compare')) || 0;
          });

          var bundlePriceEl = section.querySelector('[data-bundle-price]');
          if (bundlePriceEl) bundlePriceEl.textContent = formatMoney(totalPrice);

          var savings = totalCompare - totalPrice;
          if (savings > 0) {
            var compareEl = section.querySelector('[data-bundle-compare]');
            var saveEl = section.querySelector('[data-bundle-save]');
            if (!compareEl) {
              compareEl = document.createElement('span');
              compareEl.className = 'elevate-pdp-bundle__bundle-compare';
              compareEl.setAttribute('data-bundle-compare', '');
              var priceValues = section.querySelector('.elevate-pdp-bundle__price-values');
              if (priceValues) priceValues.appendChild(compareEl);
            }
            if (!saveEl) {
              saveEl = document.createElement('span');
              saveEl.className = 'elevate-pdp-bundle__save-badge elevate-pdp-bundle__save-badge--summary';
              saveEl.setAttribute('data-bundle-save', '');
              var priceValues2 = section.querySelector('.elevate-pdp-bundle__price-values');
              if (priceValues2) priceValues2.appendChild(saveEl);
            }
            compareEl.textContent = formatMoney(totalCompare);
            saveEl.textContent = 'Save ' + formatMoney(savings);
          }

          section.style.display = '';
        })
        .catch(function (err) {
          console.warn('[elevate-pdp-bundle] Recommendations fallback failed:', err);
        });
    }
  })();
</script>
{%- endif -%}

{% stylesheet %}
  /* ─── PDP — Complete the Kit ─── */
  .elevate-pdp-bundle {
    padding-block-start: var(--elevate-pdp-bundle-pt);
    padding-block-end: var(--elevate-pdp-bundle-pb);
    overflow: hidden;
  }

  .elevate-pdp-bundle__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  /* ── Header ── */
  .elevate-pdp-bundle__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }

  .elevate-pdp-bundle__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-pdp-bundle__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    line-height: 1.2;
    color: #36393F;
    margin: 0;
  }

  .elevate-pdp-bundle__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #36393F;
    margin: 0;
  }

  /* ── Cards ── */
  .elevate-pdp-bundle__cards {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .elevate-pdp-bundle__card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: #FDFCFC;
    border-radius: 1rem;
    padding: 1rem;
    align-items: stretch;
  }

  .elevate-pdp-bundle__card.is-current {
    border: 0.09375rem solid #E31E24;
  }

  .elevate-pdp-bundle__card-img {
    width: 10.4375rem;
    height: auto;
    aspect-ratio: 167 / 100;
    flex-shrink: 0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .elevate-pdp-bundle__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .elevate-pdp-bundle__card-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }

  .elevate-pdp-bundle__card-category {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #AEB2B8;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.0075rem;
  }

  .elevate-pdp-bundle__card-title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.2;
    color: #141517;
    margin: 0;
  }

  .elevate-pdp-bundle__card-desc {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #36393F;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .elevate-pdp-bundle__card-price-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .elevate-pdp-bundle__card-price {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.5;
    color: #141517;
    letter-spacing: -0.015rem;
  }

  .elevate-pdp-bundle__card-compare {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    line-height: 1;
    color: #AEB2B8;
    text-decoration: line-through;
  }

  .elevate-pdp-bundle__save-badge {
    display: inline-flex;
    align-items: center;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    line-height: 1;
    color: #359E5B;
    background: #EDFCF2;
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
  }

  .elevate-pdp-bundle__save-badge--summary {
    color: #141517;
    background: #4ADE80;
    border-radius: 62.4375rem;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
  }

  /* ── Summary bar ── */
  .elevate-pdp-bundle__summary {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 2rem;
    border-radius: 1.5rem 1.5rem 0 0;
    margin-inline: calc(-0.5rem - var(--page-margin));
    margin-bottom: calc(-1 * var(--elevate-pdp-bundle-pb));
  }

  .elevate-pdp-bundle__price-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .elevate-pdp-bundle__price-label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: 0.05em;
    color: #AEB2B8;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-pdp-bundle__price-values {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .elevate-pdp-bundle__bundle-price {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: #fff;
  }

  .elevate-pdp-bundle__bundle-compare {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: line-through;
  }

  .elevate-pdp-bundle__shipping-note {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #AEB2B8;
    margin: 0;
  }

  /* ── CTAs ── */
  .elevate-pdp-bundle__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .elevate-pdp-bundle__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: 'Host Grotesk', 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.03rem;
    line-height: 1;
    height: 3rem;
    padding: 0 1.5rem;
    border-radius: 0.75rem;
    width: 100%;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .elevate-pdp-bundle__btn:hover {
    opacity: 0.85;
  }

  .elevate-pdp-bundle__btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .elevate-pdp-bundle__btn--outline {
    background: transparent;
    border: 0.03125rem solid #FDFCFC;
    color: #fff;
  }

  .elevate-pdp-bundle__btn--primary {
    background: #E31E24;
    border: none;
    color: #fff;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-pdp-bundle__inner {
      padding-inline: 4.375rem;
    }

    /* Cards row */
    .elevate-pdp-bundle__cards {
      flex-direction: row;
    }

    .elevate-pdp-bundle__card {
      flex: 1;
      padding: 1.25rem;
      min-height: 18.125rem;
    }

    .elevate-pdp-bundle__card-title {
      font-size: 1.25rem;
    }

    /* Summary bar — horizontal */
    .elevate-pdp-bundle__summary {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 2rem;
      border-radius: 1.5rem;
      margin-inline: 0;
      margin-bottom: 0;
    }

    .elevate-pdp-bundle__ctas {
      flex-direction: row;
      flex-shrink: 0;
    }

    .elevate-pdp-bundle__btn {
      width: auto;
    }
  }
{% endstylesheet %}

