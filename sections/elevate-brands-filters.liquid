{%- doc -%}
  Elevate Cycling — Brands filter pills.
  Horizontal row of category pills that filter the brand grid below.
  "All" is always present; extra categories come from blocks.
  Filters brands by fetching vendors from mapped collections.
{%- enddoc -%}

<div
  class="section section--page-width page-width-normal elevate-brands-filters"
  data-brands-filters
  style="background: #FDFCFC;"
>
  <div class="elevate-brands-filters__inner">
    <button
      type="button"
      class="elevate-brands-filters__pill is-active"
      data-filter="all"
      aria-pressed="true"
    >
      All
    </button>

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        {%- assign label = block.settings.label | strip -%}
        {%- assign handles = block.settings.collections | strip -%}
        {%- if label != blank and handles != blank -%}
          <button
            type="button"
            class="elevate-brands-filters__pill"
            data-filter="{{ handles | escape }}"
            aria-pressed="false"
            {{ block.shopify_attributes }}
          >
            {{ label }}
          </button>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script type="module">
  (function () {
    var wrap = document.querySelector('[data-brands-filters]');
    if (!wrap) return;

    var pills = wrap.querySelectorAll('[data-filter]');
    var brandsSection = document.querySelector('[data-brands-page]');
    if (!pills.length || !brandsSection) return;

    /* Cache: filter key → Set of lowercase vendor names */
    var vendorCache = {};

    function setActive(btn) {
      pills.forEach(function (p) {
        p.classList.remove('is-active');
        p.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');
    }

    function showAll() {
      var cards = brandsSection.querySelectorAll('.elevate-brands__card');
      cards.forEach(function (c) { c.style.display = ''; });
      var groups = brandsSection.querySelectorAll('.elevate-brands__group');
      groups.forEach(function (g) { g.style.display = ''; });
      var letters = brandsSection.querySelectorAll('.elevate-brands__letter');
      letters.forEach(function (l) { l.style.display = ''; });
    }

    function filterByVendors(vendorSet) {
      var groups = brandsSection.querySelectorAll('.elevate-brands__group');

      groups.forEach(function (group) {
        var cards = group.querySelectorAll('.elevate-brands__card');
        var anyVisible = false;

        cards.forEach(function (card) {
          var vendor = (card.getAttribute('data-vendor') || '').toLowerCase();
          if (vendorSet.has(vendor)) {
            card.style.display = '';
            anyVisible = true;
          } else {
            card.style.display = 'none';
          }
        });

        /* Hide entire letter group if no cards match */
        group.style.display = anyVisible ? '' : 'none';
      });
    }

    /**
     * Fetch all products from a single collection, paginating to collect every vendor.
     * Returns a Promise that resolves with an array of lowercase vendor strings.
     */
    function fetchCollectionVendors(handle) {
      var vendors = [];
      var page = 1;
      var maxPages = 10;

      function fetchPage(resolve) {
        fetch('/collections/' + encodeURIComponent(handle) + '/products.json?limit=250&page=' + page)
          .then(function (r) { return r.json(); })
          .then(function (data) {
            var products = (data && data.products) || [];
            products.forEach(function (p) {
              if (p.vendor) vendors.push(p.vendor.toLowerCase());
            });

            if (products.length === 250 && page < maxPages) {
              page++;
              fetchPage(resolve);
            } else {
              resolve(vendors);
            }
          })
          .catch(function () {
            resolve(vendors);
          });
      }

      return new Promise(function (resolve) {
        fetchPage(resolve);
      });
    }

    /**
     * Fetch vendors from all collections mapped to a filter key.
     * Merges results into a single Set and caches it.
     */
    function fetchVendorsForCollections(filterKey, callback) {
      if (vendorCache[filterKey]) {
        callback(vendorCache[filterKey]);
        return;
      }

      var handles = filterKey.split(',').map(function (h) { return h.trim(); }).filter(Boolean);
      if (!handles.length) {
        callback(new Set());
        return;
      }

      Promise.all(handles.map(fetchCollectionVendors))
        .then(function (results) {
          var merged = new Set();
          results.forEach(function (arr) {
            arr.forEach(function (v) { merged.add(v); });
          });
          vendorCache[filterKey] = merged;
          callback(merged);
        })
        .catch(function () {
          vendorCache[filterKey] = new Set();
          callback(vendorCache[filterKey]);
        });
    }

    pills.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.getAttribute('data-filter');
        setActive(btn);

        if (filter === 'all') {
          showAll();
          return;
        }

        fetchVendorsForCollections(filter, function (vendorSet) {
          filterByVendors(vendorSet);
        });
      });
    });
  })();
</script>

{% stylesheet %}
  /* ─── Brands Filter Pills ─── */
  .elevate-brands-filters {
    border-bottom: 0.0625rem solid #AEB2B8;
    overflow: hidden;
  }

  .elevate-brands-filters__inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-block: 1rem;
    padding-left: 0.5rem;
    padding-right: calc(0.5rem + var(--page-margin, 12px));
    margin-right: calc(-0.5rem - var(--page-margin, 12px));
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .elevate-brands-filters__inner::-webkit-scrollbar {
    display: none;
  }

  .elevate-brands-filters__pill {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: #FDFCFC;
    border: 0.0625rem solid #E2E3E5;
    border-radius: 0.5rem;
    font-family: var(--font-body--family), 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #36393F;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .elevate-brands-filters__pill:hover {
    border-color: #E31E24;
    color: #141517;
  }

  .elevate-brands-filters__pill.is-active {
    background: #F1DBDC;
    border-width: 0.125rem;
    border-color: #E31E24;
    color: #141517;
  }

  /* ─── Desktop ─── */
  @media (min-width: 61.9375rem) {
    .elevate-brands-filters__inner {
      justify-content: center;
      gap: 1rem;
      padding-block: 1.5rem;
      padding-inline: 4.375rem;
      margin-right: 0;
    }

    .elevate-brands-filters__pill {
      font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
      font-size: 1.25rem;
      line-height: 1.2;
      letter-spacing: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brands Filters",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Text shown on the pill button."
        },
        {
          "type": "text",
          "id": "collections",
          "label": "Collection handles",
          "info": "Comma-separated Shopify collection handles to pull vendors from."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Filters",
      "blocks": [
        { "type": "category", "settings": { "label": "Bikes", "collections": "complete-bikes,road-bikes,triathalon-tt-bikes,framesets" } },
        { "type": "category", "settings": { "label": "Components", "collections": "cockpit-components,gruppo-components,groupsets,cranksets,derailleurs,handlebars,stems,seatposts,saddles,pedals" } },
        { "type": "category", "settings": { "label": "Wheels", "collections": "wheels,tires-tubes" } },
        { "type": "category", "settings": { "label": "Accessories", "collections": "accessories,bottle-cages,computer-mounts" } }
      ]
    }
  ]
}
{% endschema %}
