{%- doc -%}
  Elevate Cycling — B2B Brand Safety section.
  Two-column layout: heading + quote left, 2×2 commitment cards right.
{%- enddoc -%}

{%- liquid
  assign full = section.settings.heading
  assign accent = section.settings.heading_accent
  if accent != blank and full contains accent
    assign parts = full | split: accent
    assign before = parts[0]
  endif
-%}

<div
  class="section section--page-width page-width-normal elevate-b2b-brand-safety"
  data-scroll-reveal="children"
  style="
    background: #FDFCFC;
    --b2b-safety-pad-top: {{ section.settings.padding_top | divided_by: 16.0 }}rem;
    --b2b-safety-pad-bottom: {{ section.settings.padding_bottom | divided_by: 16.0 }}rem;
    {%- if section.settings.mobile_padding_custom -%}
      --b2b-safety-pad-top-m: {{ section.settings.padding_top_mobile | divided_by: 16.0 }}rem;
      --b2b-safety-pad-bottom-m: {{ section.settings.padding_bottom_mobile | divided_by: 16.0 }}rem;
    {%- endif -%}
  "
>
  <hr class="elevate-b2b-brand-safety__divider" aria-hidden="true">
  <div class="elevate-b2b-brand-safety__inner">
    {%- if full != blank -%}
      <div class="elevate-b2b-brand-safety__left">
        <h2 class="elevate-b2b-brand-safety__heading">
          {%- if accent != blank and full contains accent -%}
            {{ before }}<span class="elevate-b2b-brand-safety__heading-accent">{{ accent }}</span>
          {%- else -%}
            {{ full }}
          {%- endif -%}
        </h2>

        {%- if section.settings.quote_title != blank or section.settings.quote_body != blank -%}
          <div class="elevate-b2b-brand-safety__quote">
            {%- if section.settings.quote_title != blank -%}
              <p class="elevate-b2b-brand-safety__quote-title">{{ section.settings.quote_title }}</p>
            {%- endif -%}
            {%- if section.settings.quote_body != blank -%}
              <p class="elevate-b2b-brand-safety__quote-body">{{ section.settings.quote_body }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="elevate-b2b-brand-safety__cards">
        {%- for block in section.blocks -%}
          <div class="elevate-b2b-brand-safety__card" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <div class="elevate-b2b-brand-safety__card-header">
                <svg class="elevate-b2b-brand-safety__card-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 2.25C6.60059 2.25 2.25 6.60059 2.25 12C2.25 17.3994 6.60059 21.75 12 21.75C17.3994 21.75 21.75 17.3994 21.75 12C21.75 10.9512 21.6094 9.90527 21.2344 8.92969L20.0156 10.125C20.165 10.7256 20.25 11.3262 20.25 12C20.25 16.5762 16.5762 20.25 12 20.25C7.42383 20.25 3.75 16.5762 3.75 12C3.75 7.42383 7.42383 3.75 12 3.75C14.25 3.75 16.2715 4.64648 17.6953 6.07031L18.75 5.01562C17.0244 3.29004 14.625 2.25 12 2.25ZM20.4609 5.46094L12 13.9219L8.78906 10.7109L7.71094 11.7891L11.4609 15.5391L12 16.0547L12.5391 15.5391L21.5391 6.53906L20.4609 5.46094Z" fill="#E31E24"/>
                </svg>
                <p class="elevate-b2b-brand-safety__card-title">{{ block.settings.title }}</p>
              </div>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="elevate-b2b-brand-safety__card-body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .elevate-b2b-brand-safety__inner {
    padding-block: var(--b2b-safety-pad-top-m, var(--b2b-safety-pad-top)) var(--b2b-safety-pad-bottom-m, var(--b2b-safety-pad-bottom));
    padding-inline: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ---- Left column: heading + quote ---- */
  .elevate-b2b-brand-safety__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #36393F;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
  }

  .elevate-b2b-brand-safety__heading-accent {
    color: #E31E24;
  }

  .elevate-b2b-brand-safety__quote {
    border: 0.125rem solid #AEB2B8;
    border-radius: 1.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-b2b-brand-safety__quote-title {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.2;
    color: #36393F;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-brand-safety__quote-body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #36393F;
    margin: 0;
  }

  /* ---- Divider ---- */
  .elevate-b2b-brand-safety__divider {
    border: none;
    height: 0.0625rem;
    background: var(--Neutrals-Dark-200, #AEB2B8);
    max-width: 63rem;
    margin: 0 auto;
  }

  /* ---- Right column: cards ---- */
  .elevate-b2b-brand-safety__cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .elevate-b2b-brand-safety__card {
    background: rgba(226, 227, 229, 0.4);
    border-radius: 1.5rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .elevate-b2b-brand-safety__card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .elevate-b2b-brand-safety__card-icon {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
  }

  .elevate-b2b-brand-safety__card-title {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1.0625rem;
    line-height: 1.5;
    letter-spacing: -0.0125rem;
    color: #36393F;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-b2b-brand-safety__card-body {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #36393F;
    margin: 0;
  }

  /* ---- Desktop: two-column layout ---- */
  @media (min-width: 61.9375rem) {
    .elevate-b2b-brand-safety__inner {
      padding-block: var(--b2b-safety-pad-top) var(--b2b-safety-pad-bottom);
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding-inline: 4.375rem;
      gap: 0;
    }


    .elevate-b2b-brand-safety__left {
      width: 17.3125rem;
      flex-shrink: 0;
    }

    .elevate-b2b-brand-safety__heading {
      font-size: 3.5625rem;
      margin-bottom: 2rem;
    }

    .elevate-b2b-brand-safety__cards {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 2rem;
      width: 42.9375rem;
    }

    .elevate-b2b-brand-safety__card {
      width: 20.4375rem;
    }

    .elevate-b2b-brand-safety__card-title {
      font-size: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "B2B Brand Safety",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOUR BRAND, PROTECTED BY CONTRACT."
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (red portion)",
      "default": "PROTECTED BY CONTRACT."
    },
    {
      "type": "text",
      "id": "quote_title",
      "label": "Quote title",
      "default": "OUR DEFAULT POSITION"
    },
    {
      "type": "textarea",
      "id": "quote_body",
      "label": "Quote body",
      "default": "We list under our certified pre-owned program. Never as new. Never below your floor. Never to dealers."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "mobile_padding_custom",
      "label": "Custom mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40,
      "visible_if": "{{ section.settings.mobile_padding_custom }}"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Card body text."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2B Brand Safety",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "PRICE FLOOR ENFORCEMENT",
            "body": "Minimum advertised price set by you, enforced across every channel we list on. Violations void the agreement."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "CHANNEL RESTRICTIONS",
            "body": "Carve out marketplaces, geographies, or dealer territories you want off-limits. We list only where you allow."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "CERTIFIED PRE-OWNED FRAMING",
            "body": "Listings carry the Elevate CPO badge — clearly differentiated from new product, never positioned against your current line."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "SERIAL & WARRANTY HANDLING",
            "body": "Serials de-listed from your warranty program on purchase if requested. Full chain-of-custody documentation provided."
          }
        }
      ]
    }
  ]
}
{% endschema %}
