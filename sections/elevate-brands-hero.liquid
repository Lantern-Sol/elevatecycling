{%- doc -%}
  Elevate Cycling — Brands hero section.
  Full-bleed background with solid dark overlay,
  center-aligned content: badge pill, heading with accent-color word,
  subtitle, and a dynamic count badge showing brand/item totals.
{%- enddoc -%}

{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign heading_html = section.settings.heading
  if section.settings.heading_accent != blank
    assign accent_open = '<span class="elevate-brands-hero__accent">'
    assign accent_close = '</span>'
    assign accent_wrap = accent_open | append: section.settings.heading_accent | append: accent_close
    assign heading_html = heading_html | replace: section.settings.heading_accent, accent_wrap
  endif

  assign brand_count = shop.vendors | size
  assign item_count = collections.all.products_count | default: 0
-%}

<div
  class="section section--page-width page-width-normal elevate-brands-hero"
  style="
    background: #0a0a0a;
    --elevate-brands-hero-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-brands-hero-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
    --elevate-brands-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- comment -%} ── Background media ── {%- endcomment -%}
  <div class="elevate-brands-hero__media">
    {%- if has_image -%}
      {%- assign img = section.settings.image -%}
      {{
        img
        | image_url: width: 3840
        | image_tag:
          widths: '375, 750, 1080, 1440, 1920, 2560, 3840',
          sizes: '100vw',
          fetchpriority: 'high',
          loading: 'eager',
          class: 'elevate-brands-hero__image',
          alt: ''
      }}
    {%- else -%}
      <div class="elevate-brands-hero__placeholder"></div>
    {%- endif -%}

    <div class="elevate-brands-hero__overlay"></div>
  </div>

  <div class="elevate-brands-hero__inner">
    {%- if section.settings.badge_text != blank -%}
      <span class="elevate-brands-hero__badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="elevate-brands-hero__heading">{{ heading_html }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="elevate-brands-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.show_count_badge -%}
      <div class="elevate-brands-hero__count-badge">
        <span>{{ brand_count }} brands · {{ item_count }} items in stock</span>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ─── Brands Hero ─── */
  .elevate-brands-hero {
    position: relative;
    overflow: hidden;
    padding-block-start: var(--elevate-brands-hero-pt);
    padding-block-end: var(--elevate-brands-hero-pb);
  }

  .elevate-brands-hero__inner {
    grid-column: 2;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 16rem;
    padding-inline: 0.5rem;
    gap: 1rem;
  }

  /* ── Media layer ── */
  .elevate-brands-hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--layer-lowest);
    grid-column: 1 / -1;
  }

  .elevate-brands-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .elevate-brands-hero__placeholder {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
  }

  .elevate-brands-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--elevate-brands-hero-overlay-opacity, 0.95));
    pointer-events: none;
  }

  /* ── Badge ── */
  .elevate-brands-hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3125rem 0.75rem;
    background: #E31E24;
    border-radius: 62.4375rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.5;
    letter-spacing: -0.00875rem;
    color: #FDFCFC;
    text-transform: uppercase;
  }

  /* ── Heading ── */
  .elevate-brands-hero__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1.1;
    color: #FDFCFC;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-brands-hero__accent {
    color: #E31E24;
  }

  /* ── Subtitle ── */
  .elevate-brands-hero__subtitle {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01rem;
    color: #E2E3E5;
    margin: 0;
    max-width: 35.75rem;
  }

  /* ── Count badge ── */
  .elevate-brands-hero__count-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: rgba(226, 227, 229, 0.4);
    border-radius: 2rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #FDFCFC;
    backdrop-filter: blur(0.5rem);
    -webkit-backdrop-filter: blur(0.5rem);
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-brands-hero__inner {
      min-height: 20rem;
      padding-inline: 4.375rem;
    }

    .elevate-brands-hero__heading {
      font-size: 4rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brands Hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 95
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "SHOP BY BRAND"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND YOUR BRAND"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent text",
      "info": "Word(s) within the heading to highlight in red.",
      "default": "BRAND"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every brand links to our current inventory — certified pre-owned and brand-new, only what's actually in stock."
    },
    {
      "type": "checkbox",
      "id": "show_count_badge",
      "label": "Show count badge",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Brands Hero"
    }
  ]
}
{% endschema %}
