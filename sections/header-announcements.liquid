{%- comment -%}
  Elevate Cycling — USP announcement bar.
  Desktop: all items in a row.
  Mobile: horizontal CSS marquee (items cloned via JS for seamless loop).
{%- endcomment -%}

{%- liquid
  assign bg = section.settings.background_color | default: '#E31E24'
  assign fg = section.settings.text_color | default: '#FDFCFC'
-%}

{% render 'contrast-override', background_color: bg, text_color: fg, section_id: section.id %}

<div class="section-background color-custom-{{ section.id }}"></div>
<aside
  class="usps-bar spacing-style section section--full-width color-custom-{{ section.id }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --usps-speed: {{ section.settings.marquee_speed }}s;
  "
  aria-label="Store highlights"
>
  <div class="usps-bar__track">
    {% content_for 'blocks' %}
  </div>
</aside>

<script>
  (function () {
    var track = document.querySelector(
      '#shopify-section-{{ section.id }} .usps-bar__track'
    );
    if (!track) return;

    var items = track.querySelectorAll('.usps-bar__item');
    if (!items.length) return;

    items.forEach(function (item) {
      var clone = item.cloneNode(true);
      clone.classList.add('usps-bar__item--clone');
      clone.setAttribute('aria-hidden', 'true');
      clone.removeAttribute('data-shopify-editor-block');
      track.appendChild(clone);
    });
  })();
</script>

{% stylesheet %}
  .usps-bar {
    overflow: hidden;
    position: relative;
  }

  /* ── Track — mobile marquee ── */
  .usps-bar__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    width: max-content;
    animation: usps-marquee var(--usps-speed, 20s) linear infinite;
  }

  @keyframes usps-marquee {
    to {
      translate: -50% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .usps-bar__track {
      animation: none;
      width: 100%;
      overflow-x: auto;
    }
  }

  /* ── Individual item ── */
  .usps-bar__item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .usps-bar__icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .usps-bar__text {
    font-family: var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .usps-bar__text p {
    margin: 0;
  }

  /* ── Desktop — static row ── */
  @media screen and (min-width: 61.9375rem) {
    .usps-bar__track {
      animation: none;
      width: 100%;
      justify-content: space-between;
      padding-inline: 4.5rem;
    }

    .usps-bar__item--clone {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#E31E24"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FDFCFC"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Mobile scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "use_mobile_padding",
      "label": "Use mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
