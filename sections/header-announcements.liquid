{%- comment -%}
  Elevate Cycling — USP announcement bar.
  Desktop: all items in a static row.
  Mobile: single-item rotator with left/right arrows + auto-rotate.
{%- endcomment -%}

{%- liquid
  assign bg = section.settings.background_color | default: '#E31E24'
  assign fg = section.settings.text_color | default: '#FDFCFC'
-%}

{% render 'contrast-override', background_color: bg, text_color: fg, section_id: section.id %}

<div class="section-background color-custom-{{ section.id }}"></div>
<aside
  class="usps-bar spacing-style section section--full-width color-custom-{{ section.id }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --usps-rotate-speed: {{ section.settings.rotate_speed }}s;
    display: flex;
    align-items: center;
    background-color: {{ bg }};
    color: {{ fg }};
  "
  aria-label="Store highlights"
>
  {%- comment -%} Mobile arrows + single item rotator {%- endcomment -%}
  <button
    class="usps-bar__arrow usps-bar__arrow--prev"
    type="button"
    aria-label="Previous highlight"
  >
    <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M9.96094 5.08594L3.58594 11.4609L3.07031 12L3.58594 12.5391L9.96094 18.9141L11.0391 17.8359L5.95312 12.75H21V11.25H5.95312L11.0391 6.16406L9.96094 5.08594Z" fill="currentColor"/>
    </svg>
  </button>

  <div class="usps-bar__track">
    {% content_for 'blocks' %}
  </div>

  <button
    class="usps-bar__arrow usps-bar__arrow--next"
    type="button"
    aria-label="Next highlight"
  >
    <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M14.0391 5.08594L12.9609 6.16406L18.0469 11.25H3V12.75H18.0469L12.9609 17.8359L14.0391 18.9141L20.4141 12.5391L20.9297 12L20.4141 11.4609L14.0391 5.08594Z" fill="currentColor"/>
    </svg>
  </button>
</aside>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    var track = section.querySelector('.usps-bar__track');
    var items = track.querySelectorAll('.usps-bar__item');
    if (items.length < 2) return;

    var current = 0;
    var total = items.length;
    var interval = null;
    var speed = {{ section.settings.rotate_speed | default: 4 }} * 1000;

    function show(index) {
      items.forEach(function (item, i) {
        item.classList.toggle('usps-bar__item--active', i === index);
      });
      current = index;
    }

    function next() {
      show((current + 1) % total);
    }

    function prev() {
      show((current - 1 + total) % total);
    }

    function startAuto() {
      stopAuto();
      interval = setInterval(next, speed);
    }

    function stopAuto() {
      if (interval) clearInterval(interval);
    }

    /* Init: show first item */
    show(0);

    /* Arrow clicks */
    var prevBtn = section.querySelector('.usps-bar__arrow--prev');
    var nextBtn = section.querySelector('.usps-bar__arrow--next');

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        prev();
        startAuto();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        next();
        startAuto();
      });
    }

    /* Auto-rotate only on mobile */
    var mql = window.matchMedia('(max-width: 61.875rem)');

    function handleMQ(e) {
      if (e.matches) {
        startAuto();
      } else {
        stopAuto();
      }
    }

    mql.addEventListener('change', handleMQ);
    handleMQ(mql);
  })();
</script>

{% stylesheet %}
  .usps-bar {
    overflow: hidden;
    position: relative;
    padding-inline: 1rem;
  }

  /* ── Mobile: single-item rotator with arrows ── */
  .usps-bar__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0;
    border: none;
    background: none;
    color: inherit;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .usps-bar__arrow svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .usps-bar__track {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-width: 0;
  }

  /* ── Individual item ── */
  .usps-bar__item {
    display: none;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .usps-bar__item--active {
    display: flex;
  }

  .usps-bar__icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }

  .usps-bar__text {
    font-family: var(--font-body--family), sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .usps-bar__text p {
    margin: 0;
  }

  /* ── Desktop — static row, no arrows ── */
  @media screen and (min-width: 61.9375rem) {
    .usps-bar__arrow {
      display: none;
    }

    .usps-bar__track {
      justify-content: space-between;
      padding-inline: 4.5rem;
    }

    .usps-bar__item {
      display: flex;
      flex-shrink: 0;
    }

    .usps-bar__text {
      font-size: 0.875rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#E31E24"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FDFCFC"
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "label": "Auto-rotate interval (mobile)",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "use_mobile_padding",
      "label": "Use mobile padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.use_mobile_padding }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
