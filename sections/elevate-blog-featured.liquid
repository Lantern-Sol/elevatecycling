{%- doc -%}
  Elevate Cycling — Blog featured article section.
  Full-width horizontal card with article image on the left and
  content on the right, over a dark-to-red gradient background.
  Merchant selects which article to feature via article picker.
{%- enddoc -%}

{%- liquid
  assign article = section.settings.article
  assign has_article = false
  if article != blank
    assign has_article = true
  endif

  assign badge_text = ''
  if has_article
    assign badge_text = article.metafields.custom.article_badge.value
  endif

  assign featured_image = section.settings.image | default: article.image

  assign word_count = article.content | strip_html | split: ' ' | size
  assign read_time = word_count | divided_by: 200
  if read_time < 1
    assign read_time = 1
  endif

  assign pt = section.settings.padding_top | times: 0.0625
  assign pb = section.settings.padding_bottom | times: 0.0625
-%}

{%- if has_article -%}
  <div
    class="section section--page-width page-width-normal elevate-blog-featured"
    data-scroll-reveal
    style="
      background: linear-gradient(180deg, #f1dbdc 0%, #fdfcfc 100%);
      padding-block-start: {{ pt }}rem;
      padding-block-end: {{ pb }}rem;
    "
  >
    <div class="elevate-blog-featured__inner">
      <a href="{{ article.url }}" class="elevate-blog-featured__card" aria-label="{{ article.title }}">
        {%- comment -%} ── Image half ── {%- endcomment -%}
        <div class="elevate-blog-featured__image-wrap">
          {%- if featured_image -%}
            {{
              featured_image
              | image_url: width: 1200
              | image_tag:
                widths: '375, 600, 800, 1000, 1200',
                sizes: '(min-width: 990px) 600px, 100vw',
                loading: 'lazy',
                class: 'elevate-blog-featured__image',
                alt: article.title
            }}
          {%- else -%}
            <div class="elevate-blog-featured__image-placeholder"></div>
          {%- endif -%}

          {%- if badge_text != blank -%}
            <span class="elevate-blog-featured__tag">{{ badge_text }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} ── Content half ── {%- endcomment -%}
        <div class="elevate-blog-featured__content">
          <span class="elevate-blog-featured__badge-featured">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="14" viewBox="0 0 15 14" fill="none" aria-hidden="true">
              <path d="M14.3359 5.20703L9.25 4.66992L7.16797 0L5.08594 4.66992L0 5.20703L3.79883 8.63086L2.73828 13.6328L7.16797 11.0781L11.5977 13.6328L10.5371 8.63086L14.3359 5.20703Z" fill="#141517"/>
            </svg>
            {{ section.settings.featured_badge_text }}
          </span>

          <h2 class="elevate-blog-featured__title">{{ article.title }}</h2>

          {%- if article.excerpt_or_content != blank -%}
            <p class="elevate-blog-featured__excerpt">
              {{ article.excerpt_or_content | strip_html | truncate: 160 }}
            </p>
          {%- endif -%}

          <hr class="elevate-blog-featured__divider">

          <div class="elevate-blog-featured__meta">
            <div class="elevate-blog-featured__meta-left">
              {%- if article.metafields.custom.author_avatar.value != blank -%}
                <img
                  class="elevate-blog-featured__avatar-img"
                  src="{{ article.metafields.custom.author_avatar.value | image_url: width: 48 }}"
                  alt="{{ article.author }}"
                  width="24"
                  height="24"
                  loading="lazy"
                >
              {%- else -%}
                <div class="elevate-blog-featured__avatar">
                  {{ article.author | slice: 0 | upcase }}
                </div>
              {%- endif -%}
              <div class="elevate-blog-featured__meta-text">
                <span class="elevate-blog-featured__author">{{ article.author }}</span>
                <span class="elevate-blog-featured__date">
                  {{ article.published_at | date: '%b %d, %Y' }}
                </span>
              </div>
            </div>
            <span class="elevate-blog-featured__read-time">{{ read_time }} min read</span>
          </div>

          <span class="elevate-blog-featured__cta">
            {{ section.settings.cta_text }}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  /* ─── Blog Featured Article ─── */
  .elevate-blog-featured__inner {
    grid-column: 2;
    display: flex;
    justify-content: center;
    padding-inline: 0.5rem;
  }

  .elevate-blog-featured__card {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 75rem;
    border-radius: 1rem;
    overflow: hidden;
    background: linear-gradient(180deg, #250a0a 0%, #6d1316 100%);
    box-shadow:
      0 0.125rem 0.25rem -0.125rem rgba(0, 0, 0, 0.1),
      0 0.25rem 0.375rem -0.0625rem rgba(0, 0, 0, 0.1);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.25s ease;
  }

  .elevate-blog-featured__card:hover {
    box-shadow:
      0 0.25rem 0.5rem -0.125rem rgba(0, 0, 0, 0.14),
      0 0.5rem 0.75rem -0.0625rem rgba(0, 0, 0, 0.14);
  }

  /* ── Image half ── */
  .elevate-blog-featured__image-wrap {
    position: relative;
    width: 100%;
    height: 14.25rem;
    overflow: hidden;
  }

  .elevate-blog-featured__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .elevate-blog-featured__image-placeholder {
    width: 100%;
    height: 100%;
    background: #3a1012;
    border-radius: 0.5rem;
  }

  .elevate-blog-featured__tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    background: #E31E24;
    border-radius: 0.125rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #FDFCFC;
    text-transform: capitalize;
    letter-spacing: -0.0075rem;
  }

  /* ── Content half ── */
  .elevate-blog-featured__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
  }

  .elevate-blog-featured__badge-featured {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    background: #F9D44E;
    border-radius: 0.25rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #141517;
    text-transform: capitalize;
  }

  .elevate-blog-featured__title {
    font-family: 'Inter', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: -0.0125rem;
    color: #FDFCFC;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .elevate-blog-featured__excerpt {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: -0.0075rem;
    color: #AEB2B8;
    margin: 0;
  }

  .elevate-blog-featured__divider {
    border: none;
    border-top: 0.5px solid #AEB2B8;
    margin: 0;
    opacity: 0.4;
  }

  /* ── Meta row ── */
  .elevate-blog-featured__meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    padding-inline: 0.5rem;
  }

  .elevate-blog-featured__meta-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .elevate-blog-featured__avatar-img {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .elevate-blog-featured__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: #AEB2B8;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 0.625rem;
    color: #141517;
    flex-shrink: 0;
  }

  .elevate-blog-featured__meta-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .elevate-blog-featured__author {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.625rem;
    line-height: 1.5;
    letter-spacing: -0.00625rem;
    color: #AEB2B8;
  }

  .elevate-blog-featured__date {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.625rem;
    line-height: 1.5;
    letter-spacing: -0.00625rem;
    color: #AEB2B8;
  }

  .elevate-blog-featured__read-time {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #AEB2B8;
    white-space: nowrap;
  }

  /* ── CTA ── */
  .elevate-blog-featured__cta {
    display: inline-flex;
    align-items: center;
    align-self: end;
    gap: 0.5rem;
    padding-inline: 0.5rem;
    font-family: 'Host Grotesk', var(--font-body--family), sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: 0.03rem;
    color: #FDFCFC;
    text-decoration: none;
    border-bottom: 0.5px solid #FDFCFC;
    padding-block: 0.5rem;
  }

  .elevate-blog-featured__card:hover .elevate-blog-featured__cta {
    border-bottom-width: 1.5px;
  }

  /* ─── Desktop (990px+) ─── */
  @media (min-width: 61.9375rem) {
    .elevate-blog-featured__inner {
      padding-inline: 4.375rem;
    }

    .elevate-blog-featured__card {
      flex-direction: row;
      max-height: 25rem;
    }

    .elevate-blog-featured__image-wrap {
      flex: 0 0 50%;
      height: auto;
    }

    .elevate-blog-featured__content {
      flex: 1;
      padding: 2rem;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Blog Featured",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "article",
      "id": "article",
      "label": "Featured article"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image override",
      "info": "Replaces the article's featured image"
    },
    {
      "type": "text",
      "id": "featured_badge_text",
      "label": "Featured badge text",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Read Article"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Blog Featured"
    }
  ]
}
{% endschema %}
