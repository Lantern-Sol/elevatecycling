{%- doc -%}
  Elevate Cycling — PDP Geometry section.
  Inline SVG bike diagram (switchable by bike_type), stat highlight cards,
  and a collapsible full geometry table.
  Metafield: custom.geometry (multi_line_text_field)
  Format: Label: Value | Unit (one per line)
{%- enddoc -%}

{%- liquid
  assign geo_raw = product.metafields.custom.geometry.value
  if geo_raw == blank
    assign geo_raw = product.metafields.custom.geometry
  endif
-%}

{%- unless geo_raw == blank -%}
{%- capture newline %}
{% endcapture -%}
{%- liquid
  assign geo_lines = geo_raw | split: newline
  assign bike_type = section.settings.bike_type
-%}

<div
  class="section section--page-width page-width-normal elevate-geometry"
  data-scroll-reveal
  style="
    background: #141517;
    border-radius: 1.5rem;
    --elevate-geometry-pt: {{ section.settings.padding_top | times: 0.0625 }}rem;
    --elevate-geometry-pb: {{ section.settings.padding_bottom | times: 0.0625 }}rem;
  "
>
  <div class="elevate-geometry__inner">

    <div class="elevate-geometry__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="elevate-geometry__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="elevate-geometry__heading">{{ section.settings.heading }}</h2>
    </div>

    {%- comment -%} ── SVG Diagram ── {%- endcomment -%}
    <div class="elevate-geometry__diagram" aria-hidden="true">
      {%- case bike_type -%}
        {%- when 'gravel' -%}
          <svg viewBox="0 0 600 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="elevate-geometry__svg">
            {%- comment -%} Gravel bike silhouette — wider tire clearance, relaxed geo {%- endcomment -%}
            <circle cx="130" cy="230" r="70" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="470" cy="230" r="70" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="130" cy="230" r="3" fill="#E31E24"/>
            <circle cx="470" cy="230" r="3" fill="#E31E24"/>
            {%- comment -%} Frame triangle {%- endcomment -%}
            <path d="M130 230 L270 95 L370 95 L470 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none"/>
            <path d="M270 95 L295 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M370 95 L350 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            {%- comment -%} Seat tube {%- endcomment -%}
            <path d="M295 230 L280 70" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            {%- comment -%} Handlebars {%- endcomment -%}
            <path d="M130 230 L155 115 L140 95" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
            {%- comment -%} Key dimension lines {%- endcomment -%}
            <line x1="270" y1="95" x2="370" y2="95" stroke="#E31E24" stroke-width="1" stroke-dasharray="4 3" opacity="0.6"/>
            <text x="320" y="88" fill="#E31E24" font-size="10" text-anchor="middle" font-family="Inter, sans-serif">TOP TUBE</text>
            <line x1="370" y1="95" x2="370" y2="230" stroke="#4ade80" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
            <text x="385" y="165" fill="#4ade80" font-size="10" font-family="Inter, sans-serif" opacity="0.7">STACK</text>
          </svg>

        {%- when 'mtb' -%}
          <svg viewBox="0 0 600 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="elevate-geometry__svg">
            {%- comment -%} MTB silhouette — slack head angle, longer travel {%- endcomment -%}
            <circle cx="120" cy="230" r="75" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="480" cy="230" r="75" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="120" cy="230" r="3" fill="#E31E24"/>
            <circle cx="480" cy="230" r="3" fill="#E31E24"/>
            {%- comment -%} Frame — slack head angle {%- endcomment -%}
            <path d="M120 230 L255 110 L365 110 L480 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none"/>
            <path d="M255 110 L285 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M365 110 L345 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M285 230 L270 75" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            {%- comment -%} Front fork (more travel) {%- endcomment -%}
            <path d="M120 230 L170 110" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
            {%- comment -%} Dimension lines {%- endcomment -%}
            <line x1="255" y1="110" x2="365" y2="110" stroke="#E31E24" stroke-width="1" stroke-dasharray="4 3" opacity="0.6"/>
            <text x="310" y="103" fill="#E31E24" font-size="10" text-anchor="middle" font-family="Inter, sans-serif">TOP TUBE</text>
            <line x1="365" y1="110" x2="365" y2="230" stroke="#4ade80" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
            <text x="380" y="175" fill="#4ade80" font-size="10" font-family="Inter, sans-serif" opacity="0.7">STACK</text>
          </svg>

        {%- else -%}
          {%- comment -%} Road bike (default) {%- endcomment -%}
          <svg viewBox="0 0 600 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="elevate-geometry__svg">
            <circle cx="140" cy="230" r="65" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="460" cy="230" r="65" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
            <circle cx="140" cy="230" r="3" fill="#E31E24"/>
            <circle cx="460" cy="230" r="3" fill="#E31E24"/>
            {%- comment -%} Frame triangle — steeper, aggressive {%- endcomment -%}
            <path d="M140 230 L275 100 L375 100 L460 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" fill="none"/>
            <path d="M275 100 L300 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M375 100 L355 230" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            {%- comment -%} Seat post {%- endcomment -%}
            <path d="M300 230 L288 72" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            {%- comment -%} Front fork + drops {%- endcomment -%}
            <path d="M140 230 L158 120 L145 100" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
            {%- comment -%} Key dimension lines {%- endcomment -%}
            <line x1="275" y1="100" x2="375" y2="100" stroke="#E31E24" stroke-width="1" stroke-dasharray="4 3" opacity="0.6"/>
            <text x="325" y="93" fill="#E31E24" font-size="10" text-anchor="middle" font-family="Inter, sans-serif">TOP TUBE</text>
            <line x1="375" y1="100" x2="375" y2="230" stroke="#4ade80" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>
            <text x="390" y="168" fill="#4ade80" font-size="10" font-family="Inter, sans-serif" opacity="0.7">STACK</text>
          </svg>
      {%- endcase -%}
    </div>

    {%- comment -%} ── Stat highlight cards ── {%- endcomment -%}
    <div class="elevate-geometry__stats">
      {%- for line in geo_lines -%}
        {%- assign trimmed = line | strip -%}
        {%- if trimmed == blank -%}{%- continue -%}{%- endif -%}

        {%- assign label_split = trimmed | split: ':' -%}
        {%- assign geo_label = label_split[0] | strip -%}
        {%- assign rest = trimmed | split: ':' | last | strip -%}
        {%- assign val_unit = rest | split: '|' -%}
        {%- assign geo_val = val_unit[0] | strip -%}
        {%- assign geo_unit = val_unit[1] | strip | default: '' -%}

        {%- assign geo_label_lower = geo_label | downcase -%}
        {%- if geo_label_lower == 'stack' or geo_label_lower == 'reach' or geo_label_lower == 'head angle' or geo_label_lower == 'seat angle' -%}
          <div class="elevate-geometry__stat-card">
            <p class="elevate-geometry__stat-label">{{ geo_label }}</p>
            <p class="elevate-geometry__stat-value">
              {{ geo_val }}
              {%- if geo_unit != blank -%}
                <span class="elevate-geometry__stat-unit">{{ geo_unit }}</span>
              {%- endif -%}
            </p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── Full geometry table (collapsible) ── {%- endcomment -%}
    <details class="elevate-geometry__details">
      <summary class="elevate-geometry__summary-btn">
        <span>Full geometry table</span>
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="elevate-geometry__table-wrap">
        <table class="elevate-geometry__table">
          <thead>
            <tr>
              <th>Measurement</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            {%- for line in geo_lines -%}
              {%- assign trimmed = line | strip -%}
              {%- if trimmed == blank -%}{%- continue -%}{%- endif -%}

              {%- assign label_split = trimmed | split: ':' -%}
              {%- assign geo_label = label_split[0] | strip -%}
              {%- assign rest = trimmed | split: ':' | last | strip -%}
              {%- assign val_unit = rest | split: '|' -%}
              {%- assign geo_val = val_unit[0] | strip -%}
              {%- assign geo_unit = val_unit[1] | strip | default: '' -%}

              {%- if geo_label != blank and geo_val != blank -%}
                <tr>
                  <td>{{ geo_label }}</td>
                  <td>{{ geo_val }}{% if geo_unit != blank %} {{ geo_unit }}{% endif %}</td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </details>

  </div>
</div>
{%- endunless -%}

{% stylesheet %}
  /* ─── PDP — Geometry ─── */
  .elevate-geometry {
    padding-block-start: var(--elevate-geometry-pt);
    padding-block-end: var(--elevate-geometry-pb);
    overflow: hidden;
  }

  .elevate-geometry__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: 0.5rem;
  }

  .elevate-geometry__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .elevate-geometry__eyebrow {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    line-height: 1.5;
    letter-spacing: 0.05em;
    color: #E31E24;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-geometry__heading {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }

  /* ── SVG diagram ── */
  .elevate-geometry__diagram {
    width: 100%;
    max-width: 37.5rem;
    margin: 0 auto;
  }

  .elevate-geometry__svg {
    width: 100%;
    height: auto;
  }

  /* ── Stat cards ── */
  .elevate-geometry__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .elevate-geometry__stat-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: rgba(255, 255, 255, 0.06);
    border: 0.0625rem solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 1rem;
  }

  .elevate-geometry__stat-label {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: #AEB2B8;
    text-transform: uppercase;
    margin: 0;
  }

  .elevate-geometry__stat-value {
    font-family: 'Big Shoulders Display', var(--font-heading--family), sans-serif;
    font-weight: 700;
    font-size: 1.75rem;
    line-height: 1;
    color: #fff;
    margin: 0;
  }

  .elevate-geometry__stat-unit {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #AEB2B8;
    margin-left: 0.125rem;
  }

  /* ── Collapsible table ── */
  .elevate-geometry__details {
    border-top: 0.0625rem solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
  }

  .elevate-geometry__summary-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: #fff;
    cursor: pointer;
    list-style: none;
  }

  .elevate-geometry__summary-btn::-webkit-details-marker {
    display: none;
  }

  .elevate-geometry__summary-btn svg {
    transition: transform 0.3s ease;
  }

  .elevate-geometry__details[open] .elevate-geometry__summary-btn svg {
    transform: rotate(180deg);
  }

  .elevate-geometry__table-wrap {
    margin-top: 1rem;
  }

  .elevate-geometry__table {
    width: 100%;
    border-collapse: collapse;
  }

  .elevate-geometry__table thead th {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: #AEB2B8;
    text-transform: uppercase;
    text-align: left;
    padding: 0.5rem 0;
    border-bottom: 0.0625rem solid rgba(255, 255, 255, 0.15);
  }

  .elevate-geometry__table thead th:last-child {
    text-align: right;
  }

  .elevate-geometry__table tbody td {
    font-family: 'Inter', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    padding: 0.625rem 0;
    border-bottom: 0.0625rem solid rgba(255, 255, 255, 0.06);
  }

  .elevate-geometry__table tbody td:first-child {
    color: #AEB2B8;
    font-weight: 400;
  }

  .elevate-geometry__table tbody td:last-child {
    color: #fff;
    font-weight: 500;
    text-align: right;
  }

  .elevate-geometry__table tbody tr:last-child td {
    border-bottom: none;
  }

  /* ─── Desktop ─── */
  @media (min-width: 61.9375rem) {
    .elevate-geometry__inner {
      padding-inline: 4.375rem;
    }

    .elevate-geometry__heading {
      font-size: 2.5rem;
    }

    .elevate-geometry__stats {
      grid-template-columns: repeat(4, 1fr);
    }

    .elevate-geometry__stat-value {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PDP — Geometry",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "GEOMETRY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frame Geometry"
    },
    {
      "type": "select",
      "id": "bike_type",
      "label": "Bike type (diagram)",
      "options": [
        { "value": "road", "label": "Road" },
        { "value": "gravel", "label": "Gravel" },
        { "value": "mtb", "label": "Mountain" }
      ],
      "default": "road"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "PDP — Geometry"
    }
  ]
}
{% endschema %}
