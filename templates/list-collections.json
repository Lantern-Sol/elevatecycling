    "elevate_faq_mEJhLE": {
      "type": "elevate-faq",
      "blocks": {
        "faq_yPdnKD": {
          "type": "faq",
          "settings": {
            "question": "What types of inventory does Elevate carry?",
            "answer": "Elevate carries two types of inventory: brand-new gear sourced directly from brands at below-retail prices, and certified pre-owned gear bought from cyclists. Every item — new or pre-owned — is inspected, cleaned, and fully documented by our in-house mechanics before it goes live. We list condition honestly so you know exactly what you're getting before you decide."
          }
        },
        "faq_9G8k3k": {
          "type": "faq",
          "settings": {
            "question": "How accurate are the condition descriptions?",
            "answer": "Every listing includes Mechanic's Notes written by the tech who inspected the item — specific, honest, and not filtered through a marketing lens. If there's a scratch on the chainstay or wear on the cassette, it'll say so. We'd rather lose a sale than have a customer surprised by something we didn't disclose."
          }
        },
        "faq_wnb7im": {
          "type": "faq",
          "settings": {
            "question": "Can I return an item if it doesn't match the description?",
            "answer": "Yes — we offer a 30-day satisfaction guarantee on all purchases. If the item doesn't match what was described, contact us and we'll make it right. Free return shipping is included for condition discrepancies. We stand behind every listing."
          }
        },
        "faq_d3UKbp": {
          "type": "faq",
          "settings": {
            "question": "How do I know if the geometry fits me?",
            "answer": "Every complete bike listing includes the full geometry table — top tube, stack, reach, head tube angle, and more. If you're unsure, contact our mechanics before you buy. We're familiar with most frames in our catalog and can help you compare to what you're currently riding."
          }
        },
        "faq_ixxAY3": {
          "type": "faq",
          "settings": {
            "question": "How does the sell or trade program work?",
            "answer": "Submit your gear details through our sell form — takes about 2 minutes. We'll send a fair cash or store credit offer within 24hrs. Store credit runs 15–20% higher than cash and can be applied to anything in the catalog. If you accept, we send a free shipping label. Payment is processed within 48hrs of inspection."
          }
        },
        "faq_QEYzmF": {
          "type": "faq",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "Yes. We ship to most countries outside the US. International shipping rates are calculated at checkout based on destination and item weight. Complete bikes ship fully assembled and boxed by our mechanics. All international orders are fully insured and tracked."
          }
        }
      },
