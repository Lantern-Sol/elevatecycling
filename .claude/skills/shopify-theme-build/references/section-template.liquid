{%- comment -%}
  Section scaffold — fill in / rename. Demonstrates house style:
  - scoped class + section.id for instance styles
  - real settings (heading, color_scheme, padding, alignment)
  - blocks with max_blocks
  - semantic, accessible markup
  - rem, mobile-first, no !important, prefers-reduced-motion
  Rename "feature-grid" everywhere to your section's role-based name.
{%- endcomment -%}

<section
  class="feature-grid color-{{ section.settings.color_scheme }}"
  id="shopify-section-{{ section.id }}"
  style="--pad-block: {{ section.settings.padding_block | divided_by: 16.0 }}rem;"
  aria-labelledby="feature-grid-title-{{ section.id }}"
>
  <div class="feature-grid__inner">
    {%- if section.settings.heading != blank -%}
      <h2
        id="feature-grid-title-{{ section.id }}"
        class="feature-grid__title"
        style="text-align: {{ section.settings.alignment }};"
      >
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="feature-grid__list" role="list">
        {%- for block in section.blocks -%}
          <li class="feature-grid__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 64rem) 25vw, (min-width: 48rem) 50vw, 100vw',
                  widths: '300, 400, 600, 800',
                  alt: block.settings.image_alt | default: block.settings.title,
                  class: 'feature-grid__img'
              }}
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="feature-grid__item-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="feature-grid__item-text rte">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
              <a class="feature-grid__link btn" href="{{ block.settings.link_url }}">
                {{ block.settings.link_label | escape }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{%- stylesheet -%}
  .feature-grid {
    padding-block: var(--pad-block, 3rem);
  }
  .feature-grid__inner {
    max-width: 75rem;
    margin-inline: auto;
    padding-inline: 1rem;
  }
  .feature-grid__title {
    font-size: clamp(1.75rem, 1.4rem + 1.5vw, 2.5rem);
    margin-block-end: 1.5rem;
  }
  .feature-grid__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  .feature-grid__img {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }
  .feature-grid__item-title {
    font-size: clamp(1.25rem, 1.1rem + 0.6vw, 1.5rem);
    margin-block: 0.75rem 0.5rem;
  }
  .feature-grid__link:focus-visible {
    outline: 0.1875rem solid currentColor;
    outline-offset: 0.125rem;
  }

  @media (min-width: 48rem) {
    .feature-grid__list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 64rem) {
    .feature-grid__list { grid-template-columns: repeat(4, 1fr); }
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-grid * { transition: none !important; } /* allowed only to kill motion for a11y */
  }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Feature grid",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured" },
    {
      "type": "select",
      "id": "alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_block",
      "label": "Vertical padding",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text", "info": "Describe the image for screen readers. Leave blank if decorative." },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "richtext", "id": "text", "label": "Text" },
        { "type": "url", "id": "link_url", "label": "Link" },
        { "type": "text", "id": "link_label", "label": "Link label" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    { "name": "Feature grid", "blocks": [ { "type": "feature" }, { "type": "feature" }, { "type": "feature" }, { "type": "feature" } ] }
  ]
}
{% endschema %}
