{%- comment -%}
  Elevate Cycling — PDP Sidecar (bottom)
  "Ask a Mechanic" button + trust icons row.
  Rendered inside .elevate-cta-card after buy-buttons.
{%- endcomment -%}

<a href="{{ settings.elevate_ask_mechanic_url | default: '/pages/contact' }}" class="elevate-cta-card__ask-btn">
  Ask a Mechanic
</a>

<script>
  (function () {
    var card = document.querySelector('.elevate-cta-card');
    if (!card) return;

    var arrowSvg = '<svg class="elevate-atc-arrow" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14.0391 5.08594l-1.0782 1.07812L18.0469 11.25H3v1.5h15.0469l-5.086 5.0859 1.0782 1.0782L20.4141 12.539 20.9297 12l-.5156-.5391L14.0391 5.08594z" fill="currentColor"/></svg>';

    function formatPrice(cents) {
      var dollars = (cents / 100).toFixed(2);
      return '$' + dollars.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function updateButton() {
      var btn = card.querySelector('button[name="add"]');
      if (!btn) return;

      var textEl = btn.querySelector('.add-to-cart-text__content span span');
      if (!textEl || textEl.dataset.elevatePatched) return;

      var form = btn.closest('form[action*="/cart/add"]') || btn.closest('form');
      var priceText = '';

      /* Try to read price from the selected variant */
      var selectEl = form ? form.querySelector('select[name="id"]') : null;
      if (selectEl) {
        var opt = selectEl.selectedOptions[0];
        if (opt && opt.dataset.price) {
          priceText = formatPrice(parseInt(opt.dataset.price, 10));
        }
      }

      /* Fallback: read from sidecar price block */
      if (!priceText) {
        var sidecarPrice = document.querySelector('.elevate-sidecar__price');
        if (sidecarPrice) {
          priceText = sidecarPrice.textContent.trim();
        }
      }

      textEl.dataset.elevatePatched = 'true';
      textEl.innerHTML = 'Add to Cart' + (priceText ? ' — ' + priceText : '') + ' ' + arrowSvg;
    }

    /* Run on load + observe for Horizon's async rendering */
    updateButton();
    var observer = new MutationObserver(function () { updateButton(); });
    observer.observe(card, { childList: true, subtree: true });

    /* Update on variant change */
    document.addEventListener('variant:changed', function () {
      var btn = card.querySelector('button[name="add"]');
      if (btn) {
        var textEl = btn.querySelector('.add-to-cart-text__content span span');
        if (textEl) {
          textEl.dataset.elevatePatched = '';
          updateButton();
        }
      }
    });
  })();
</script>

