{%- comment -%} ── B. Product title ── {%- endcomment -%}
<h1 class="elevate-sidecar__title">{{ product.title }}</h1>

{%- comment -%} ── C. eBay stars row ── {%- endcomment -%}
<div class="elevate-sidecar__stars">
  <span class="elevate-sidecar__stars-icons" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
  <span class="elevate-sidecar__stars-pct">99.8%</span>
  <span class="elevate-sidecar__stars-text">Positive feedback on ebay</span>
</div>

{%- comment -%} ── D. Price + MSRP ── {%- endcomment -%}
<div class="elevate-sidecar__price-block">
  <span class="elevate-sidecar__price">
    {{ current_variant.price | money_without_trailing_zeros }}
  </span>
  {%- if has_msrp -%}
    <div class="elevate-sidecar__msrp">
      <span class="elevate-sidecar__msrp-label">
        Retail Price: ~{{ msrp_cents | money_without_trailing_zeros }}
      </span>
      <span class="elevate-sidecar__savings-badge">
        Save ~{{ savings_pct }}% off retail
      </span>
    </div>
  {%- endif -%}
</div>

{%- comment -%} ── E. General Stats ── {%- endcomment -%}
{%- if has_any_stat -%}
  <div class="elevate-stats">
    <div class="elevate-stats__header">
      <span class="elevate-stats__heading">General Stats</span>
      {%- if has_condition -%}
        <span class="elevate-grade">
          <span class="elevate-grade__text">Grade {{ grade_letter }} &mdash; {{ grade_label }}</span>
          <span class="elevate-grade__pill">{{ grade_letter }}</span>
        </span>
      {%- endif -%}
    </div>

    <div class="elevate-stats__grid">
      {%- comment -%} Condition ── {%- endcomment -%}
      {%- if has_condition -%}
        {%- assign condition_width = condition_rating | times: 10 | round -%}
        <div class="elevate-stat">
          <div class="elevate-stat__row">
            <svg class="elevate-stat__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2C6.875 2 6.11719 2.44336 5.4375 2.8125C4.75781 3.18164 4.14062 3.5 3 3.5H2.5V4C2.5 7.85938 3.80469 10.3711 5.125 11.8906C6.44531 13.4102 7.8125 13.9688 7.8125 13.9688L8 14.0312L8.1875 13.9688C8.1875 13.9688 9.55469 13.4219 10.875 11.9062C12.1953 10.3906 13.5 7.87305 13.5 4V3.5H13C11.8652 3.5 11.2422 3.18164 10.5625 2.8125C9.88281 2.44336 9.125 2 8 2ZM8 3C8.875 3 9.37695 3.30664 10.0781 3.6875C10.6699 4.00977 11.4551 4.31836 12.4688 4.42188C12.373 7.80469 11.2539 9.95508 10.125 11.25C9.10156 12.4238 8.24219 12.8145 8 12.9219C7.75586 12.8125 6.89844 12.4121 5.875 11.2344C4.74609 9.93555 3.62695 7.78906 3.53125 4.42188C4.54883 4.31836 5.33008 4.00977 5.92188 3.6875C6.62305 3.30664 7.125 3 8 3Z" fill="#141517"/></svg>
            <span class="elevate-stat__label">Condition</span>
            <span class="elevate-stat__value elevate-stat__value--green">{{ condition_rating }}/10</span>
          </div>
          <div class="elevate-stat__bar">
            <div class="elevate-stat__fill" style="width: {{ condition_width }}%"></div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Mechanical integrity ── {%- endcomment -%}
      {%- if has_mechanical -%}
        {%- assign mech_width = mechanical_integrity | times: 10 | round -%}
        <div class="elevate-stat">
          <div class="elevate-stat__row">
            <svg class="elevate-stat__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2.625 1.375L2.34375 1.64062L1.64062 2.34375L1.375 2.625L1.57812 2.95312L2.625 4.70312L2.76562 4.95312H4.23438L6.23438 6.9375C4.44727 8.73242 2.17383 11.0137 2.09375 11.0937C1.31055 11.877 1.30859 13.1602 2.10938 13.9062C2.89062 14.6777 4.16406 14.6973 4.90625 13.9062C4.91211 13.9004 4.91602 13.8965 4.92188 13.8906L8 10.7969L11.0938 13.9062L11.1406 13.9375C11.9258 14.6777 13.1738 14.6875 13.9062 13.9062V13.8906H13.9219C14.6875 13.1074 14.6953 11.834 13.9062 11.0937L13.8906 11.0781L11.2812 8.48437C13.0371 8.32031 14.4121 6.83789 14.4375 5.04687H14.4531C14.4551 5.03711 14.4531 5.02539 14.4531 5.01562C14.4531 5.00977 14.4531 5.00586 14.4531 5C14.502 4.42187 14.377 3.86914 14.0781 3.39062L13.7344 2.85937L11.4062 5.1875L10.7031 4.45312L13.0781 2.07812L12.3906 1.79687C11.9883 1.625 11.5234 1.5 11 1.5C9.07812 1.5 7.5 3.07812 7.5 5C7.5 5.20898 7.54492 5.39062 7.57812 5.57812C7.35938 5.79687 7.19531 5.97656 6.9375 6.23437L4.95312 4.25V2.76562L4.70312 2.625L2.95312 1.57812L2.625 1.375ZM11 2.5C11.0703 2.5 11.1191 2.54102 11.1875 2.54687L9.29688 4.4375L9.64062 4.79687L11.0469 6.25L11.3906 6.60937L13.375 4.625C13.3848 4.74023 13.4668 4.82422 13.4531 4.95312V5C13.4531 6.37695 12.3301 7.5 10.9531 7.5C10.7695 7.5 10.5469 7.45703 10.2969 7.40625L10.0312 7.35937L9.84375 7.54687L4.20312 13.2031H4.1875V13.2187C3.83203 13.6074 3.21094 13.6172 2.79688 13.2031V13.1875H2.78125C2.39258 12.832 2.38281 12.2109 2.79688 11.7969C2.98633 11.6074 6.65625 7.90625 8.45312 6.10937L8.65625 5.90625L8.57812 5.625C8.53711 5.46289 8.5 5.18359 8.5 5C8.5 3.62305 9.62305 2.5 11 2.5ZM2.78125 2.625L3.95312 3.34375V3.84375L3.84375 3.95312H3.34375L2.625 2.78125L2.78125 2.625ZM10.0938 8.70312L13.2031 11.7969V11.8125H13.2188C13.6074 12.168 13.6172 12.7891 13.2031 13.2031H13.1875V13.2187C12.832 13.6074 12.2109 13.6172 11.7969 13.2031L8.70312 10.0937L10.0938 8.70312Z" fill="#141517"/></svg>
            <span class="elevate-stat__label">Mechanical integrity</span>
            <span class="elevate-stat__value elevate-stat__value--green">{{ mechanical_integrity }}/10</span>
          </div>
          <div class="elevate-stat__bar">
            <div class="elevate-stat__fill" style="width: {{ mech_width }}%"></div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Value vs. retail ── {%- endcomment -%}
      {%- if has_msrp -%}
        <div class="elevate-stat">
          <div class="elevate-stat__row">
            <svg class="elevate-stat__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5L7.84375 2.64062L2.14062 8.40625L1.79688 8.75L2.14062 9.10938L6.89062 13.8594L7.25 14.2031L7.59375 13.8594L13.3594 8.15625L13.5 8V2.5H8ZM8.42188 3.5H12.5V7.57812L7.25 12.7969L3.20312 8.75L8.42188 3.5ZM11 4.5C10.7246 4.5 10.5 4.72461 10.5 5C10.5 5.27539 10.7246 5.5 11 5.5C11.2754 5.5 11.5 5.27539 11.5 5C11.5 4.72461 11.2754 4.5 11 4.5Z" fill="#141517"/></svg>
            <span class="elevate-stat__label">Value vs. retail</span>
            <span class="elevate-stat__value elevate-stat__value--green">{{ savings_pct }}% Less</span>
          </div>
          <div class="elevate-stat__bar">
            <div class="elevate-stat__fill" style="width: {{ savings_pct }}%"></div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} Spec level ── {%- endcomment -%}
      {%- if has_spec -%}
        <div class="elevate-stat">
          <div class="elevate-stat__row">
            <svg class="elevate-stat__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3C4.69141 3 2 5.69141 2 9C2 10.4473 2.51758 11.7754 3.375 12.8125L3.51562 13H12.4844L12.625 12.8125C13.4824 11.7754 14 10.4473 14 9C14 5.69141 11.3086 3 8 3ZM8 4C10.7676 4 13 6.23242 13 9C13 10.1328 12.6035 11.1621 11.9688 12H4.03125C3.39648 11.1621 3 10.1328 3 9C3 6.23242 5.23242 4 8 4ZM8 4.5C7.72461 4.5 7.5 4.72461 7.5 5C7.5 5.27539 7.72461 5.5 8 5.5C8.27539 5.5 8.5 5.27539 8.5 5C8.5 4.72461 8.27539 4.5 8 4.5ZM6 5.03125C5.72461 5.03125 5.5 5.25586 5.5 5.53125C5.5 5.80664 5.72461 6.03125 6 6.03125C6.27539 6.03125 6.5 5.80664 6.5 5.53125C6.5 5.25586 6.27539 5.03125 6 5.03125ZM10 5.03125C9.72461 5.03125 9.5 5.25586 9.5 5.53125C9.5 5.80664 9.72461 6.03125 10 6.03125C10.2754 6.03125 10.5 5.80664 10.5 5.53125C10.5 5.25586 10.2754 5.03125 10 5.03125ZM4.53125 6.5C4.25586 6.5 4.03125 6.72461 4.03125 7C4.03125 7.27539 4.25586 7.5 4.53125 7.5C4.80664 7.5 5.03125 7.27539 5.03125 7C5.03125 6.72461 4.80664 6.5 4.53125 6.5ZM11.3281 6.51562L8.5 8.14062C8.35352 8.05469 8.18164 8 8 8C7.44727 8 7 8.44727 7 9C7 9.55273 7.44727 10 8 10C8.54688 10 8.99219 9.56055 9 9.01562C9 9.00977 9 9.00586 9 9L11.8281 7.39062L11.3281 6.51562ZM4 8.5C3.72461 8.5 3.5 8.72461 3.5 9C3.5 9.27539 3.72461 9.5 4 9.5C4.27539 9.5 4.5 9.27539 4.5 9C4.5 8.72461 4.27539 8.5 4 8.5ZM12 8.5C11.7246 8.5 11.5 8.72461 11.5 9C11.5 9.27539 11.7246 9.5 12 9.5C12.2754 9.5 12.5 9.27539 12.5 9C12.5 8.72461 12.2754 8.5 12 8.5ZM4.53125 10.5C4.25586 10.5 4.03125 10.7246 4.03125 11C4.03125 11.2754 4.25586 11.5 4.53125 11.5C4.80664 11.5 5.03125 11.2754 5.03125 11C5.03125 10.7246 4.80664 10.5 4.53125 10.5ZM11.4688 10.5C11.1934 10.5 10.9688 10.7246 10.9688 11C10.9688 11.2754 11.1934 11.5 11.4688 11.5C11.7441 11.5 11.9688 11.2754 11.9688 11C11.9688 10.7246 11.7441 10.5 11.4688 10.5Z" fill="#141517"/></svg>
