{%- comment -%}
  Elevate Cycling — PDP Sidecar (top)
  Renders above variant-picker + buy-buttons inside _product-details.
  Receives: product (product object)
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign sku = current_variant.sku
  assign msrp_raw = product.metafields.custom.msrp.value
  assign condition_rating = product.metafields.custom.condition_rating.value
  assign mechanical_integrity = product.metafields.custom.mechanical_integrity.value
  assign spec_level = product.metafields.custom.spec_level.value
  assign size_fit = product.metafields.custom.size_fit.value

  comment
    Badge detection from product tags
  endcomment
  assign has_new = false
  assign has_new_arrival = false
  assign has_cpo = false
  assign has_clearance = false

  for tag in product.tags
    assign tag_lower = tag | downcase
    if tag_lower == 'new'
      assign has_new = true
    elsif tag_lower == 'new arrival'
      assign has_new_arrival = true
    elsif tag_lower == 'cpo'
      assign has_cpo = true
    elsif tag_lower == 'clearance'
      assign has_clearance = true
    endif
  endfor

  assign has_any_badge = false
  if has_new or has_new_arrival or has_cpo or has_clearance
    assign has_any_badge = true
  endif

  comment
    MSRP savings calculation
  endcomment
  assign has_msrp = false
  assign savings_pct = 0
  if msrp_raw != blank
    assign msrp_cents = msrp_raw | times: 100 | round
    assign price_cents = current_variant.price
    if msrp_cents > price_cents
      assign has_msrp = true
      assign diff = msrp_cents | minus: price_cents
      assign savings_pct = diff | times: 100 | divided_by: msrp_cents
    endif
  endif

  comment
    Grade derivation from condition_rating
  endcomment
  assign has_condition = false
  assign grade_letter = ''
  assign grade_label = ''
  if condition_rating != blank
    assign has_condition = true
    assign cr_num = condition_rating | times: 1.0
    if cr_num >= 9
      assign grade_letter = 'A+'
      assign grade_label = 'New'
    elsif cr_num >= 8
      assign grade_letter = 'A'
      assign grade_label = 'Like New'
    elsif cr_num >= 7
      assign grade_letter = 'B+'
      assign grade_label = 'Good'
    elsif cr_num >= 6
      assign grade_letter = 'B'
      assign grade_label = 'Fair'
    else
      assign grade_letter = 'C'
      assign grade_label = 'Poor'
    endif
  endif

  comment
    Spec level bar width
  endcomment
  assign spec_width = 0
  if spec_level != blank
    assign spec_lower = spec_level | downcase
    if spec_lower == 'entry'
      assign spec_width = 33
    elsif spec_lower == 'medium'
      assign spec_width = 66
    elsif spec_lower == 'pro'
      assign spec_width = 100
    endif
  endif

  comment
    Determine if stats section should show
  endcomment
  assign has_mechanical = false
  if mechanical_integrity != blank
    assign has_mechanical = true
  endif
  assign has_spec = false
  if spec_level != blank
    assign has_spec = true
  endif
  assign has_any_stat = false
  if has_condition or has_mechanical or has_msrp or has_spec
    assign has_any_stat = true
  endif
-%}

