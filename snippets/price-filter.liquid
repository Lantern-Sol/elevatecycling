{%- doc -%}
  Renders a price filter.

  @param {object} filter - The filter object to render.
  @param {string} filter_style - The filter style, can be 'horizontal' or 'vertical'.
  @param {boolean} [should_render_clear] - Whether to render the clear button.
  @param {string} [id_prefix] - Unique prefix to avoid duplicate IDs when rendered multiple times.

  @example
  {% render 'price-filter', filter: filter, filter_style: 'vertical', id_prefix: 'dialog' %}
{%- enddoc -%}

{%- liquid
  assign is_horizontal = false
  assign is_vertical = false
  if filter_style == 'horizontal'
    assign is_horizontal = true
  elsif filter_style == 'vertical'
    assign is_vertical = true
  endif

  comment
    Range slider values — all in cents (minor units).
    money_without_currency on these gives display values like "10.50",
    but the range inputs need raw cents for integer stepping.
  endcomment
  assign range_max_cents = filter.range_max | default: 0
  assign current_min_cents = filter.min_value.value | default: 0
  assign current_max_cents = filter.max_value.value | default: range_max_cents

  comment
    Percentage positions for the fill track (server-rendered for morph compat).
  endcomment
  if range_max_cents > 0
    assign min_pct = current_min_cents | times: 100.0 | divided_by: range_max_cents
    assign max_pct = current_max_cents | times: 100.0 | divided_by: range_max_cents
  else
    assign min_pct = 0
    assign max_pct = 100
  endif

  comment
    Display values for the price label boxes.
  endcomment
  assign current_min_display = current_min_cents | money_without_currency | strip
  assign current_max_display = current_max_cents | money_without_currency | strip
-%}
{% capture accordion_children %}
  <details
    class="facets__panel"
    {% if filter_style == 'horizontal' %}
      data-auto-close-details="desktop"
    {% endif %}
    {% if filter_style == 'vertical' %}
      open
    {% endif %}
  >
    <summary
      class="facets__summary"
      data-testid="price-filter"
    >
      <span class="facets__label">{{ filter.label }}</span>
      <facet-status-component class="facets__status">
        <template ref="moneyFormat">{{ shop.money_format }}</template>

        <span
          class="hide-when-empty"
          ref="facetStatus"
          data-currency="{{ localization.country.currency.iso_code }}"
          data-range-max="{{ filter.range_max | money_without_currency }}"
        >
          {%- if filter.min_value.value != null or filter.max_value.value != null %}
            {%- if filter.min_value.value != null and filter.max_value.value != null %}
              {{- filter.min_value.value | money | strip_html -}}
              –
              {{- filter.max_value.value | money | strip_html -}}
            {%- elsif filter.min_value.value != null -%}
              {{ filter.min_value.value | money | strip_html }}–{{ filter.range_max | money | strip_html }}

            {%- elsif filter.max_value.value != null -%}
              {{- 0 | money | strip_html -}}
              –
              {{- filter.max_value.value | money | strip_html -}}
            {%- endif -%}
          {%- endif -%}
        </span>
      </facet-status-component>
      <span class="svg-wrapper icon-caret icon-animated">
        {{- 'icon-caret-custom.svg' | inline_asset_content -}}
      </span>
    </summary>
    <floating-panel-component
      {% unless filter_style == 'vertical' %}
        data-close-on-resize
      {% endunless %}
      class="facets__panel-content details-content{% if filter_style == 'horizontal' %} color-custom-popover{% endif %}"
    >
      {% assign min_input_max_value = filter.max_value.value | default: filter.range_max %}
      {% assign max_input_min_value = filter.min_value.value | default: 0 %}

      <price-facet-component
        class="
          price-facet
          {%- if filter_style == 'horizontal' %}
            price-facet--horizontal
          {%- endif %}
        "
        id="facet-inputs-{{ filter.param_name | escape | replace: '.', '-' }}"
        data-money-format="{{ shop.money_format | strip_html }}"
        data-currency="{{ localization.country.currency.iso_code }}"
        on:change="/updatePriceFilterAndResults"
      >
        {%- comment -%} Hidden text inputs — PriceFacetComponent reads these via ref {%- endcomment -%}
        <div class="price-slider__hidden-inputs">
          <input
            class="field__input price-facet__input"
            name="{{ filter.min_value.param_name }}"
            id="{{ filter.label | escape }}-GTE-{{ id_prefix }}"
            {%- if filter.min_value.value -%}
              value="{{ filter.min_value.value | money_without_currency }}"
            {%- endif -%}
            type="text"
            inputmode="decimal"
            placeholder="0"
            data-min="0"
            data-max="{{ min_input_max_value | money_without_currency }}"
            ref="minInput"
            autocomplete="off"
            aria-label="{{ 'accessibility.price_filter_low' | t }}"
          >
          <input
            class="field__input price-facet__input"
            name="{{ filter.max_value.param_name }}"
            id="{{ filter.label | escape }}-LTE-{{ id_prefix }}"
            {%- if filter.max_value.value -%}
              value="{{ filter.max_value.value | money_without_currency }}"
            {%- endif -%}
            type="text"
            inputmode="decimal"
            placeholder="{{ filter.range_max | money_without_currency }}"
            data-min="{{ max_input_min_value | money_without_currency }}"
            data-max="{{ filter.range_max | money_without_currency }}"
            ref="maxInput"
            autocomplete="off"
            aria-label="{{ 'accessibility.price_filter_high' | t }}"
          >
        </div>

        {%- comment -%} Dual range slider {%- endcomment -%}
        <div class="price-slider"
          data-range-max="{{ range_max_cents }}"
          data-currency-symbol="{{ cart.currency.symbol }}"
          style="--min-pct: {{ min_pct }}%; --max-pct: {{ max_pct }}%;"
        >
          <div class="price-slider__track-wrap">
            <div class="price-slider__track"></div>
            <div class="price-slider__fill"></div>
            <input type="range" class="price-slider__range price-slider__range--min"
              min="0" max="{{ range_max_cents }}"
              value="{{ current_min_cents }}" step="1"
              aria-label="Minimum price">
            <input type="range" class="price-slider__range price-slider__range--max"
              min="0" max="{{ range_max_cents }}"
              value="{{ current_max_cents }}" step="1"
              aria-label="Maximum price">
          </div>
          <div class="price-slider__labels">
            <span class="price-slider__label" data-role="min">{{ cart.currency.symbol }}{{ current_min_display }}</span>
            <span class="price-slider__label" data-role="max">{{ cart.currency.symbol }}{{ current_max_display }}</span>
          </div>
        </div>

        {% if filter.min_value.value != null or filter.max_value.value != null %}
          {% assign has_active_values = true %}
        {% endif %}

        {% if should_render_clear %}
          <facet-clear-component
            class="clear-filter"
            tabindex="{% if has_active_values %}0{% else %}-1{% endif %}"
            on:click="/clearFilter"
            on:keydown="/clearFilter"
          >
            <div
              class="facets__clear {% if has_active_values %}facets__clear--active{% endif %}"
              ref="clearButton"
            >
              {{- 'actions.clear' | t -}}
            </div>
          </facet-clear-component>
        {% endif %}
      </price-facet-component>
    </floating-panel-component>
  </details>
{% endcapture %}
{% render 'accordion-custom-component',
  children: accordion_children,
  class: 'facets__item',
  open: is_vertical,
  open_by_default_on_desktop: is_vertical,
  open_by_default_on_mobile: is_vertical,
  disable_animation_on_desktop: is_horizontal,
  close_with_escape: is_horizontal
%}

{% stylesheet %}
  /* Price filter */
  .price-facet {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
  }
  .price-facet--horizontal {
    min-width: 360px;
  }

  /* Hidden text inputs — kept in DOM for PriceFacetComponent refs */
  .price-slider__hidden-inputs {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  /* ── Dual range slider ── */
  .price-slider {
    padding: 0.5rem 0 0;
  }

  .price-slider__track-wrap {
    position: relative;
    height: 2.5rem;
  }

  /* Gray base track — z-index 0 (bottom layer) */
  .price-slider__track {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 0.25rem;
    background: hsla(216, 5%, 72%, 1);
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
  }

  /* Red fill between thumbs — z-index 1 (above track, below inputs) */
  .price-slider__fill {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 0.25rem;
    background: #E31E24;
    border-radius: 999px;
    pointer-events: none;
    left: var(--min-pct);
    right: calc(100% - var(--max-pct));
    z-index: 1;
  }

  /* Range inputs — z-index 2+ (above fill, thumbs must be interactive) */
  .price-slider__range {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    height: 0;
    margin: 0;
    padding: 0;
    background: transparent;
    pointer-events: none;
    -webkit-appearance: none;
    appearance: none;
    outline: none;
  }

  /* Webkit — native track transparent */
  .price-slider__range::-webkit-slider-runnable-track {
    background: transparent;
    border: none;
    height: 0;
  }

  /* Webkit thumb — margin-top pulls it up to center on the track */
  .price-slider__range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 2.5rem;
    height: 1.5rem;
    margin-top: -0.75rem;
    background: #E31E24;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    pointer-events: auto;
  }

  /* Firefox — native track transparent */
  .price-slider__range::-moz-range-track {
    background: transparent;
    border: none;
    height: 0;
  }

  /* Firefox thumb */
  .price-slider__range::-moz-range-thumb {
    width: 2.5rem;
    height: 1.5rem;
    background: #E31E24;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    pointer-events: auto;
  }

  /* Stacking: max above min, active/focus on top */
  .price-slider__range--min {
    z-index: 2;
  }
  .price-slider__range--max {
    z-index: 3;
  }
  .price-slider__range--min:active,
  .price-slider__range--min:focus {
    z-index: 4;
  }

  /* ── Price label boxes ── */
  .price-slider__labels {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .price-slider__label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 5.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid #AEB2B8;
    border-radius: 1rem;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    color: #141517;
    white-space: nowrap;
  }
{% endstylesheet %}

{{ 'elevate-price-slider.js' | asset_url | script_tag }}
