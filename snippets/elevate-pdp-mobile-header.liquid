{%- comment -%}
  Elevate Cycling — PDP Mobile Header
  Mobile-only duplicate of sidecar header (breadcrumbs, badges, title, stars, price).
  Rendered inside the media column BEFORE the gallery so mobile sees:
  header → gallery → sidecar body.
  Hidden on desktop via display:none at min-width:750px.
  Receives: product (product object)
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign sku = current_variant.sku
  assign msrp_raw = product.metafields.custom.msrp.value

  comment
    Badge detection from product tags
  endcomment
  assign has_new = false
  assign has_new_arrival = false
  assign has_cpo = false
  assign has_clearance = false

  for tag in product.tags
    assign tag_lower = tag | downcase
    if tag_lower == 'new'
      assign has_new = true
    elsif tag_lower == 'new arrival'
      assign has_new_arrival = true
    elsif tag_lower == 'cpo'
      assign has_cpo = true
    elsif tag_lower == 'clearance'
      assign has_clearance = true
    endif
  endfor

  assign has_any_badge = false
  if has_new or has_new_arrival or has_cpo or has_clearance
    assign has_any_badge = true
  endif

  comment
    MSRP savings calculation
  endcomment
  assign has_msrp = false
  assign savings_pct = 0
  if msrp_raw != blank
    assign msrp_cents = msrp_raw | times: 100 | round
    assign price_cents = current_variant.price
    if msrp_cents > price_cents
      assign has_msrp = true
      assign diff = msrp_cents | minus: price_cents
      assign savings_pct = diff | times: 100 | divided_by: msrp_cents
    endif
  endif

  comment
    Compare-at discount calculation
  endcomment
  assign has_compare = false
  assign discount_pct = 0
  if current_variant.compare_at_price > current_variant.price
    assign has_compare = true
    assign compare_diff = current_variant.compare_at_price | minus: current_variant.price
    assign discount_pct = compare_diff | times: 100 | divided_by: current_variant.compare_at_price
  endif
-%}

<div class="elevate-mobile-header">
  {%- comment -%} ── Breadcrumbs ── {%- endcomment -%}
  {% render 'elevate-breadcrumbs-nav' %}

  {%- comment -%} ── Badges row + SKU ── {%- endcomment -%}
  {%- if has_any_badge or sku != blank -%}
    <div class="elevate-mobile-header__badges-row">
      <div class="elevate-mobile-header__badges">
        {%- if has_new -%}
          <span class="elevate-badge elevate-badge--new">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M15.168 6.27344L10.082 5.73633L8 1.06641L5.91797 5.73633L0.832031 6.27344L4.63086 9.69727L3.57031 14.6992L8 12.1445L12.4297 14.6992L11.3691 9.69727L15.168 6.27344Z" fill="currentColor"/></svg>
            New
          </span>
        {%- endif -%}
        {%- if has_new_arrival -%}
